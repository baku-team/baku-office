---
import "../styles/app.css";
import { atLeast } from "@baku-office/shared";
const env = Astro.locals.runtime.env;
interface Props { title: string; active?: string; auth?: boolean; bare?: boolean }
const { title, active = "", auth = true, bare = false } = Astro.props as Props;

const { getSession } = await import("../lib/auth.ts");
const ses = await getSession(env, Astro.request).catch(() => null);

// ストロークアイコン（24x24・README icons.jsx 由来）。
const ICONS: Record<string, string> = {
  home: "M3 11.2 12 4l9 7.2M5 9.6V20h5v-5.5h4V20h5V9.6",
  spark: "M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8z",
  grid: "M4 4h6v6H4zM14 4h6v6h-6zM4 14h6v6H4zM14 14h6v6h-6z",
  gear: "M12 9.2a2.8 2.8 0 100 5.6 2.8 2.8 0 000-5.6M19.4 12c0-.5 0-1-.1-1.4l2-1.5-2-3.4-2.3 1a7 7 0 00-2.4-1.4L14.2 2H9.8l-.4 2.3a7 7 0 00-2.4 1.4l-2.3-1-2 3.4 2 1.5c-.1.4-.1.9-.1 1.4s0 1 .1 1.4l-2 1.5 2 3.4 2.3-1a7 7 0 002.4 1.4l.4 2.3h4.4l.4-2.3a7 7 0 002.4-1.4l2.3 1 2-3.4-2-1.5c.1-.4.1-.9.1-1.4",
  bell: "M6 16V11a6 6 0 0112 0v5l2 2H4zM9.5 20a2.5 2.5 0 005 0",
  moon: "M20 13.5A8 8 0 119.5 4 6.5 6.5 0 0020 13.5z",
  sun: "M12 6.5V3M12 21v-3.5M6.5 12H3M21 12h-3.5M7 7 4.8 4.8M19.2 19.2 17 17M17 7l2.2-2.2M4.8 19.2 7 17M12 8.5a3.5 3.5 0 100 7 3.5 3.5 0 000-7z",
  card: "M3 6h18v12H3zM3 10h18",
  logout: "M9 5H5v14h4M14 8l4 4-4 4M18 12H9",
};
const navIcon: Record<string, string> = { "/": "home", "/chat": "spark", "/apps": "grid", "/settings": "gear" };
const iconFor = (href: string) => ICONS[navIcon[href] ?? "home"] ?? ICONS.home;

// 4項目ナビ（ホーム/AI/アプリ/設定）。業務画面は「アプリ」からランチャー起動、各種設定は「設定」に集約。
type Item = { href: string; label: string; show: boolean };
const items: Item[] = [
  { href: "/", label: "ホーム", show: true },
  { href: "/chat", label: "AI", show: true },
  { href: "/apps", label: "アプリ", show: true },
  { href: "/settings", label: "設定", show: true },
];

// UIカスタマイズ（共通ベース＋団体ごと上書き）。レイアウトの各データは並列取得して直列待ちを排除。
const ctx = Astro.locals.ctx;
const [themeMod, navMod, diagMod, notifMod, clientMod] = await Promise.all([
  import("../core/theme.ts"), import("../core/nav.ts"), import("../lib/diag.ts"), import("../lib/notifications.ts"), import("../lib/client.ts"),
]);
const [theme, navOv, limitErr, unreadNotif, entitlement] = await Promise.all([
  themeMod.getTheme(ctx).catch(() => ({}) as import("../core/theme.ts").ThemeConfig),
  navMod.getNavOverrides(ctx).catch(() => null),
  diagMod.hasRecentLimitError(env).catch(() => false),
  ses ? notifMod.countUnread(ctx, ses.uid).catch(() => 0) : Promise.resolve(0),
  ses ? clientMod.cachedEntitlement(env).catch(() => "free" as const) : Promise.resolve("free" as const),
]);
const themeStyle = themeMod.themeCss(theme);
const brand = themeMod.brandName(theme);
const logoUrl = theme.logoUrl;
const navItems = navMod.buildNav(items, [], navOv);
// 相棒（エージェント）マスコット：既定は貘キャラ。Pro未満は「眠っている」表示。
const mascotUrl = theme.mascotUrl || "/mascot/baku.png";
const agentAwake = atLeast(entitlement, "pro");
// ユーザーチップ表示用。
const uname = ses?.name ?? ses?.role ?? "";
const initial = (uname || "B").slice(0, 1).toUpperCase();
const firstName = ses?.name ?? (ses?.role ?? "ユーザー");
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      // テーマ・ナビ形態の初期適用（描画前に data-theme / data-nav を確定＝ちらつき防止）。
      (function () { try {
        var t = localStorage.getItem("bo_theme"); document.documentElement.setAttribute("data-theme", t === "dark" ? "dark" : "light");
        var n = localStorage.getItem("bo_nav"); document.documentElement.setAttribute("data-nav", (n === "side" || n === "top") ? n : "bottom");
      } catch (e) {} })();
    </script>
    <title>{title} — {brand}</title>
    {themeStyle && <style set:html={themeStyle}></style>}
  </head>
  <body>
    <div id="bo-progress" aria-hidden="true"></div>
    <div class="app">
    {auth && ses && (
      <aside class="sidebar">
        <a class="sb-brand" href="/"><span class="mark"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={ICONS.spark} /></svg></span>{brand}</a>
        <nav class="sb-nav" aria-label="サイドナビ">
          {navItems.map((i) => (
            <a href={i.href} data-astro-prefetch="viewport" aria-current={active === i.href ? "page" : undefined}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={iconFor(i.href)} /></svg>
              {i.label}
            </a>
          ))}
        </nav>
      </aside>
    )}
    <div class="shell">
    {auth && (
      <header class="appbar">
        <div class="appbar-inner">
          <span class="brand-wrap">
            <a class="brand" href="/">
              {logoUrl
                ? <img src={logoUrl} alt={brand} style="height:24px;vertical-align:middle" />
                : <><span class="mark"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={ICONS.spark} /></svg></span>{brand}</>}
            </a>
            <span class="beta-badge" title="本サービスは現在ベータ（試験提供）版です。現在は Test ユーザーのみ利用できます。">β版</span>
          </span>
          <nav class="nav">
            {navItems.map((i) => (
              <a href={i.href} data-astro-prefetch="viewport" aria-current={active === i.href ? "page" : undefined}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={iconFor(i.href)} /></svg>
                {i.label}
              </a>
            ))}
          </nav>
          <span class="user">
            <button class="iconbtn" id="bo-theme" type="button" title="ダーク" aria-label="テーマを切り替え">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path id="bo-theme-ico" d={ICONS.moon} /></svg>
            </button>
            {ses && (
              <a href="#" class="iconbtn" id="bo-bell" title="通知" aria-label="通知">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={ICONS.bell} /></svg>
                {unreadNotif > 0 && <span id="bo-bell-badge" class="badge-num">{unreadNotif}</span>}
              </a>
            )}
            {ses
              ? (
                <span style="position:relative">
                  <button class="userchip" id="bo-user" type="button" aria-haspopup="menu" aria-expanded="false">
                    <span class="avatar">{initial}</span>
                    <span class="nm">{firstName}<small>{ses.role}</small></span>
                  </button>
                  <div class="menu-ov" id="bo-user-ov" hidden></div>
                  <div class="usermenu fade-up" id="bo-user-menu" role="menu" hidden>
                    <div class="um-head"><span class="avatar" style="width:38px;height:38px;font-size:.95rem">{initial}</span><div><strong>{firstName}</strong><div class="muted" style="font-size:.8rem">{ses.ctx === "org" ? "組織" : "個人"}・{ses.role}</div></div></div>
                    <a class="um-item" href="/settings" role="menuitem"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={ICONS.gear} /></svg> 設定</a>
                    <a class="um-item" href="/billing" role="menuitem"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={ICONS.card} /></svg> プラン・課金</a>
                    <div class="hr" style="margin:6px 0"></div>
                    <button class="um-item danger" id="bo-logout" type="button" role="menuitem"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={ICONS.logout} /></svg> ログアウト</button>
                  </div>
                </span>
              )
              : <a class="btn btn-sm" href="/login">ログイン</a>}
          </span>
        </div>
      </header>
    )}
    {bare ? <slot /> : (
      <main class="wrap">
        {limitErr && (
          <div class="banner banner-danger">
            ⚠️ 直近に Cloudflare 無料枠の制限に達した可能性があります。重い処理を安定させるには
            <a href="/settings/advanced">高度なオプション → Workers Paid</a> をご検討ください（<a href="/diagnostics">診断</a>）。
          </div>
        )}
        <slot />
      </main>
    )}
    </div>
    {auth && ses && (
      <nav class="tabbar" aria-label="メインナビ">
        {navItems.map((i) => (
          <a href={i.href} data-astro-prefetch="viewport" aria-current={active === i.href ? "page" : undefined}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={active === i.href ? "2.2" : "1.8"} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={iconFor(i.href)} /></svg>
            {i.label}
          </a>
        ))}
      </nav>
    )}
    </div>
    {auth && ses && (
      <>
        <button class={"bo-agent " + (agentAwake ? "idle" : "asleep")} id="bo-agent" type="button" data-awake={agentAwake ? "1" : "0"} title="相棒（AI・エージェント）" aria-label="相棒（AI・エージェント）の稼働状況">
          <span class="bo-agent-dots" aria-hidden="true"><i></i><i></i><i></i></span>
          <span class="bo-agent-zzz" aria-hidden="true">z<small>z</small></span>
          <span class="bo-agent-sprite-wrap">
            <img class="bo-agent-img" src={mascotUrl} alt="相棒" width="88" height="88" decoding="async" />
          </span>
          <span class="bo-agent-badge" id="bo-agent-badge"></span>
        </button>
        <div class="bo-agent-pop" id="bo-agent-pop" hidden></div>
      </>
    )}
    <div id="toasts" aria-live="polite"></div>
    <div id="bo-notif" hidden style="position:fixed;top:52px;right:12px;width:320px;max-height:70vh;overflow:auto;background:var(--surface);border:1px solid var(--line);border-radius:10px;box-shadow:var(--shadow-lg);z-index:50;padding:8px"></div>

    <script>
      // 共通フィードバック：トースト＋fetchラッパ。全操作で必ず成否を可視化する。
      type ApiOpts = { btn?: HTMLButtonElement | null; method?: string; errMsg?: string | null; successMsg?: string | null };
      const wrap = document.getElementById("toasts");
      // 上部進捗バー（ホスト/API通信中・画面遷移中）。参照カウントで多重に耐える。
      const progEl = document.getElementById("bo-progress");
      let progCount = 0; let progTimer: number | null = null; let progW = 0;
      function progStart() {
        progCount++;
        if (!progEl || progCount > 1) return;
        progW = 8; progEl.classList.add("on"); progEl.style.width = "8%";
        progTimer = window.setInterval(() => { progW = Math.min(92, progW + (92 - progW) * 0.18); progEl.style.width = progW + "%"; }, 240);
      }
      function progDone() {
        progCount = Math.max(0, progCount - 1);
        if (!progEl || progCount > 0) return;
        if (progTimer) { clearInterval(progTimer); progTimer = null; }
        progEl.style.width = "100%";
        window.setTimeout(() => { progEl.classList.remove("on"); progEl.style.width = "0"; progW = 0; }, 260);
      }
      function toast(msg: string, kind = "ok") {
        // エラーは assertive で即読み上げ（成功/情報は polite）。
        if (wrap) wrap.setAttribute("aria-live", kind === "err" ? "assertive" : "polite");
        const el = document.createElement("div");
        el.className = "toast " + (kind === "err" ? "err" : kind === "info" ? "info" : "ok");
        el.textContent = msg;
        wrap?.appendChild(el);
        requestAnimationFrame(() => el.classList.add("show"));
        setTimeout(() => { el.classList.remove("show"); setTimeout(() => el.remove(), 250); }, kind === "err" ? 5000 : 2800);
      }
      // ボタン押下中の視覚状態。
      function busy(btn: HTMLButtonElement | null, on: boolean) {
        if (!btn) return;
        if (on) { btn.disabled = true; btn.dataset.label = btn.innerHTML; btn.innerHTML = '<span class="spin"></span>処理中…'; }
        else { btn.disabled = false; if (btn.dataset.label) btn.innerHTML = btn.dataset.label; }
      }
      // JSON API 呼び出し＋自動トースト。成功/失敗を必ず表示。通信中は上部進捗バーを表示。
      async function api(url: string, body?: unknown, opts: ApiOpts = {}) {
        const btn = opts.btn ?? null; busy(btn, true); progStart();
        try {
          const r = await fetch(url, { method: opts.method || "POST", headers: { "content-type": "application/json" }, body: body !== undefined ? JSON.stringify(body) : undefined });
          let j: any = {}; try { j = await r.json(); } catch { /* non-json */ }
          if (!r.ok || j.error) { toast(opts.errMsg || ("エラー：" + (j.error || r.status)), "err"); return { ok: false, data: j }; }
          if (opts.successMsg !== null) toast(opts.successMsg || "完了しました", "ok");
          return { ok: true, data: j };
        } catch (e) {
          toast("通信に失敗しました：" + ((e as Error)?.message || ""), "err"); return { ok: false, error: e };
        } finally { busy(btn, false); progDone(); }
      }
      // 確認ダイアログ（危険操作の統一・§9）。window.confirm を置換し、リスクラベル・取消不可表示・
      // 監査ログ導線を標準化。Promise<boolean> を返す。a11y: role=dialog/aria-modal・フォーカストラップ・
      // ESC=キャンセル・既定フォーカスはキャンセル（誤確定の防止）。
      type ConfirmOpts = { title?: string; confirmLabel?: string; cancelLabel?: string; danger?: boolean; irreversible?: boolean; auditHref?: string };
      let boModalSeq = 0;
      function confirmDialog(message: string, opts: ConfirmOpts = {}): Promise<boolean> {
        return new Promise((resolve) => {
          const prev = document.activeElement as HTMLElement | null;
          const ov = document.createElement("div");
          ov.className = "bo-modal-ov";
          ov.setAttribute("role", "presentation");
          const dlg = document.createElement("div");
          dlg.className = "bo-modal";
          dlg.setAttribute("role", "dialog");
          dlg.setAttribute("aria-modal", "true");
          const uid = "bo-m" + (++boModalSeq); // 同時表示でもID衝突しないよう連番化。
          const titleId = uid + "t", descId = uid + "d";
          dlg.setAttribute("aria-labelledby", titleId);
          dlg.setAttribute("aria-describedby", descId);
          const danger = !!opts.danger || !!opts.irreversible;
          const h = document.createElement("h2");
          h.id = titleId; h.className = "bo-modal-title"; h.textContent = opts.title || (danger ? "確認" : "確認");
          const p = document.createElement("p");
          p.id = descId; p.className = "bo-modal-msg"; p.textContent = message;
          dlg.appendChild(h); dlg.appendChild(p);
          if (opts.irreversible) {
            const w = document.createElement("p");
            w.className = "bo-modal-warn"; w.textContent = "⚠ この操作は取り消せません。";
            dlg.appendChild(w);
          }
          if (opts.auditHref) {
            const a = document.createElement("a");
            a.href = /^(\/|#)/.test(opts.auditHref) ? opts.auditHref : "#";
            a.className = "bo-modal-audit"; a.textContent = "操作履歴（監査ログ）を見る";
            dlg.appendChild(a);
          }
          const row = document.createElement("div");
          row.className = "bo-modal-row";
          const cancel = document.createElement("button");
          cancel.type = "button"; cancel.className = "btn"; cancel.textContent = opts.cancelLabel || "キャンセル";
          const ok = document.createElement("button");
          ok.type = "button"; ok.className = "btn " + (danger ? "btn-danger" : "btn-primary"); ok.textContent = opts.confirmLabel || "実行";
          row.appendChild(cancel); row.appendChild(ok);
          dlg.appendChild(row);
          ov.appendChild(dlg);
          document.body.appendChild(ov);

          const close = (val: boolean) => {
            document.removeEventListener("keydown", onKey, true);
            ov.remove();
            if (prev && typeof prev.focus === "function") prev.focus();
            resolve(val);
          };
          const onKey = (e: KeyboardEvent) => {
            if (e.key === "Escape") { e.preventDefault(); close(false); }
            else if (e.key === "Tab") {
              // ダイアログ内の全フォーカス可能要素を巡回（監査リンクも到達可能に）。
              const f = Array.from(dlg.querySelectorAll<HTMLElement>("a[href],button")).filter((el) => !el.hasAttribute("disabled"));
              if (!f.length) { e.preventDefault(); return; }
              const i = f.indexOf(document.activeElement as HTMLElement);
              e.preventDefault();
              const next = e.shiftKey ? (i <= 0 ? f.length - 1 : i - 1) : (i >= f.length - 1 ? 0 : i + 1);
              f[next].focus();
            }
          };
          document.addEventListener("keydown", onKey, true);
          ov.addEventListener("mousedown", (e) => { if (e.target === ov) close(false); });
          cancel.addEventListener("click", () => close(false));
          ok.addEventListener("click", () => close(true));
          cancel.focus(); // 既定はキャンセル＝誤確定を防ぐ
        });
      }
      (window as any).bo = { toast, busy, api, confirm: confirmDialog, progress: { start: progStart, done: progDone } };

      // 画面遷移（内部リンク/フォーム送信）でも進捗バーを表示。フルページ遷移は新ページ読込で自然にリセット。
      document.addEventListener("click", (e) => {
        const a = (e.target as HTMLElement)?.closest?.("a[href]") as HTMLAnchorElement | null;
        if (!a) return;
        if (e.defaultPrevented || (e as MouseEvent).button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        if (a.target === "_blank" || a.hasAttribute("download")) return;
        const href = a.getAttribute("href") || "";
        if (!href || href.startsWith("#") || href.startsWith("javascript:")) return;
        if (a.host && a.host !== location.host) return; // 外部リンクは除外
        progStart(); window.setTimeout(progDone, 8000); // 遷移しなかった場合の保険
      }, true);
      document.addEventListener("submit", (e) => { const f = e.target as HTMLFormElement; if (f && f.method && f.method.toLowerCase() === "get") { progStart(); window.setTimeout(progDone, 8000); } }, true);
      window.addEventListener("pageshow", () => { progCount = 0; if (progEl) { progEl.classList.remove("on"); progEl.style.width = "0"; } });

      // テーマ切替（ダーク/ライト）。切替の一瞬だけ theme-switching でトランジション抑制。
      const MOON = "M20 13.5A8 8 0 119.5 4 6.5 6.5 0 0020 13.5z";
      const SUN = "M12 6.5V3M12 21v-3.5M6.5 12H3M21 12h-3.5M7 7 4.8 4.8M19.2 19.2 17 17M17 7l2.2-2.2M4.8 19.2 7 17M12 8.5a3.5 3.5 0 100 7 3.5 3.5 0 000-7z";
      const rootEl = document.documentElement;
      const themeBtn = document.getElementById("bo-theme");
      function syncThemeIco() {
        const dark = rootEl.getAttribute("data-theme") === "dark";
        const ico = document.getElementById("bo-theme-ico");
        if (ico) ico.setAttribute("d", dark ? SUN : MOON);
        if (themeBtn) themeBtn.title = dark ? "ライト" : "ダーク";
      }
      syncThemeIco();
      themeBtn?.addEventListener("click", () => {
        const dark = rootEl.getAttribute("data-theme") !== "dark";
        rootEl.classList.add("theme-switching");
        rootEl.setAttribute("data-theme", dark ? "dark" : "light");
        try { localStorage.setItem("bo_theme", dark ? "dark" : "light"); } catch (e) { /* noop */ }
        requestAnimationFrame(() => requestAnimationFrame(() => rootEl.classList.remove("theme-switching")));
        syncThemeIco();
      });

      // ユーザーメニュー（設定/課金/ログアウト）。
      const uBtn = document.getElementById("bo-user");
      const uMenu = document.getElementById("bo-user-menu");
      const uOv = document.getElementById("bo-user-ov");
      function closeUser() { if (uMenu) uMenu.hidden = true; if (uOv) uOv.hidden = true; uBtn?.setAttribute("aria-expanded", "false"); }
      if (uBtn && uMenu) {
        uBtn.addEventListener("click", () => {
          const open = uMenu.hidden;
          uMenu.hidden = !open; if (uOv) uOv.hidden = !open;
          uBtn.setAttribute("aria-expanded", String(open));
        });
        uOv?.addEventListener("click", closeUser);
        document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeUser(); });
      }

      const lo = document.getElementById("bo-logout");
      if (lo) lo.addEventListener("click", async (e) => { e.preventDefault(); await fetch("/api/login", { method: "DELETE" }); location.href = "/login"; });
      // 通知ベル：クリックで一覧をパネル表示し、開いたら全既読にしてバッジを消す。
      const bell = document.getElementById("bo-bell");
      const panel = document.getElementById("bo-notif");
      if (bell && panel) {
        bell.addEventListener("click", async (e) => {
          e.preventDefault();
          if (!panel.hidden) { panel.hidden = true; return; }
          const r = await api("/api/notifications", undefined, { method: "GET", successMsg: null });
          const items = (r.ok && r.data.items) || [];
          panel.replaceChildren();
          if (items.length) {
            for (const n of items as any[]) {
              const a = document.createElement("a");
              const link = String(n.link || "#");
              // javascript: 等のスキーム注入を排除し、相対/http(s)/#のみ許可。
              a.href = /^(https?:|\/|#)/.test(link) ? link : "#";
              a.style.cssText = "display:block;padding:8px;border-bottom:1px solid var(--line);color:var(--ink);text-decoration:none;" + (n.read_at ? "opacity:.55" : "font-weight:600");
              a.textContent = String(n.body || "");
              panel.appendChild(a);
            }
          } else {
            const p = document.createElement("p");
            p.style.cssText = "padding:10px;color:var(--muted);font-size:.85rem;margin:0";
            p.textContent = "通知はありません";
            panel.appendChild(p);
          }
          panel.hidden = false;
          if (items.some((n: any) => !n.read_at)) {
            await api("/api/notifications", { _action: "read" }, { successMsg: null });
            document.getElementById("bo-bell-badge")?.remove();
          }
        });
        document.addEventListener("click", (e) => {
          if (!panel.hidden && !panel.contains(e.target as Node) && e.target !== bell) panel.hidden = true;
        });
      }
      // エージェント稼働マスコット：/api/activity を定期取得して相棒の動きに反映（全ページ共通）。
      const agentEl = document.getElementById("bo-agent");
      const agentPop = document.getElementById("bo-agent-pop");
      const agentBadge = document.getElementById("bo-agent-badge");
      if (agentEl && agentPop && agentBadge) {
        const KIND: Record<string, string> = { agent: "🤖", summary: "📝", video: "🎬" };
        const KLABEL: Record<string, string> = { agent: "AIエージェント", summary: "ファイル要約", video: "動画生成" };
        let agentTasks: { kind: string; status: string; label: string }[] = [];
        const escHtml = (s: string) => s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c] as string));
        function renderPop() {
          if (!agentTasks.length) { agentPop!.innerHTML = '<h4>相棒は待機中です</h4><div class="muted" style="font-size:.8rem">いまバックグラウンドで動いているタスクはありません。</div>'; return; }
          let h = '<h4><span class="spin"></span>稼働中のタスク ' + agentTasks.length + " 件</h4>";
          for (const t of agentTasks) h += '<div class="bo-agent-task"><span class="k">' + (KIND[t.kind] || "⚙") + '</span><span class="t">' + escHtml(t.label || KLABEL[t.kind] || "処理") + '</span><span class="s">' + (t.status === "running" ? "実行中" : "待機") + "</span></div>";
          agentPop!.innerHTML = h;
        }
        async function pollAgent() {
          try {
            const r = await fetch("/api/activity", { headers: { accept: "application/json" } }); // 進捗バーは出さない（静かに監視）
            if (!r.ok) return;
            const d: any = await r.json();
            agentTasks = d.tasks || [];
            const n = d.active || 0;
            agentEl!.classList.toggle("working", n > 0);
            agentEl!.classList.toggle("idle", n === 0);
            agentBadge!.textContent = n > 0 ? String(n) : "";
            if (!agentPop!.hidden) renderPop();
          } catch { /* offline */ }
        }
        (window as any).bo.pollAgent = pollAgent;
        const agentAwake = agentEl.dataset.awake === "1";
        // クリック：稼働中→進捗（吹き出し）／何もしていなければチャットで対話（なにか御用ですか？）。
        agentEl.addEventListener("click", () => {
          if (agentEl.classList.contains("working")) { agentPop.hidden = !agentPop.hidden; if (!agentPop.hidden) renderPop(); return; }
          location.href = "/chat?greet=1";
        });
        document.addEventListener("click", (e) => { if (!agentPop.hidden && !agentPop.contains(e.target as Node) && !agentEl.contains(e.target as Node)) agentPop.hidden = true; });
        // Pro未満（眠り）は稼働ポーリングしない＝眠ったまま。Pro以上のみ稼働状況を反映。
        if (agentAwake) { pollAgent(); setInterval(pollAgent, 8000); }
      }
    </script>
    <slot name="scripts" />
  </body>
</html>
