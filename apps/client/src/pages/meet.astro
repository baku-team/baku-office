---
export const prerender = false;
import App from "../layouts/App.astro";
import { atLeast } from "@baku-office/shared";
const env = Astro.locals.runtime.env;
const { getSession } = await import("../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses) return Astro.redirect("/login", 302);
const isAdmin = ses.role === "admin" && ses.ctx === "org";
const { cachedEntitlement } = await import("../lib/client.ts");
const hasPro = atLeast(await cachedEntitlement(env), "pro");
const { googleConfigured, googleConnected } = await import("../lib/google.ts");

let configured = false, connected = false;
type Rec = { id: string; title: string | null; summary: string | null; actions: string | null; created_at: number };
let recs: Rec[] = [];
if (hasPro) {
  configured = googleConfigured(env);
  connected = await googleConnected(env);
  recs = (await env.DB.prepare("SELECT id,title,summary,actions,created_at FROM meet_records ORDER BY created_at DESC LIMIT 50").all<Rec>()).results;
}
const fmtDate = (s: number) => new Date(s * 1000).toISOString().slice(0, 16).replace("T", " ");
const parseActions = (s: string | null): { content: string; due?: string }[] => { try { const v = JSON.parse(s ?? "[]"); return Array.isArray(v) ? v : []; } catch { return []; } };
---
<App title="Meet議事録" active="/meet">
  <h1>Google Meet 議事録（会議後処理）</h1>
  {!hasPro && (
    <div class="card">
      <div class="banner banner-warn">この機能は <strong>Pro 以上</strong>のプランで利用できます。</div>
      <p class="muted">会議後に Google Meet のトランスクリプトから議事録要約を作成し、ナレッジ保存・タスク化します（リアルタイム参加はしません）。</p>
      <a class="btn btn-primary" href="/billing">プラン・課金へ</a>
    </div>
  )}
  {hasPro && (
    <Fragment>
      {!configured && (<div class="banner banner-warn">Google OAuth（GOOGLE_CLIENT_ID/SECRET）が未設定のため連携できません。管理者にご確認ください。</div>)}
      <div class="card">
        <p>Google 連携：<span class="pill">{connected ? "連携済み" : "未連携"}</span> <span class="muted" style="font-size:.8rem">（カレンダー・Gmail・Meet 共通）</span></p>
        {isAdmin && configured && !connected && (<a class="btn btn-primary" href="/api/google/start">Google と連携</a>)}
        {isAdmin && connected && (<div class="row"><a class="btn" href="/api/google/start">再連携</a><button class="btn" id="gdisc">連携を解除</button></div>)}
        {!isAdmin && (<p class="muted">連携・解除の操作は管理者のみ可能です。</p>)}
      </div>
      {connected && (
        <Fragment>
          <div class="card">
            <p class="muted">AIチャットに「最近の会議を一覧して」「この会議を要約して議事録にして」と依頼すると、トランスクリプトから議事録を作成し、ナレッジ保存とアクションのリマインダ登録を行います。<br />※ 取得できるのは Meet の<strong>文字起こしが有効</strong>な会議のみです。</p>
          </div>
          <h2>作成済みの議事録</h2>
          {recs.length === 0 && (<div class="card muted">まだ議事録はありません。会議後に AIチャットから要約を依頼してください。</div>)}
          {recs.map((r) => (
            <div class="card">
              <strong>{r.title ?? "(無題)"}</strong> <span class="muted" style="font-size:.75rem">{fmtDate(r.created_at)}</span>
              <pre style="white-space:pre-wrap;font-size:.85rem">{(r.summary ?? "").slice(0, 1200)}</pre>
              {parseActions(r.actions).length > 0 && (
                <details>
                  <summary class="muted" style="font-size:.8rem">アクションアイテム（{parseActions(r.actions).length}）</summary>
                  <ul>{parseActions(r.actions).map((a) => (<li>{a.content}{a.due ? `（期限 ${a.due}）` : ""}</li>))}</ul>
                </details>
              )}
            </div>
          ))}
        </Fragment>
      )}
    </Fragment>
  )}
  <script slot="scripts" is:inline>
    const d = document.getElementById("gdisc");
    if (d) d.addEventListener("click", async (e) => {
      const r = await window.bo.api("/api/google", { _action: "disconnect" }, { btn: e.currentTarget, successMsg: "連携を解除しました" });
      if (r.ok) setTimeout(() => location.reload(), 600);
    });
  </script>
</App>
