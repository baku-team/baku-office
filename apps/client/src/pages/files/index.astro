---
export const prerender = false;
import App from "../../layouts/App.astro";
const env = Astro.locals.runtime.env;
const { getSession } = await import("../../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses) return Astro.redirect("/login", 302);
const { listFilesForSession, storageMode } = await import("../../lib/storage.ts");
const files = await listFilesForSession(env, ses);
const mode = storageMode(env);
const kb = (n: number) => (n < 1024 ? n + " B" : (n / 1024).toFixed(1) + " KB");
---
<App title="ファイル" active="/files">
  <h1>ファイル</h1>
  <p class="muted">ストレージ：<strong>{mode === "r2" ? "高度（R2）" : "標準（KV・カード不要）"}</strong>（§11）</p>
  <div class="card">
    <div class="row">
      <input type="file" id="file" />
      <button class="btn btn-primary" id="up" style="flex:0 0 auto">アップロード</button>
    </div>
  </div>
  <div class="table-wrap" style="margin-top:1rem">
    <table>
      <thead><tr><th>名前</th><th>サイズ</th><th>種類</th><th>操作</th></tr></thead>
      <tbody>
        {files.map((f) => (
          <tr data-id={f.id}>
            <td>{f.name}</td><td>{kb(f.size)}</td><td>{f.mime ?? ""}</td>
            <td><a class="btn btn-sm" href={`/files/${f.id}`}>DL</a> <button class="btn btn-sm btn-danger del">削除</button></td>
          </tr>
        ))}
        {files.length === 0 && (<tr><td colspan="4" class="muted">ファイルがありません。</td></tr>)}
      </tbody>
    </table>
  </div>

  <script slot="scripts" is:inline>
    document.getElementById("up").addEventListener("click", async (e) => {
      const f = document.getElementById("file").files[0];
      if (!f) { window.bo.toast("ファイルを選択してください", "err"); return; }
      const btn = e.currentTarget; window.bo.busy(btn, true);
      try {
        const fd = new FormData(); fd.append("file", f);
        const r = await fetch("/api/files", { method: "POST", body: fd });
        const j = await r.json().catch(() => ({}));
        if (!r.ok || j.error) { window.bo.toast("失敗：" + (j.error || r.status), "err"); }
        else { window.bo.toast("アップロードしました（" + j.mode + "）"); setTimeout(() => location.reload(), 700); }
      } finally { window.bo.busy(btn, false); }
    });
    document.querySelectorAll("tr[data-id] .del").forEach((b) => b.addEventListener("click", async (e) => {
      if (!(await window.bo.confirm("このファイルをゴミ箱へ移動しますか？", { confirmLabel: "削除", danger: true, auditHref: "/diagnostics" }))) return;
      const r = await window.bo.api("/api/files", { _action: "delete", id: e.target.closest("tr").dataset.id }, { btn: e.target, successMsg: "ゴミ箱へ移動しました" });
      if (r.ok) setTimeout(() => location.reload(), 600);
    }));
  </script>
</App>
