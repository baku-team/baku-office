---
import { env } from "cloudflare:workers";
export const prerender = false;
import App from "../layouts/App.astro";
const { getSession } = await import("../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses) return Astro.redirect("/login", 302);
const ctx = Astro.locals.ctx;
const isAdminOrg = ses.role === "admin" && ses.ctx === "org";
const { atLeast, planLabel } = await import("@baku-office/shared");
const entitlement = await (await import("../lib/client.ts")).cachedEntitlement(env).catch(() => "free" as const);
const okPlan = (minPlan?: string) => !minPlan || atLeast(entitlement, minPlan as import("@baku-office/shared").Entitlement);

await import("../parts/index.ts");
const { appCatalog, installedAppIds, MANDATORY_APPS } = await import("../core/apps.ts");
const { registeredParts } = await import("../core/parts.ts");
const cat = appCatalog();
const installed = new Set(await installedAppIds(ctx));
const isOn = (id: string) => installed.has(id);
const isMust = (id: string) => MANDATORY_APPS.includes(id);
// ランチャー：導入済み・ナビ(menu)あり・プラン充足のアプリの起動リンク。
const launch = registeredParts().filter((p) => installed.has(p.id) && (p.menu?.length ?? 0) > 0 && okPlan(p.minPlan))
  .flatMap((p) => (p.menu ?? []).map((m) => ({ app: p.name, href: m.href, label: m.label })));

const { listExternalApps, listDrafts } = await import("../lib/external-apps.ts");
const externalApps = isAdminOrg ? await listExternalApps(ctx) : [];
const drafts = isAdminOrg ? await listDrafts(ctx) : [];
// ストア（ホスト主体）：プラン充足の掲載アプリ。提供者は自分のアプリを公開設定できる。
const { storeCatalog, myApps } = await import("../lib/store.ts");
const store = await storeCatalog(env).catch(() => []);
const mine = isAdminOrg ? await myApps(env).catch(() => []) : [];
const ENT_OPTS = ["free", "plus", "pro", "nonprofit", "enterprise"];
---
<App title="アプリ" active="/apps">
  <div class="spread" style="flex-wrap:wrap;gap:12px">
    <h1 style="margin:0">アプリ</h1>
    {isAdminOrg && (
      <div class="seg" id="apps-seg" role="group" aria-label="表示切替">
        <button class="seg-opt on" type="button" data-tab="store">ストア</button>
        <button class="seg-opt" type="button" data-tab="manage">アプリ管理</button>
        <button class="seg-opt" type="button" data-tab="develop">AIで作る</button>
      </div>
    )}
  </div>

  <div class="card launcher">
    <div class="launcher-head"><strong>使う（導入済み）</strong><span class="muted" style="font-size:.85rem">導入済みアプリをすぐ起動</span></div>
    <div class="launch-grid">
      {launch.map((l) => (<a class="launch-card" href={l.href}><span class="lc-label">{l.label}</span><span class="lc-app">{l.app}</span></a>))}
      {launch.length === 0 && (<span class="muted" style="font-size:.9rem">{isAdminOrg ? "起動できるアプリがありません。下の「ストア」や「アプリ管理」から追加してください。" : "起動できるアプリがありません。管理者にアプリの追加を依頼してください。"}</span>)}
    </div>
  </div>

  <div class="apps-panel" data-panel="store">
  <h2>ストア</h2>
  <p class="muted">ホストが配信する公開アプリ。お使いのプランで入手できるものが表示されます（DL数・評価順）。</p>
  <div class="grid">
    {store.map((a) => (
      <div class="card" data-store={a.id}>
        <strong>{a.name}</strong> <span class="muted">v{a.version}{a.category ? `・${a.category}` : ""}</span>
        {a.badges.map((bd) => (<span class="pill brand" style="margin-left:4px">{bd}</span>))}
        {a.description && <div class="muted" style="font-size:.85rem;margin-top:2px">{a.description}</div>}
        <div class="muted" style="font-size:.8rem;margin-top:4px">⬇ {a.downloads}　★ {a.avg_rating || "—"}（{a.reviews}）{a.min_entitlement !== "free" ? `　要${a.min_entitlement}` : ""}</div>
        <div class="row" style="margin-top:6px">
          <button class="btn btn-primary btn-sm st-get" style="flex:0 0 auto">入手</button>
          <select class="st-rate" style="flex:0 0 auto"><option value="">評価…</option><option value="5">★5</option><option value="4">★4</option><option value="3">★3</option><option value="2">★2</option><option value="1">★1</option></select>
        </div>
      </div>
    ))}
    {store.length === 0 && (<p class="muted">公開中のアプリはありません。</p>)}
  </div>

  {isAdminOrg && mine.length > 0 && (
    <>
      <h2>自分の提供アプリ（ストア公開）</h2>
      <div class="card">
        <p class="muted">承認済みのアプリを任意でストアに公開できます。DL可能な最低プランも設定します。</p>
        {mine.map((a) => (
          <div class="field" data-mine={a.id}>
            <strong>{a.name}</strong> <span class="muted">v{a.version}・{a.status}・⬇{a.downloads}・★{a.avg || "—"}</span>
            {a.status === "approved" ? (
              <span class="row" style="margin-top:4px;align-items:center">
                <label><input type="checkbox" class="m-listed" checked={a.listed === 1} /> ストアに公開</label>
                <select class="m-ent" style="flex:0 0 auto">{ENT_OPTS.map((o) => (<option value={o} selected={a.min_entitlement === o}>{o}</option>))}</select>
                <button class="btn btn-primary btn-sm m-save" style="flex:0 0 auto">保存</button>
              </span>
            ) : (<span class="muted" style="font-size:.8rem">（承認待ち。ホスト承認後に公開できます）</span>)}
          </div>
        ))}
      </div>
    </>
  )}

  </div>

  {isAdminOrg && (
    <>
    <div class="apps-panel" data-panel="manage" hidden>
      <h2>アプリ管理（導入・削除）</h2>
      <div class="card">
        <p class="muted">使うアプリを選びます。外すと画面・道具とも消えます。<strong>AIチャットは Plus 以上で必須</strong>。</p>
        {cat.map((p) => (
          <div class="field"><label>
            <input type="checkbox" class="app-chk" value={p.id} checked={isOn(p.id)} disabled={isMust(p.id) || !okPlan(p.minPlan)} />
            <strong>{p.name}</strong> <span class="muted">v{p.version}{p.category ? `・${p.category}` : ""}{isMust(p.id) ? "・必須" : ""}{p.minPlan && !okPlan(p.minPlan) ? `・要${planLabel(p.minPlan)}` : ""}</span>
            {p.description && <><br /><span class="muted" style="font-size:.85rem">{p.description}</span></>}
            {p.permissions.length > 0 && <><br /><span class="muted" style="font-size:.8rem">権限: {p.permissions.join(" / ")}</span></>}
          </label></div>
        ))}
        <button class="btn btn-primary" id="saveApps">導入アプリを保存</button>
      </div>

      <h2>外部アプリの取り込み（署名検証）</h2>
      <div class="card">
        <p class="muted">公開レジストリのアプリIDで取り込み（ホスト署名を検証）。再デプロイ不要。</p>
        <div class="row"><input id="ext-id" placeholder="アプリID（例 inventory）" style="flex:1" /><button class="btn btn-primary" id="fetchApp" style="flex:0 0 auto">取り込む</button></div>
        {externalApps.length > 0 && (
          <div class="table-wrap" style="margin-top:.6rem"><table><thead><tr><th>ID</th><th>名称</th><th>版</th><th>権限</th><th></th></tr></thead><tbody>
            {externalApps.map((a) => (<tr data-ext={a.id}><td><code>{a.id}</code></td><td>{a.name}</td><td>{a.version}</td><td class="muted" style="font-size:.8rem">{a.permissions.join(" / ")}</td><td><button class="btn btn-ghost ext-del">削除</button></td></tr>))}
          </tbody></table></div>
        )}
      </div>

    </div>
    <div class="apps-panel" data-panel="develop" hidden>
      <h2>アプリ開発（草案 → レビュー → 公開申請）</h2>
      <div class="card">
        <p class="muted">AIチャットで「〜するアプリを作って」と頼むと草案ができます。要求権限と事前確認（環境/権限/安全/コスト）をレビューし、公開申請できます。</p>
        {drafts.length === 0 && (<p class="muted">草案はありません。AIから作成してください。</p>)}
        {drafts.map((d) => (
          <div class="card" data-draft={d.id} style="margin:.5rem 0">
            <strong>{d.name}</strong> <span class="muted">v{d.version}</span>
            <span class={"pill " + (d.gate_status === "ready" ? "ok" : d.gate_status === "blocked" ? "danger" : "")} aria-label={`状態: ${d.gate_status === "ready" ? "実装可" : d.gate_status === "blocked" ? "ブロック" : "企画中"}`}>{d.gate_status === "ready" ? "✓ 実装可" : d.gate_status === "blocked" ? "⛔ ブロック" : "企画中"}</span>
            {d.spec && <><br /><span class="muted" style="font-size:.85rem">仕様: {d.spec}</span></>}
            <br /><span class="muted" style="font-size:.8rem">要求権限: {d.permissions.join(" / ") || "なし"}</span>
            {d.preflight && (<ul style="margin:.4rem 0 0;padding-left:1.1rem;font-size:.82rem">{d.preflight.checks.map((c) => (<li class="muted">{c.status === "ok" ? "✅" : c.status === "warn" ? "⚠️" : "⛔"} {c.label}：{c.detail}</li>))}</ul>)}
            <div class="row" style="margin-top:.4rem"><button class="btn btn-primary d-submit" style="flex:0 0 auto" disabled={d.gate_status !== "ready"}>公開申請</button><button class="btn btn-ghost d-del" style="flex:0 0 auto">削除</button></div>
          </div>
        ))}
      </div>
    </div>
    </>
  )}

  <script slot="scripts" is:inline>
    // セグメント切替（ストア/アプリ管理/AIで作る）。
    (function () {
      const seg = document.getElementById("apps-seg");
      if (!seg) return;
      const panels = [...document.querySelectorAll(".apps-panel")];
      seg.querySelectorAll(".seg-opt").forEach((b) => b.addEventListener("click", () => {
        seg.querySelectorAll(".seg-opt").forEach((x) => x.classList.toggle("on", x === b));
        panels.forEach((p) => { p.hidden = p.dataset.panel !== b.dataset.tab; });
      }));
    })();
    document.getElementById("saveApps")?.addEventListener("click", async (e) => {
      const parts = [...document.querySelectorAll(".app-chk")].filter((c) => c.checked).map((c) => c.value);
      const r = await window.bo.api("/api/settings", { _action: "enabled_parts", parts }, { btn: e.currentTarget, successMsg: "導入アプリを保存しました" });
      if (r.ok) setTimeout(() => location.reload(), 600);
    });
    document.getElementById("fetchApp")?.addEventListener("click", async (e) => {
      const id = (document.getElementById("ext-id").value || "").trim();
      if (!id) { window.bo.toast("アプリIDを入力", "err"); return; }
      const r = await window.bo.api("/api/settings", { _action: "fetch_app", appId: id }, { btn: e.currentTarget, successMsg: "取り込みました" });
      if (r.ok) setTimeout(() => location.reload(), 700);
    });
    document.querySelectorAll("tr[data-ext]").forEach((tr) => {
      const id = tr.getAttribute("data-ext");
      tr.querySelector(".ext-del")?.addEventListener("click", async (e) => { const r = await window.bo.api("/api/settings", { _action: "uninstall_external", appId: id }, { btn: e.currentTarget, successMsg: "削除しました" }); if (r.ok) setTimeout(() => location.reload(), 500); });
    });
    document.querySelectorAll("[data-draft]").forEach((el) => {
      const id = el.getAttribute("data-draft");
      el.querySelector(".d-submit")?.addEventListener("click", async (e) => { const r = await window.bo.api("/api/settings", { _action: "submit_draft", draftId: id }, { btn: e.currentTarget, successMsg: "公開申請しました（ホスト承認待ち）" }); if (r.ok) setTimeout(() => location.reload(), 800); });
      el.querySelector(".d-del")?.addEventListener("click", async (e) => { const r = await window.bo.api("/api/settings", { _action: "delete_draft", draftId: id }, { btn: e.currentTarget, successMsg: "削除しました" }); if (r.ok) setTimeout(() => location.reload(), 500); });
    });
    // ストア：入手（DL）・評価
    document.querySelectorAll("[data-store]").forEach((el) => {
      const id = el.getAttribute("data-store");
      el.querySelector(".st-get")?.addEventListener("click", async (e) => { const r = await window.bo.api("/api/settings", { _action: "fetch_app", appId: id }, { btn: e.currentTarget, successMsg: "入手しました（アプリ管理で有効化できます）" }); if (r.ok) setTimeout(() => location.reload(), 800); });
      el.querySelector(".st-rate")?.addEventListener("change", async (e) => { const rating = e.currentTarget.value; if (!rating) return; const r = await window.bo.api("/api/store", { _action: "rate", appId: id, rating: Number(rating) }, { btn: e.currentTarget, successMsg: "評価しました" }); if (r.ok) setTimeout(() => location.reload(), 600); });
    });
    // 自分の提供アプリ：ストア公開設定
    document.querySelectorAll("[data-mine]").forEach((el) => {
      const id = el.getAttribute("data-mine");
      el.querySelector(".m-save")?.addEventListener("click", async (e) => {
        const listed = el.querySelector(".m-listed")?.checked || false;
        const minEntitlement = el.querySelector(".m-ent")?.value || "free";
        const r = await window.bo.api("/api/store", { _action: "set_listed", appId: id, listed, minEntitlement }, { btn: e.currentTarget, successMsg: "公開設定を保存しました" });
        if (r.ok) setTimeout(() => location.reload(), 600);
      });
    });
  </script>

  <style>
    .launcher { margin-top: 1rem; }
    .launcher-head { display: flex; align-items: baseline; gap: 10px; justify-content: space-between; margin-bottom: 10px; flex-wrap: wrap; }
    .launch-chips { display: flex; gap: 8px; flex-wrap: wrap; }
    .launch-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px; }
    .launch-card { display: flex; flex-direction: column; justify-content: center; gap: 3px; min-height: 64px; padding: 14px 16px; border: 1px solid var(--line-strong); border-radius: var(--r-md); background: var(--surface); color: var(--ink); text-decoration: none; box-shadow: var(--shadow-sm); transition: transform .1s, border-color .15s, box-shadow .15s; }
    .launch-card:hover { transform: translateY(-2px); border-color: var(--brand); box-shadow: var(--shadow); text-decoration: none; }
    .launch-card .lc-label { font-size: 1.05rem; font-weight: 700; }
    .launch-card .lc-app { font-size: .82rem; color: var(--muted); }
    .apps-panel { margin-top: 8px; }
  </style>
</App>
