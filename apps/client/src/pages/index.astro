---
export const prerender = false;
import App from "../layouts/App.astro";
import { planLabel } from "@baku-office/shared";
const env = Astro.locals.runtime.env;
const { pollHost, cachedEntitlement } = await import("../lib/client.ts");
const check = await pollHost(env, Astro.url.origin);
const entitlement = check?.entitlement ?? (await cachedEntitlement(env));
let balance = 0;
try { balance = (await env.DB.prepare("SELECT COALESCE(SUM(opening_balance),0) AS b FROM wallets").first<{ b: number }>())?.b ?? 0; } catch { /* 未マイグレ */ }
const notices = check?.notices ?? [];
const yen = (n: number) => "¥" + n.toLocaleString("ja-JP");
---
<App title="ホーム" active="/">
  <h1>ホーム</h1>
  <p class="muted">プラン：<span class="pill">{planLabel(entitlement)}</span> ／ {check ? "ホスト疎通OK" : "オフライン（キャッシュ表示）"}</p>

  {notices.map((n) => (<div class={`banner ${n.severity === "critical" ? "banner-danger" : n.severity === "important" ? "banner-warn" : "banner-info"}`} data-sev={n.severity} data-id={n.id}>{n.body}</div>))}

  <div class="grid">
    <div class="card"><div class="label">口座残高（期首合計）</div><div class="num">{yen(balance)}</div></div>
    <div class="card"><div class="label">当月収支</div><div class="num">¥0</div><div class="muted">会計で登録</div></div>
    <div class="card"><div class="label">未処理伝票</div><div class="num">0</div></div>
    <div class="card"><div class="label">プラン / ライセンス</div><div class="num" style="font-size:1.1rem">{planLabel(entitlement)}</div></div>
  </div>

  <h2>できること</h2>
  <div class="grid">
    <a class="card" href="/accounting" style="text-decoration:none;color:inherit"><strong>会計</strong><div class="muted">入出金・出納帳・収支・CSV</div></a>
    <a class="card" href="/files" style="text-decoration:none;color:inherit"><strong>ファイル</strong><div class="muted">アップロード・共有</div></a>
    <a class="card" href="/minutes" style="text-decoration:none;color:inherit"><strong>議事録</strong><div class="muted">作成・一覧</div></a>
    <a class="card" href="/settings/keys" style="text-decoration:none;color:inherit"><strong>連携設定</strong><div class="muted">Gemini/LINE/Claude</div></a>
  </div>

  <div class="modal" id="critModal"><div class="box"><h2 style="margin-top:0;border:0">重要なお知らせ</h2><div id="critBody"></div><button class="btn btn-primary" id="critAck" style="margin-top:1rem">確認しました</button></div></div>

  <script slot="scripts" is:inline>
    const crit = [...document.querySelectorAll('.banner[data-sev="critical"]')].filter((n) => !localStorage.getItem("ack:" + n.dataset.id));
    if (crit.length) {
      const m = document.getElementById("critModal");
      document.getElementById("critBody").innerHTML = crit.map((n) => "<p>" + n.textContent + "</p>").join("");
      m.classList.add("open");
      document.getElementById("critAck").onclick = () => { crit.forEach((n) => localStorage.setItem("ack:" + n.dataset.id, "1")); m.classList.remove("open"); window.bo.toast("確認しました"); };
    }
  </script>
</App>
