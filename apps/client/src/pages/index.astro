---
import { kvPut } from "../lib/kv.ts";
import { env } from "cloudflare:workers";
export const prerender = false;
import App from "../layouts/App.astro";
import Slot from "../components/Slot.astro";
import { planLabel } from "@baku-office/shared";
const { getSession } = await import("../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses) return Astro.redirect("/login", 302);
const ctx = Astro.locals.ctx;
const isOrgAdmin = ses.role === "admin" && ses.ctx === "org";
const { pollHost, cachedEntitlement, APP_VERSION, nowSec } = await import("../lib/client.ts");
const { cmpVersion } = await import("../lib/update.ts");
await import("../parts/index.ts"); // パーツ登録（カタログ参照の前提）
const { appCatalog, installedAppIds } = await import("../core/apps.ts");
const { getStorageUsage, fmtBytes } = await import("../lib/storage-usage.ts");
const { kvWritesToday, KV_WRITE_FREE_LIMIT } = await import("../lib/kv.ts");
const { scopedWidgets, enabledParts } = await import("../core/parts.ts");
const { getHomeLayout, orderedSections, HOME_SECTIONS } = await import("../core/home.ts");
const { brandName, getTheme } = await import("../core/theme.ts");
const { reviewQueue } = await import("../lib/users.ts");
const { backupAlert } = await import("../lib/backup.ts");

// 後続の多くが依存するため先に取得。
const instSet = new Set(await installedAppIds(ctx).catch(() => []));
const ym = new Date().toISOString().slice(0, 7);

// ホスト疎通＋テレメトリ＋entitlement/notices キャッシュ更新は描画をブロックせず背景実行（体感速度の要）。
const _apps = appCatalog().filter((a) => instSet.has(a.id)).map((a) => ({ id: a.id, version: a.version }));
try { Astro.locals.cfContext.waitUntil(pollHost(env, Astro.url.origin, _apps).catch(() => {})); }
catch { pollHost(env, Astro.url.origin, _apps).catch(() => {}); }

// 軽量データは常に並列取得。重い KPI（残高・当月収支・承認待ち・ストレージ）は短期キャッシュ。
const widgetDefs = scopedWidgets(enabledParts([...instSet]));
const [entitlement, homeLayout, theme, latestVersion, noticesRaw, lastAtRaw, backupAlertState, widgetData, kpiRaw] = await Promise.all([
  cachedEntitlement(env).catch(() => "free" as const),
  getHomeLayout(ctx).catch(() => null),
  getTheme(ctx).catch(() => ({}) as import("../core/theme.ts").ThemeConfig),
  env.LICENSE.get("latest_version").catch(() => null),
  env.LICENSE.get("notices_cache").catch(() => null),
  env.LICENSE.get("entitlement_at").catch(() => null),
  isOrgAdmin ? backupAlert(env).catch(() => ({ alert: false, never: false, lastAt: null })) : Promise.resolve({ alert: false, never: false, lastAt: null }),
  Promise.all(widgetDefs.map(async (w) => { try { return { title: w.title, span: w.span, ...(await w.run(ctx, ses.uid)) }; } catch { return null; } })).then((a) => a.filter(Boolean) as { title: string; value: string; sub?: string; span?: number }[]),
  env.LICENSE.get("kpi_cache").catch(() => null),
]);

// KPIは30秒キャッシュ＝DB集計/ストレージ計測を間引く（D1/KV読取の削減＋描画高速化）。
// 月初〜翌月初の range 検索でインデックス（idx_tx_date）を利用（substr は不可）。
const monthStart = ym + "-01";
const _d = new Date();
const nextMonthStart = new Date(Date.UTC(_d.getUTCFullYear(), _d.getUTCMonth() + 1, 1)).toISOString().slice(0, 10);
type Kpi = { balance: number; monthIncome: number; monthExpense: number; pending: number; storage: Awaited<ReturnType<typeof getStorageUsage>>; at: number };
let kpi: Kpi | null = null;
try { if (kpiRaw) { const o = JSON.parse(kpiRaw) as Kpi; if (nowSec() - o.at < 120) kpi = o; } } catch { /* noop */ }
if (!kpi) {
  const [balanceRow, monthAgg, pending, st] = await Promise.all([
    env.DB.prepare("SELECT COALESCE(SUM(opening_balance),0) AS b FROM wallets").first<{ b: number }>().catch(() => null),
    env.DB.prepare("SELECT kind, COALESCE(SUM(amount),0) AS s FROM transactions WHERE deleted_at IS NULL AND kind IN ('income','expense') AND date >= ? AND date < ? GROUP BY kind").bind(monthStart, nextMonthStart).all<{ kind: string; s: number }>().catch(() => ({ results: [] as { kind: string; s: number }[] })),
    reviewQueue(env).then((r) => r.length).catch(() => 0),
    getStorageUsage(env).catch(() => [] as Awaited<ReturnType<typeof getStorageUsage>>),
  ]);
  let mi = 0, me = 0;
  for (const row of monthAgg.results) { if (row.kind === "income") mi = row.s; else if (row.kind === "expense") me = row.s; }
  kpi = { balance: balanceRow?.b ?? 0, monthIncome: mi, monthExpense: me, pending, storage: st, at: nowSec() };
  const blob = JSON.stringify(kpi);
  // KV書き込み（kpi_cache）は失敗しても描画を止めない。上限超過時に put が同期例外/拒否のどちらでも500にしない。
  try { Astro.locals.cfContext.waitUntil(kvPut(env, "kpi_cache", blob).catch(() => {})); } catch { /* KV上限など：無視 */ }
}
const balance = kpi.balance;
const monthIncome = kpi.monthIncome, monthExpense = kpi.monthExpense;
const monthNet = monthIncome - monthExpense;
const pendingCount = kpi.pending;
const storage = kpi.storage;
const updateAvailable = !!latestVersion && cmpVersion(latestVersion, APP_VERSION) > 0;
let notices: { id: string; severity: string; body: string }[] = [];
try { notices = JSON.parse(noticesRaw ?? "[]"); } catch { /* noop */ }
const lastAt = Number(lastAtRaw);
const online = Number.isFinite(lastAt) && nowSec() - lastAt < 86400;

const pct = (u: number, l: number) => (u < 0 || l <= 0 ? 0 : Math.min(100, Math.round((u / l) * 100)));
// 通信量（KV書き込み）：管理者向け詳細にのみ表示。一般ユーザーには出さない（専門情報のマスク）。
const kvWrites = isOrgAdmin ? await kvWritesToday(env).catch(() => 0) : 0;
const kvPct = KV_WRITE_FREE_LIMIT > 0 ? Math.min(100, Math.round((kvWrites / KV_WRITE_FREE_LIMIT) * 100)) : 0;
// 一般ユーザー向けは内訳（D1/KV/R2）を見せず「保存できる容量」1本に合算する。
const measurable = storage.filter((s) => s.enabled && s.used >= 0 && s.limit > 0);
const totalUsed = measurable.reduce((a, s) => a + s.used, 0);
const totalLimit = measurable.reduce((a, s) => a + s.limit, 0);
const totalPct = pct(totalUsed, totalLimit);
const yen = (n: number) => "¥" + n.toLocaleString("ja-JP");
const fmtDay = (s: number) => new Date(s * 1000).toISOString().slice(0, 10);
const jstHour = (new Date().getUTCHours() + 9) % 24;
const greeting = jstHour < 11 ? "おはようございます" : jstHour < 18 ? "こんにちは" : "おつかれさまです";
const dispName = ses.name ? `${ses.name} さん` : "";
const brandLabel = brandName(theme);
const sections = orderedSections(homeLayout);
const hiddenSet = new Set(homeLayout?.hidden ?? []);
const clampSpan = (n?: number) => Math.max(1, Math.min(3, Number(n) || 1));
---
<App title="ホーム" active="/">
  <Slot name="home-hero" />
  <div class="home-head">
    <div>
      <div class="eyebrow">{brandLabel}</div>
      <h1 class="h1" style="margin:.25rem 0 0">{greeting}{dispName && <span style="color:var(--muted);font-weight:600">、{dispName}</span>}</h1>
    </div>
    <div class="home-head-right">
      <span class="pill brand">{planLabel(entitlement)}</span>
      <span class="pill"><span class="dot" style={`background:${online ? "var(--ok)" : "var(--faint)"}`}></span>{online ? "オンライン" : "未接続"}</span>
      {isOrgAdmin && (<button class="btn btn-ghost btn-sm" id="editHome">ホームを編集</button>)}
    </div>
  </div>

  <style>
    .home-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 14px; flex-wrap: wrap; }
    .home-head-right { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
  </style>

  {/* 業務の入口：よく使う4つを大ボタンで常設（並べ替え/非表示の対象外・最上部）。高齢ユーザーが1タップで届くように。 */}
  <nav class="home-actions" aria-label="よく使う操作">
    <a class="ha" href="/accounting">
      <span class="ha-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18v12H3zM3 10h18M7 15h4" /></svg></span>
      <span class="ha-txt"><strong>お金の記録</strong><small>入金・出金・残高</small></span>
    </a>
    <a class="ha" href="/schedule">
      <span class="ha-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 5h16v15H4zM4 9h16M8 3v4M16 3v4" /></svg></span>
      <span class="ha-txt"><strong>予定</strong><small>行事・スケジュール</small></span>
    </a>
    <a class="ha" href="/membership">
      <span class="ha-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11a3 3 0 100-6 3 3 0 000 6M3 19a6 6 0 0112 0M17 11a3 3 0 000-6M21 19a6 6 0 00-4-5.7" /></svg></span>
      <span class="ha-txt"><strong>名簿</strong><small>会員の一覧・管理</small></span>
    </a>
    <a class="ha" href="/import">
      <span class="ha-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v10M8 9l4 4 4-4M5 21h14" /></svg></span>
      <span class="ha-txt"><strong>書類の取り込み</strong><small>ファイル・資料を取込</small></span>
    </a>
  </nav>
  <style>
    .home-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin: 1.1rem 0 .4rem; }
    .ha { display: flex; align-items: center; gap: 14px; min-height: 84px; padding: 16px 18px; border: 1px solid var(--line-strong); border-radius: var(--r-md); background: var(--surface); color: var(--ink); text-decoration: none; box-shadow: var(--shadow-sm); transition: transform .1s, box-shadow .15s, border-color .15s; }
    .ha:hover { transform: translateY(-2px); box-shadow: var(--shadow); border-color: var(--brand); text-decoration: none; }
    .ha:active { transform: translateY(0); }
    .ha-ico { width: 52px; height: 52px; flex: 0 0 auto; border-radius: 14px; display: grid; place-items: center; background: var(--brand-soft); color: var(--brand-strong); }
    .ha-ico svg { width: 28px; height: 28px; }
    .ha-txt strong { display: block; font-size: 1.15rem; font-weight: 800; letter-spacing: -.01em; }
    .ha-txt small { display: block; color: var(--muted); font-size: .9rem; margin-top: 2px; }
    @media (max-width: 420px) { .home-actions { gap: 10px; } .ha { min-height: 76px; padding: 14px; gap: 11px; } .ha-ico { width: 46px; height: 46px; } .ha-txt strong { font-size: 1.05rem; } }
  </style>

  {/* 固定セクション：baku-office からのお知らせ・重要なお知らせ（並べ替え/非表示の対象外・常に最上部）。 */}
  <section class="home-fixed">
    <h2>お知らせ</h2>
    {notices.length === 0 && !updateAvailable && (<p class="muted">現在、新しいお知らせはありません。</p>)}
    {notices.map((n) => (<div class={`banner ${n.severity === "critical" ? "banner-danger" : n.severity === "important" ? "banner-warn" : "banner-info"}`} data-sev={n.severity} data-id={n.id}>{n.body}</div>))}
    {updateAvailable && (
      <div class="banner banner-warn">🔔 新しいバージョン <strong>{latestVersion}</strong> があります（現在 {APP_VERSION}）。{isOrgAdmin ? <a href="/settings/update">更新する</a> : "管理者にアプリの更新をご依頼ください。"}</div>
    )}
    {backupAlertState.alert && (
      <div class="banner banner-warn">💾 {backupAlertState.never ? "データのバックアップがまだ実行されていません。" : `最終バックアップから7日以上経過しています（最終：${backupAlertState.lastAt ? fmtDay(backupAlertState.lastAt) : "—"}）。`}<a href="/backup">今すぐバックアップ</a></div>
    )}
  </section>

  {/* 並べ替え/非表示できるセクション群（団体ごと）。 */}
  {sections.map((sec) => (
    sec === "summary" ? (
      <section data-sec="summary">
        <div class="grid">
          <a class="card link" href="/accounting"><div class="label">口座残高（期首合計）</div><div class="num">{yen(balance)}</div></a>
          <a class="card link" href="/accounting"><div class="label">当月収支（{ym}）</div><div class="num" style={`color:${monthNet < 0 ? "var(--danger)" : monthNet > 0 ? "var(--ok)" : "inherit"}`}>{(monthNet < 0 ? "-¥" : "¥") + Math.abs(monthNet).toLocaleString("ja-JP")}</div><div class="muted" style="font-size:.78rem">収入 {yen(monthIncome)}／支出 {yen(monthExpense)}</div></a>
          <a class="card link" href="/review"><div class="label">未処理伝票（承認待ち）</div><div class="num">{pendingCount}</div><div class="muted" style="font-size:.78rem">{pendingCount > 0 ? "確認してください" : "なし"}</div></a>
          <div class="card"><div class="label">プラン / ライセンス</div><div class="num" style="font-size:1.1rem">{planLabel(entitlement)}</div></div>
        </div>
      </section>
    ) : sec === "widgets" ? (
      widgetData.length > 0 && (
        <section data-sec="widgets">
          <h2>アプリの状況</h2>
          <div class="grid wgrid">
            {widgetData.map((w) => (
              <div class="card" style={`grid-column:span ${clampSpan(w.span)}`}><div class="label">{w.title}</div><div class="num">{w.value}</div>{w.sub && <div class="muted" style="font-size:.82rem">{w.sub}</div>}</div>
            ))}
          </div>
        </section>
      )
    ) : sec === "storage" ? (
      <section data-sec="storage">
        <h2>保存できる容量</h2>
        {totalPct >= 80 && (<div class="banner banner-warn">⚠️ 保存できる容量が残りわずかです（{totalPct}% 使用）。{isOrgAdmin ? "下の「内訳」から拡張をご検討ください。" : "管理者にご相談ください。"}</div>)}
        <div class="card">
          <div class="label">いまの使用状況</div>
          <div class="gauge"><div class={`gfill ${totalPct >= 80 ? "hot" : ""}`} style={`width:${totalPct}%`}></div></div>
          <div class="muted" style="margin-top:6px">{totalLimit > 0 ? `${fmtBytes(totalUsed)} / ${fmtBytes(totalLimit)}（${totalPct}%）` : "計測中"}</div>
        </div>
        {isOrgAdmin && (
          <div class="card" style="margin-top:.6rem">
            <div class="label">通信量（保存・更新の回数）{kvPct >= 80 && (<span class="muted" style="font-weight:400"> ⚠️ 残りわずか</span>)}</div>
            <div class="gauge"><div class={`gfill ${kvPct >= 80 ? "hot" : ""}`} style={`width:${kvPct}%`}></div></div>
            <div class="muted" style="margin-top:6px">本日 {kvWrites.toLocaleString()} / {KV_WRITE_FREE_LIMIT.toLocaleString()} 回（{kvPct}%）・毎日UTC0時にリセット ・ <a href="/usage">使用量を見る</a></div>
          </div>
        )}
        {isOrgAdmin && (
          <details class="adv">
            <summary>保存容量の内訳・拡張（管理者向け）</summary>
            <p class="adv-note">保存先ごとの内訳です。容量の拡張・外部ストレージの有効化はこちらから行えます。</p>
            <div class="grid">
              {storage.map((s) => (
                <div class="card">
                  <div class="label">{s.label}{!s.enabled && (s.key === "r2" ? "（未使用）" : s.key === "drive" ? "（未連携）" : "")}</div>
                  <div class="gauge"><div class={`gfill ${pct(s.used, s.limit) >= 80 ? "hot" : ""}`} style={`width:${pct(s.used, s.limit)}%`}></div></div>
                  <div class="muted" style="font-size:.85rem;margin-top:4px">{s.used < 0 ? "計測不可" : `${fmtBytes(s.used)} / ${fmtBytes(s.limit)}（${pct(s.used, s.limit)}%）`}</div>
                  {(s.hint === "paid" || s.hint === "r2") && (<div class="muted" style="font-size:.85rem;margin-top:2px"><a href="/settings/advanced">{s.hint === "r2" ? "外部ストレージを有効化" : "容量プランを拡張"}</a></div>)}
                  {s.key === "drive" && !s.enabled && (<div class="muted" style="font-size:.85rem;margin-top:2px"><a href="/drive">連携する</a></div>)}
                </div>
              ))}
            </div>
          </details>
        )}
      </section>
    ) : sec === "quicklinks" ? (
      <section data-sec="quicklinks">
        <h2>そのほかの機能</h2>
        <div class="grid">
          <a class="card" href="/files" style="text-decoration:none;color:inherit"><strong>ファイル</strong><div class="muted">アップロード・共有</div></a>
          <a class="card" href="/minutes" style="text-decoration:none;color:inherit"><strong>議事録</strong><div class="muted">作成・一覧</div></a>
          <a class="card" href="/apps" style="text-decoration:none;color:inherit"><strong>アプリ</strong><div class="muted">機能の追加</div></a>
          <a class="card" href="/settings" style="text-decoration:none;color:inherit"><strong>設定</strong><div class="muted">表示・アカウント</div></a>
        </div>
      </section>
    ) : null
  ))}

  {/* ホーム編集モーダル（別ウィンドウ）：セクションの表示/非表示・並べ替え。 */}
  {isOrgAdmin && (
    <div class="modal" id="homeModal"><div class="box">
      <h2 style="margin-top:0;border:0">ホームの表示を編集</h2>
      <p class="muted" style="font-size:.85rem">セクションの表示/非表示と並び順を変更します（お知らせは固定）。</p>
      <div id="secList" class="sec-list">
        {HOME_SECTIONS.map((s) => (
          <div class="sec-row" data-id={s.id}>
            <label style="flex:1"><input type="checkbox" class="sec-on" checked={!hiddenSet.has(s.id)} /> {s.label}</label>
            <button class="btn btn-sm sec-up" title="上へ">↑</button>
            <button class="btn btn-sm sec-down" title="下へ">↓</button>
          </div>
        ))}
      </div>
      <div class="row" style="margin-top:1rem">
        <button class="btn btn-primary" id="saveHome" style="flex:1">保存</button>
        <button class="btn btn-ghost" id="closeHome" style="flex:0 0 auto">閉じる</button>
      </div>
    </div></div>
  )}

  <div class="modal" id="critModal"><div class="box"><h2 style="margin-top:0;border:0">重要なお知らせ</h2><div id="critBody"></div><button class="btn btn-primary" id="critAck" style="margin-top:1rem">確認しました</button></div></div>

  <style>
    .gauge { height: 8px; background: #eef1f5; border-radius: 4px; overflow: hidden; margin-top: 6px; }
    .gfill { height: 100%; background: #14365c; border-radius: 4px; transition: width .3s; }
    .gfill.hot { background: #b4541a; }
    .wgrid { grid-auto-flow: row dense; }
    .sec-list { display: flex; flex-direction: column; gap: 6px; }
    .sec-row { display: flex; align-items: center; gap: 6px; border: 1px solid #dde3ea; border-radius: 6px; padding: 6px 8px; }
    .sec-row.off { opacity: .55; }
  </style>

  <script slot="scripts" is:inline>
    (function () {
      // 重要なお知らせの確認モーダル。
      const crit = [...document.querySelectorAll('.banner[data-sev="critical"]')].filter((n) => !localStorage.getItem("ack:" + n.dataset.id));
      if (crit.length) {
        const m = document.getElementById("critModal");
        document.getElementById("critBody").innerHTML = crit.map((n) => "<p>" + n.textContent + "</p>").join("");
        m.classList.add("open");
        document.getElementById("critAck").onclick = () => { crit.forEach((n) => localStorage.setItem("ack:" + n.dataset.id, "1")); m.classList.remove("open"); window.bo.toast("確認しました"); };
      }
      // ホーム編集（管理者のみ要素が存在）。
      const edit = document.getElementById("editHome");
      const modal = document.getElementById("homeModal");
      if (edit && modal) {
        const list = document.getElementById("secList");
        const refresh = () => list.querySelectorAll(".sec-row").forEach((r) => r.classList.toggle("off", !r.querySelector(".sec-on").checked));
        edit.addEventListener("click", () => { modal.classList.add("open"); refresh(); });
        document.getElementById("closeHome")?.addEventListener("click", () => modal.classList.remove("open"));
        list.querySelectorAll(".sec-row").forEach((row) => {
          row.querySelector(".sec-on")?.addEventListener("change", refresh);
          row.querySelector(".sec-up")?.addEventListener("click", () => { const p = row.previousElementSibling; if (p) list.insertBefore(row, p); });
          row.querySelector(".sec-down")?.addEventListener("click", () => { const n = row.nextElementSibling; if (n) list.insertBefore(n, row); });
        });
        document.getElementById("saveHome")?.addEventListener("click", async (e) => {
          const rows = [...list.querySelectorAll(".sec-row")];
          const order = rows.map((r) => r.dataset.id);
          const hidden = rows.filter((r) => !r.querySelector(".sec-on").checked).map((r) => r.dataset.id);
          const r = await window.bo.api("/api/settings", { _action: "home_layout", layout: { order, hidden } }, { btn: e.currentTarget, successMsg: "ホームの表示を保存しました" });
          if (r.ok) setTimeout(() => location.reload(), 600);
        });
      }
    })();
  </script>
</App>
