---
export const prerender = false;
import App from "../layouts/App.astro";
import Slot from "../components/Slot.astro";
import { planLabel } from "@baku-office/shared";
const env = Astro.locals.runtime.env;
const { getSession } = await import("../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses) return Astro.redirect("/login", 302);
const { pollHost, cachedEntitlement, APP_VERSION } = await import("../lib/client.ts");
const { cmpVersion } = await import("../lib/update.ts");
// 導入アプリを中枢へ申告（どのアプリが使われているかをホストが把握）。
await import("../parts/index.ts");
const { appCatalog, installedAppIds } = await import("../core/apps.ts");
const _inst = new Set(await installedAppIds(Astro.locals.ctx).catch(() => []));
const _apps = appCatalog().filter((a) => _inst.has(a.id)).map((a) => ({ id: a.id, version: a.version }));
const check = await pollHost(env, Astro.url.origin, _apps);
const entitlement = check?.entitlement ?? (await cachedEntitlement(env));
// 第2層更新：最新版が同梱版より新しければ更新を案内（管理者のみ操作可）。
const updateAvailable = !!check && cmpVersion(check.latestVersion, APP_VERSION) > 0;
const isOrgAdmin = ses.role === "admin" && ses.ctx === "org";
const { getStorageUsage, fmtBytes } = await import("../lib/storage-usage.ts");
const storage = await getStorageUsage(env);
const pct = (u: number, l: number) => (u < 0 || l <= 0 ? 0 : Math.min(100, Math.round((u / l) * 100)));
const hintText: Record<string, string> = { paid: "高度なオプション → Workers Paid で上限を拡張できます。", r2: "高度なオプションで R2 を有効化すると大容量に対応できます。", drive: "Google ドライブの空き容量をご確認ください。", none: "" };
const nearFull = storage.filter((s) => s.enabled && s.used >= 0 && pct(s.used, s.limit) >= 80);
let balance = 0;
try { balance = (await env.DB.prepare("SELECT COALESCE(SUM(opening_balance),0) AS b FROM wallets").first<{ b: number }>())?.b ?? 0; } catch { /* 未マイグレ */ }
// 当月収支（実データ）。date は 'YYYY-MM-DD' 文字列のため substr で当月抽出。
const ym = new Date().toISOString().slice(0, 7);
let monthIncome = 0, monthExpense = 0;
try {
  const r = await env.DB.prepare("SELECT kind, COALESCE(SUM(amount),0) AS s FROM transactions WHERE deleted_at IS NULL AND kind IN ('income','expense') AND substr(date,1,7)=? GROUP BY kind").bind(ym).all<{ kind: string; s: number }>();
  for (const row of r.results) { if (row.kind === "income") monthIncome = row.s; else if (row.kind === "expense") monthExpense = row.s; }
} catch { /* 未マイグレ */ }
const monthNet = monthIncome - monthExpense;
// 未処理伝票（個人→組織の承認待ち件数）。
let pendingCount = 0;
try { pendingCount = (await (await import("../lib/users.ts")).reviewQueue(env)).length; } catch { /* noop */ }
const notices = check?.notices ?? [];
const yen = (n: number) => "¥" + n.toLocaleString("ja-JP");
// バックアップ未実施/7日超過アラート（管理者のみ・P0-5）。
const backupAlertState = isOrgAdmin ? await (await import("../lib/backup.ts")).backupAlert(env).catch(() => ({ alert: false, never: false, lastAt: null })) : { alert: false, never: false, lastAt: null };
const fmtDay = (s: number) => new Date(s * 1000).toISOString().slice(0, 10);
// 時間帯で変わる挨拶（JST）。
const jstHour = (new Date().getUTCHours() + 9) % 24;
const greeting = jstHour < 11 ? "おはようございます" : jstHour < 18 ? "こんにちは" : "おつかれさまです";
const dispName = ses.name ? `${ses.name} さん` : "";
const aiSuggestions = ["今月の会費の入金状況をまとめて", "先週の理事会の議事録を要約して", "在庫管理のアプリを作りたい"];
const brandLabel = (await import("../core/theme.ts")).brandName(await (await import("../core/theme.ts")).getTheme(Astro.locals.ctx).catch(() => ({}) as import("../core/theme.ts").ThemeConfig));
// アプリ連携ウィジェット（有効アプリが提供：例 登録メンバー数・取引数）。span はアプリ側が指定。
const { widgetsOf, enabledParts } = await import("../core/parts.ts");
const widgetData: { title: string; value: string; sub?: string; span?: number }[] = [];
for (const w of widgetsOf(enabledParts([..._inst]))) {
  try { widgetData.push({ title: w.title, span: w.span, ...(await w.run(Astro.locals.ctx, ses.uid)) }); } catch { /* skip */ }
}
// ホームのセクション構成（団体ごと・並べ替え/非表示）。お知らせは固定で対象外。
const { getHomeLayout, orderedSections, HOME_SECTIONS } = await import("../core/home.ts");
const homeLayout = await getHomeLayout(Astro.locals.ctx).catch(() => null);
const sections = orderedSections(homeLayout);
const hiddenSet = new Set(homeLayout?.hidden ?? []);
const clampSpan = (n?: number) => Math.max(1, Math.min(3, Number(n) || 1));
---
<App title="ホーム" active="/">
  <Slot name="home-hero" />
  <div class="home-head">
    <div>
      <div class="eyebrow">{brandLabel}</div>
      <h1 class="h1" style="margin:.25rem 0 0">{greeting}{dispName && <span style="color:var(--muted);font-weight:600">、{dispName}</span>}</h1>
    </div>
    <div class="home-head-right">
      <span class="pill brand">{planLabel(entitlement)}</span>
      <span class="pill"><span class="dot" style={`background:${check ? "var(--ok)" : "var(--faint)"}`}></span>{check ? "疎通OK" : "オフライン"}</span>
      {isOrgAdmin && (<button class="btn btn-ghost btn-sm" id="editHome">ホームを編集</button>)}
    </div>
  </div>

  {/* 相棒プロンプト（AI相棒への導線） */}
  <div class="card ai-prompt" style="margin-top:1rem">
    <div class="row" style="display:flex;align-items:center;gap:12px">
      <span class="orb" style="width:34px;height:34px"></span>
      <div><strong>相棒に話しかける</strong><div class="muted" style="font-size:.82rem">やりたいことを書くと、AIが手伝います。</div></div>
    </div>
    <form class="ai-prompt-bar" method="get" action="/chat">
      <input class="ap-input" name="q" placeholder="例：今月の会費の入金状況をまとめて" aria-label="相棒に話しかける" />
      <button class="btn btn-primary btn-sm" type="submit" style="flex:0 0 auto">送信</button>
    </form>
    <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.7rem">
      {aiSuggestions.map((s) => (<a class="chip" href={`/chat?q=${encodeURIComponent(s)}`}>{s}</a>))}
    </div>
  </div>

  <style>
    .home-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 14px; flex-wrap: wrap; }
    .home-head-right { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
    .ai-prompt { background: linear-gradient(180deg, var(--brand-soft), var(--surface) 60%); border-color: color-mix(in srgb, var(--brand) 22%, var(--line)); }
    .ai-prompt-bar { display: flex; gap: 10px; align-items: center; margin-top: 12px; padding: 7px 7px 7px 16px; background: var(--surface); border: 1px solid var(--line-strong); border-radius: var(--r-pill); }
    .ai-prompt-bar:focus-within { border-color: var(--brand); box-shadow: var(--ring); }
    .ap-input { flex: 1; border: 0; background: transparent; outline: none; font: inherit; font-size: .94rem; color: var(--ink); padding: 4px 0; }
  </style>

  {/* 固定セクション：baku-office からのお知らせ・重要なお知らせ（並べ替え/非表示の対象外・常に最上部）。 */}
  <section class="home-fixed">
    <h2>お知らせ</h2>
    {notices.length === 0 && !updateAvailable && (<p class="muted">現在、新しいお知らせはありません。</p>)}
    {notices.map((n) => (<div class={`banner ${n.severity === "critical" ? "banner-danger" : n.severity === "important" ? "banner-warn" : "banner-info"}`} data-sev={n.severity} data-id={n.id}>{n.body}</div>))}
    {updateAvailable && (
      <div class="banner banner-warn">🔔 新しいバージョン <strong>{check?.latestVersion}</strong> があります（現在 {APP_VERSION}）。{isOrgAdmin ? <a href="/settings/update">更新する</a> : "管理者にアプリの更新をご依頼ください。"}</div>
    )}
    {backupAlertState.alert && (
      <div class="banner banner-warn">💾 {backupAlertState.never ? "データのバックアップがまだ実行されていません。" : `最終バックアップから7日以上経過しています（最終：${backupAlertState.lastAt ? fmtDay(backupAlertState.lastAt) : "—"}）。`}<a href="/backup">今すぐバックアップ</a></div>
    )}
  </section>

  {/* 並べ替え/非表示できるセクション群（団体ごと）。 */}
  {sections.map((sec) => (
    sec === "summary" ? (
      <section data-sec="summary">
        <div class="grid">
          <a class="card link" href="/accounting"><div class="label">口座残高（期首合計）</div><div class="num">{yen(balance)}</div></a>
          <a class="card link" href="/accounting"><div class="label">当月収支（{ym}）</div><div class="num" style={`color:${monthNet < 0 ? "var(--danger)" : monthNet > 0 ? "var(--ok)" : "inherit"}`}>{(monthNet < 0 ? "-¥" : "¥") + Math.abs(monthNet).toLocaleString("ja-JP")}</div><div class="muted" style="font-size:.78rem">収入 {yen(monthIncome)}／支出 {yen(monthExpense)}</div></a>
          <a class="card link" href="/review"><div class="label">未処理伝票（承認待ち）</div><div class="num">{pendingCount}</div><div class="muted" style="font-size:.78rem">{pendingCount > 0 ? "確認してください" : "なし"}</div></a>
          <div class="card"><div class="label">プラン / ライセンス</div><div class="num" style="font-size:1.1rem">{planLabel(entitlement)}</div></div>
        </div>
      </section>
    ) : sec === "widgets" ? (
      widgetData.length > 0 && (
        <section data-sec="widgets">
          <h2>アプリの状況</h2>
          <div class="grid wgrid">
            {widgetData.map((w) => (
              <div class="card" style={`grid-column:span ${clampSpan(w.span)}`}><div class="label">{w.title}</div><div class="num">{w.value}</div>{w.sub && <div class="muted" style="font-size:.82rem">{w.sub}</div>}</div>
            ))}
          </div>
        </section>
      )
    ) : sec === "storage" ? (
      <section data-sec="storage">
        <h2>ストレージ使用量</h2>
        {nearFull.map((s) => (<div class="banner banner-warn">⚠️ <strong>{s.label}</strong> が上限の {pct(s.used, s.limit)}% に達しています。{hintText[s.hint]}</div>))}
        <div class="grid">
          {storage.map((s) => (
            <div class="card">
              <div class="label">{s.label}{!s.enabled && (s.key === "r2" ? "（未使用）" : s.key === "drive" ? "（未連携）" : "")}</div>
              <div class="gauge"><div class={`gfill ${pct(s.used, s.limit) >= 80 ? "hot" : ""}`} style={`width:${pct(s.used, s.limit)}%`}></div></div>
              <div class="muted" style="font-size:.82rem;margin-top:4px">{s.used < 0 ? "計測不可" : `${fmtBytes(s.used)} / ${fmtBytes(s.limit)}（${pct(s.used, s.limit)}%）`}</div>
              {(s.hint === "paid" || s.hint === "r2") && (<div class="muted" style="font-size:.74rem;margin-top:2px"><a href="/settings/advanced">{s.hint === "r2" ? "R2 を有効化" : "Workers Paid で拡張"}</a></div>)}
              {s.key === "drive" && !s.enabled && (<div class="muted" style="font-size:.74rem;margin-top:2px"><a href="/drive">連携する</a></div>)}
            </div>
          ))}
        </div>
      </section>
    ) : sec === "quicklinks" ? (
      <section data-sec="quicklinks">
        <h2>できること</h2>
        <div class="grid">
          <a class="card" href="/accounting" style="text-decoration:none;color:inherit"><strong>会計</strong><div class="muted">入出金・出納帳・収支・CSV</div></a>
          <a class="card" href="/files" style="text-decoration:none;color:inherit"><strong>ファイル</strong><div class="muted">アップロード・共有</div></a>
          <a class="card" href="/minutes" style="text-decoration:none;color:inherit"><strong>議事録</strong><div class="muted">作成・一覧</div></a>
          <a class="card" href="/apps" style="text-decoration:none;color:inherit"><strong>アプリ</strong><div class="muted">機能の導入・開発</div></a>
        </div>
      </section>
    ) : null
  ))}

  {/* ホーム編集モーダル（別ウィンドウ）：セクションの表示/非表示・並べ替え。 */}
  {isOrgAdmin && (
    <div class="modal" id="homeModal"><div class="box">
      <h2 style="margin-top:0;border:0">ホームの表示を編集</h2>
      <p class="muted" style="font-size:.85rem">セクションの表示/非表示と並び順を変更します（お知らせは固定）。</p>
      <div id="secList" class="sec-list">
        {HOME_SECTIONS.map((s) => (
          <div class="sec-row" data-id={s.id}>
            <label style="flex:1"><input type="checkbox" class="sec-on" checked={!hiddenSet.has(s.id)} /> {s.label}</label>
            <button class="btn btn-sm sec-up" title="上へ">↑</button>
            <button class="btn btn-sm sec-down" title="下へ">↓</button>
          </div>
        ))}
      </div>
      <div class="row" style="margin-top:1rem">
        <button class="btn btn-primary" id="saveHome" style="flex:1">保存</button>
        <button class="btn btn-ghost" id="closeHome" style="flex:0 0 auto">閉じる</button>
      </div>
    </div></div>
  )}

  <div class="modal" id="critModal"><div class="box"><h2 style="margin-top:0;border:0">重要なお知らせ</h2><div id="critBody"></div><button class="btn btn-primary" id="critAck" style="margin-top:1rem">確認しました</button></div></div>

  <style>
    .gauge { height: 8px; background: #eef1f5; border-radius: 4px; overflow: hidden; margin-top: 6px; }
    .gfill { height: 100%; background: #14365c; border-radius: 4px; transition: width .3s; }
    .gfill.hot { background: #b4541a; }
    .wgrid { grid-auto-flow: row dense; }
    .sec-list { display: flex; flex-direction: column; gap: 6px; }
    .sec-row { display: flex; align-items: center; gap: 6px; border: 1px solid #dde3ea; border-radius: 6px; padding: 6px 8px; }
    .sec-row.off { opacity: .55; }
  </style>

  <script slot="scripts" is:inline>
    (function () {
      // 重要なお知らせの確認モーダル。
      const crit = [...document.querySelectorAll('.banner[data-sev="critical"]')].filter((n) => !localStorage.getItem("ack:" + n.dataset.id));
      if (crit.length) {
        const m = document.getElementById("critModal");
        document.getElementById("critBody").innerHTML = crit.map((n) => "<p>" + n.textContent + "</p>").join("");
        m.classList.add("open");
        document.getElementById("critAck").onclick = () => { crit.forEach((n) => localStorage.setItem("ack:" + n.dataset.id, "1")); m.classList.remove("open"); window.bo.toast("確認しました"); };
      }
      // ホーム編集（管理者のみ要素が存在）。
      const edit = document.getElementById("editHome");
      const modal = document.getElementById("homeModal");
      if (edit && modal) {
        const list = document.getElementById("secList");
        const refresh = () => list.querySelectorAll(".sec-row").forEach((r) => r.classList.toggle("off", !r.querySelector(".sec-on").checked));
        edit.addEventListener("click", () => { modal.classList.add("open"); refresh(); });
        document.getElementById("closeHome")?.addEventListener("click", () => modal.classList.remove("open"));
        list.querySelectorAll(".sec-row").forEach((row) => {
          row.querySelector(".sec-on")?.addEventListener("change", refresh);
          row.querySelector(".sec-up")?.addEventListener("click", () => { const p = row.previousElementSibling; if (p) list.insertBefore(row, p); });
          row.querySelector(".sec-down")?.addEventListener("click", () => { const n = row.nextElementSibling; if (n) list.insertBefore(n, row); });
        });
        document.getElementById("saveHome")?.addEventListener("click", async (e) => {
          const rows = [...list.querySelectorAll(".sec-row")];
          const order = rows.map((r) => r.dataset.id);
          const hidden = rows.filter((r) => !r.querySelector(".sec-on").checked).map((r) => r.dataset.id);
          const r = await window.bo.api("/api/settings", { _action: "home_layout", layout: { order, hidden } }, { btn: e.currentTarget, successMsg: "ホームの表示を保存しました" });
          if (r.ok) setTimeout(() => location.reload(), 600);
        });
      }
    })();
  </script>
</App>
