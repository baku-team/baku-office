---
export const prerender = false;
import App from "../layouts/App.astro";
import { atLeast } from "@baku-office/shared";
const env = Astro.locals.runtime.env;
const { getSession } = await import("../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses) return Astro.redirect("/login", 302);
const isAdmin = ses.role === "admin" && ses.ctx === "org";
const { cachedEntitlement } = await import("../lib/client.ts");
const hasPro = atLeast(await cachedEntitlement(env), "pro");
const { googleConfigured, googleConnected } = await import("../lib/google.ts");

let configured = false, connected = false;
if (hasPro) {
  configured = googleConfigured(env);
  connected = await googleConnected(env);
}
---
<App title="Gmail" active="/gmail">
  <h1>Gmail 連携</h1>
  {!hasPro && (
    <div class="card">
      <div class="banner banner-warn">この機能は <strong>Pro 以上</strong>のプランで利用できます。</div>
      <p class="muted">Gmail のメールを一覧・検索・閲覧・送信できます。AIチャットから操作します。</p>
      <a class="btn btn-primary" href="/billing">プラン・課金へ</a>
    </div>
  )}
  {hasPro && (
    <Fragment>
      {!configured && (<div class="banner banner-warn">Google OAuth（GOOGLE_CLIENT_ID/SECRET）が未設定のため連携できません。管理者にご確認ください。</div>)}
      <div class="card">
        <p>Google 連携：<span class="pill">{connected ? "連携済み" : "未連携"}</span> <span class="muted" style="font-size:.8rem">（カレンダー・Gmail・Meet 共通）</span></p>
        {isAdmin && configured && !connected && (<a class="btn btn-primary" href="/api/google/start">Google と連携</a>)}
        {isAdmin && connected && (<div class="row"><a class="btn" href="/api/google/start">再連携</a><button class="btn" id="gdisc">連携を解除</button></div>)}
        {!isAdmin && (<p class="muted">連携・解除の操作は管理者のみ可能です。</p>)}
      </div>
      {connected && (
        <div class="card">
          <h2 style="margin-top:0;border:0">使い方</h2>
          <p class="muted">メールの確認・検索・送信は AIチャットに依頼してください。例：</p>
          <ul class="muted">
            <li>「未読メールを一覧して」</li>
            <li>「山田さんからの先週のメールを探して」</li>
            <li>「○○さんに会議のお礼メールを送って」</li>
          </ul>
        </div>
      )}
    </Fragment>
  )}
  <script slot="scripts" is:inline>
    const d = document.getElementById("gdisc");
    if (d) d.addEventListener("click", async (e) => {
      const r = await window.bo.api("/api/google", { _action: "disconnect" }, { btn: e.currentTarget, successMsg: "連携を解除しました" });
      if (r.ok) setTimeout(() => location.reload(), 600);
    });
  </script>
</App>
