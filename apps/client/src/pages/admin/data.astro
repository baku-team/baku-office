---
import { env } from "cloudflare:workers";
export const prerender = false;
const { getSession } = await import("../../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses || ses.role !== "admin" || ses.ctx !== "org") return Astro.redirect("/login", 302);

// ゴミ箱（ソフトデリート済み）一覧。
const trashTx = (await env.DB.prepare("SELECT id,date,amount,description FROM transactions WHERE deleted_at IS NOT NULL ORDER BY deleted_at DESC LIMIT 100").all<{ id: string; date: string; amount: number; description: string | null }>()).results;
const trashFiles = (await env.DB.prepare("SELECT id,name,size FROM files WHERE deleted_at IS NOT NULL ORDER BY deleted_at DESC LIMIT 100").all<{ id: string; name: string; size: number }>()).results;
const audit = (await env.DB.prepare("SELECT actor,action,target,timestamp FROM audit_log ORDER BY timestamp DESC LIMIT 50").all<{ actor: string; action: string; target: string; timestamp: number }>()).results;
const t = (s: number) => new Date(s * 1000).toISOString().slice(0, 16).replace("T", " ");
---
<!doctype html>
<html lang="ja"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>直接DB操作 — baku-office</title>
<style>body{font-family:system-ui,sans-serif;max-width:920px;margin:0 auto;color:#1c2530}header{background:#0f172a;color:#fff;padding:.8rem 1.25rem}header a{color:#cbd5e1;text-decoration:none;margin-right:1rem;font-size:.9rem}main{padding:1.25rem}h2{border-bottom:2px solid #e2e8f0;padding-bottom:.3rem;margin-top:1.8rem}table{border-collapse:collapse;width:100%;font-size:.88rem}th,td{border:1px solid #e2e8f0;padding:.35rem .5rem}th{background:#f8fafc}button{padding:.25rem .55rem;border:0;border-radius:6px;cursor:pointer}.muted{color:#64748b}</style></head>
<body>
<header><a href="/">ホーム</a><a href="/settings/members">人・ロール管理</a><a href="/admin/data">直接DB操作</a></header>
<main>
<h1>直接DB／ストレージ操作（自己責任・§12）</h1>
<p class="muted">削除は一旦ゴミ箱（30日保持目安）。復元・完全削除が可能。すべて監査ログに記録されます。</p>

<h2>ゴミ箱：取引</h2>
<table><thead><tr><th>日付</th><th>金額</th><th>摘要</th><th>操作</th></tr></thead><tbody>
  {trashTx.map((r)=>(<tr data-t="transactions" data-id={r.id}><td>{r.date}</td><td>¥{r.amount.toLocaleString("ja-JP")}</td><td>{r.description ?? ""}</td><td><button class="restore" style="background:#16a34a;color:#fff">復元</button> <button class="purge" style="background:#ef4444;color:#fff">完全削除</button></td></tr>))}
  {trashTx.length===0 && (<tr><td colspan="4" class="muted">空</td></tr>)}
</tbody></table>

<h2>ゴミ箱：ファイル</h2>
<table><thead><tr><th>名前</th><th>サイズ</th><th>操作</th></tr></thead><tbody>
  {trashFiles.map((r)=>(<tr data-t="files" data-id={r.id}><td>{r.name}</td><td>{r.size}B</td><td><button class="restore" style="background:#16a34a;color:#fff">復元</button> <button class="purge" style="background:#ef4444;color:#fff">完全削除</button></td></tr>))}
  {trashFiles.length===0 && (<tr><td colspan="3" class="muted">空</td></tr>)}
</tbody></table>

<h2>操作監査ログ</h2>
<table><thead><tr><th>日時</th><th>実行者</th><th>操作</th><th>対象</th></tr></thead><tbody>
  {audit.map((a)=>(<tr><td>{t(a.timestamp)}</td><td>{a.actor}</td><td>{a.action}</td><td>{a.target}</td></tr>))}
  {audit.length===0 && (<tr><td colspan="4" class="muted">記録なし</td></tr>)}
</tbody></table>

<script type="module">
  const post=(b)=>fetch("/api/data",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify(b)}).then(r=>r.json());
  document.querySelectorAll("tr[data-id]").forEach(tr=>{
    const table=tr.dataset.t,id=tr.dataset.id;
    tr.querySelector(".restore").onclick=async()=>{await post({_action:"restore",table,id});location.reload();};
    tr.querySelector(".purge").onclick=async()=>{if(confirm("このレコードを完全削除しますか？元に戻せません。")){await post({_action:"purge",table,id});location.reload();}};
  });
</script>
</main></body></html>
