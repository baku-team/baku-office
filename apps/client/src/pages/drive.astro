---
export const prerender = false;
import App from "../layouts/App.astro";
import { atLeast } from "@baku-office/shared";
const env = Astro.locals.runtime.env;
const { getSession } = await import("../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses) return Astro.redirect("/login", 302);
const isAdmin = ses.role === "admin" && ses.ctx === "org";
const { cachedEntitlement } = await import("../lib/client.ts");
const hasPlus = atLeast(await cachedEntitlement(env), "plus");
const { driveConfigured, driveConnected, listDriveFiles, getDriveBackup } = await import("../lib/drive.ts");

const q = Astro.url.searchParams.get("q") ?? "";
let configured = false, connected = false, files: { id: string; name: string; mime: string | null; size: number | null; modified: string | null; synced_at: number }[] = [];
let backup = { enabled: false };
if (hasPlus) {
  configured = driveConfigured(env);
  connected = await driveConnected(env);
  files = connected ? await listDriveFiles(env, q) : [];
  backup = await getDriveBackup(env);
}
const fmtSize = (n: number | null) => (n == null ? "—" : n < 1024 ? n + "B" : n < 1048576 ? Math.round(n / 1024) + "KB" : (n / 1048576).toFixed(1) + "MB");
const fmtDate = (s: string | null) => (s ? s.slice(0, 16).replace("T", " ") : "—");
---
<App title="Google ドライブ" active="/drive">
  <h1>Google ドライブ連携</h1>
  {!hasPlus && (
    <div class="card">
      <div class="banner banner-warn">この機能は <strong>Plus 以上</strong>のプランで利用できます。</div>
      <p class="muted">ドライブ内ファイルのメタ情報を同期して検索・参照し、KV／R2 をドライブへ定期バックアップできます。</p>
      <a class="btn btn-primary" href="/billing">プラン・課金へ</a>
    </div>
  )}
  {hasPlus && (
    <Fragment>
      {!configured && (<div class="banner banner-warn">Google OAuth（GOOGLE_CLIENT_ID/SECRET）が未設定のため連携できません。連携設定の管理者にご確認ください。</div>)}
      <div class="card">
        <p>連携状態：<span class="pill">{connected ? "連携済み" : "未連携"}</span></p>
        {isAdmin && configured && !connected && (<a class="btn btn-primary" href="/api/drive/start">Google ドライブを連携</a>)}
        {isAdmin && connected && (<div class="row"><button class="btn btn-primary" id="sync">メタ情報を同期</button><a class="btn" href="/api/drive/start">再連携</a></div>)}
        {!isAdmin && (<p class="muted">連携・同期の操作は管理者のみ可能です。</p>)}
      </div>

      {connected && (
        <Fragment>
          <div class="card">
            <h2 style="margin-top:0;border:0">自動バックアップ（任意）</h2>
            <p class="muted">クライアントの KV／R2 に保存したファイルを、定期実行で Google ドライブへバックアップします（顧客自身のドライブへ退避）。</p>
            <label><input type="checkbox" id="bkEnabled" checked={backup.enabled} disabled={!isAdmin} /> 自動バックアップを有効にする</label>
            {isAdmin && (<div class="row" style="margin-top:.5rem"><button class="btn btn-primary" id="bkSave">設定を保存</button><button class="btn" id="bkNow">今すぐバックアップ</button></div>)}
          </div>

          <h2>ドライブ内ファイル（メタ情報）</h2>
          <form method="get" class="row" style="margin-bottom:.5rem">
            <input name="q" value={q} placeholder="ファイル名で検索" />
            <button class="btn" type="submit" style="flex:0 0 auto">検索</button>
          </form>
          <div class="table-wrap"><table>
            <thead><tr><th>名前</th><th>種類</th><th>サイズ</th><th>更新</th></tr></thead>
            <tbody>
              {files.map((f) => (<tr><td>{f.name}</td><td class="muted" style="font-size:.8rem">{f.mime ?? "—"}</td><td>{fmtSize(f.size)}</td><td>{fmtDate(f.modified)}</td></tr>))}
              {files.length === 0 && (<tr><td colspan="4" class="muted">{q ? "該当なし" : "未同期です。「メタ情報を同期」を実行してください。"}</td></tr>)}
            </tbody>
          </table></div>
        </Fragment>
      )}

      <script slot="scripts" is:inline>
        const sync = document.getElementById("sync");
        if (sync) sync.addEventListener("click", async (e) => {
          const r = await window.bo.api("/api/drive", { _action: "sync" }, { btn: e.currentTarget, successMsg: null });
          if (r.ok) { window.bo.toast((r.data.synced ?? 0) + " 件を同期しました"); setTimeout(() => location.reload(), 800); }
        });
        const bkSave = document.getElementById("bkSave");
        if (bkSave) bkSave.addEventListener("click", async (e) => {
          await window.bo.api("/api/drive", { _action: "backup_settings", enabled: document.getElementById("bkEnabled").checked }, { btn: e.currentTarget, successMsg: "保存しました" });
        });
        const bkNow = document.getElementById("bkNow");
        if (bkNow) bkNow.addEventListener("click", async (e) => {
          const r = await window.bo.api("/api/drive", { _action: "backup_now" }, { btn: e.currentTarget, successMsg: null });
          if (r.ok) window.bo.toast((r.data.uploaded ?? 0) + " 件をバックアップしました");
        });
      </script>
    </Fragment>
  )}
</App>
