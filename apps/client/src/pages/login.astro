---
export const prerender = false;
import App from "../layouts/App.astro";
const env = Astro.locals.runtime.env;
const { providerEnabled } = await import("../lib/oauth.ts");
// 自前Google設定、または当社ホスト経由の中継ログイン（VERIFY_PUBLIC_JWK＋HOST_BASE_URL）が使えるなら Google ボタンを出す。
const google = providerEnabled(env, "google") || !!env.HOST_BASE_URL;
const line = providerEnabled(env, "line");
const discord = providerEnabled(env, "discord");
const e = Astro.url.searchParams.get("e");
const activated = Astro.url.searchParams.get("activated");
const emsg: Record<string, string> = { state: "セッションが切れました。再度お試しください。", oauth: "認証に失敗しました。", notorg: "この組織のGoogleアカウントではありません。", pending: "登録は管理者の承認待ちです。", noapply: "このGoogleアカウント（メール）に対応する申込が見つかりません。申込時のメールのGoogleアカウントでログインしてください。" };
---
<App title="ログイン" auth={false}>
  <h1 style="margin-top:1rem;display:flex;align-items:center;gap:.5rem">ログイン<span class="beta-badge" title="本サービスは現在ベータ（試験提供）版です">β版</span></h1>
  <div class="banner banner-warn">🧪 本サービスは現在<strong>ベータ（試験提供）版</strong>です。現在ログインできるのは<strong>Test ユーザーのみ</strong>です。</div>
  {activated && <div class="banner banner-info">✅ アクティベーションが完了しました。続けて Google でログインしてください。</div>}
  {e && <div class="banner banner-danger">{emsg[e] ?? "エラー"}</div>}
  <div class="card">
    <h2 style="margin-top:0;border:0">組織（管理者）</h2>
    {google
      ? <a class="btn btn-primary" href="/api/auth/google/start">Googleでログイン</a>
      : <><p class="muted">本番は組織のGoogleアカウントで認証（§6.2）。dev：</p><button class="btn btn-primary" id="org">組織管理者としてログイン（dev）</button></>}
  </div>
  <div class="card" style="margin-top:1rem">
    <h2 style="margin-top:0;border:0">個人（メンバー）</h2>
    {(line || discord)
      ? <p>{line && <a class="btn" style="background:#06c755;color:#fff" href="/api/auth/line/start">LINEでログイン</a>} {discord && <a class="btn" style="background:#5865f2;color:#fff" href="/api/auth/discord/start">Discordでログイン</a>}</p>
      : <><p class="muted">本番はLINEログイン等（§6.2）。dev：ID/パスワード。</p><div class="field"><label for="lid">ログインID</label><input id="lid" name="lid" autocomplete="username" placeholder="ログインID" /></div><div class="field"><label for="lpw">パスワード</label><input id="lpw" name="lpw" type="password" autocomplete="current-password" placeholder="パスワード" /></div><button class="btn btn-primary" id="local">個人ログイン</button></>}
    <p class="muted">招待コードをお持ちの方は <a href="/join">こちらから参加</a></p>
  </div>
  <script slot="scripts" is:inline>
    const org=document.getElementById("org");
    if(org)org.addEventListener("click",async(e)=>{const r=await window.bo.api("/api/login",{mode:"org"},{btn:e.currentTarget,successMsg:"ログインしました"});if(r.ok)location.href="/";});
    const lc=document.getElementById("local");
    if(lc)lc.addEventListener("click",async(e)=>{const r=await window.bo.api("/api/login",{mode:"local",loginId:document.getElementById("lid").value,password:document.getElementById("lpw").value},{btn:e.currentTarget,successMsg:"ログインしました"});if(r.ok)location.href="/";});
  </script>
</App>
