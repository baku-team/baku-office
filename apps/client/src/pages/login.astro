---
export const prerender = false;
import App from "../layouts/App.astro";
const env = Astro.locals.runtime.env;
const { providerEnabled } = await import("../lib/oauth.ts");
// 自前Google設定、または当社ホスト経由の中継ログイン（VERIFY_PUBLIC_JWK＋HOST_BASE_URL）が使えるなら Google ボタンを出す。
const google = providerEnabled(env, "google") || !!env.HOST_BASE_URL;
const line = providerEnabled(env, "line");
const discord = providerEnabled(env, "discord");
const e = Astro.url.searchParams.get("e");
const activated = Astro.url.searchParams.get("activated");
const emsg: Record<string, string> = { state: "セッションが切れました。再度お試しください。", oauth: "認証に失敗しました。", notorg: "この組織のGoogleアカウントではありません。", pending: "登録は管理者の承認待ちです。", noapply: "このGoogleアカウント（メール）に対応する申込が見つかりません。申込時のメールのGoogleアカウントでログインしてください。" };
const SPARK = "M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8z";
const CHECK = "M5 12.5l4.5 4.5L19 7";
const promises = [
  { t: "所有する", d: "データもAIも自社のクラウドの中。借り物ではありません。" },
  { t: "作る", d: "必要な機能は、AI相棒と一緒に作れます。" },
  { t: "育てる", d: "使うほど手になじむ、自社専用の相棒に。" },
];
---
<App title="ログイン" auth={false} bare>
  <div class="login">
    <!-- 左：ブランドパネル -->
    <div class="login-brand">
      <div class="login-orbs" aria-hidden="true"><span></span><span></span><span></span></div>
      <div class="lb-top">
        <span class="lb-mark"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={SPARK} /></svg></span>
        <strong>baku-office</strong>
        <span class="beta-badge">β版</span>
      </div>
      <div class="login-brand-mid">
        <div class="eyebrow" style="color:var(--brand)">合同会社 貘</div>
        <h1 class="display" style="margin:.5rem 0 0">借りるのではなく、<br />会社ごと<span style="color:var(--brand)">所有する。</span></h1>
        <div class="promises">
          {promises.map((p) => (
            <div class="promise">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={CHECK} /></svg>
              <div><strong>{p.t}</strong><span>{p.d}</span></div>
            </div>
          ))}
        </div>
      </div>
      <div class="lb-foot">© 合同会社 貘（Baku LLC）</div>
    </div>

    <!-- 右：操作パネル -->
    <div class="login-main">
      <div class="login-card">
        <h1 class="h1">おかえりなさい</h1>
        <p class="muted" style="margin:.3rem 0 0">baku-office にサインインしてください。</p>
        <div class="banner warn" style="margin-top:1.1rem">
          <div class="b-body">🧪 本サービスは現在<strong>ベータ（試験提供）版</strong>です。現在ログインできるのは<strong>Test ユーザーのみ</strong>です。</div>
        </div>
        {activated && <div class="banner info" style="margin-top:.7rem"><div class="b-body">✅ アクティベーションが完了しました。続けて Google でログインしてください。</div></div>}
        {e && <div class="banner danger" style="margin-top:.7rem"><div class="b-body">{emsg[e] ?? "エラー"}</div></div>}

        <div class="card" style="margin-top:1.1rem">
          <h2 class="h2" style="margin:0 0 .2rem">組織（管理者）</h2>
          {google
            ? <a class="g-btn" href="/api/auth/google/start"><span class="g-mark">G</span> Google でサインイン</a>
            : <><p class="muted" style="font-size:.85rem">本番は組織のGoogleアカウントで認証（§6.2）。dev：</p><button class="btn btn-primary btn-block" id="org">組織管理者としてログイン（dev）</button></>}
        </div>

        <div class="card" style="margin-top:1rem">
          <h2 class="h2" style="margin:0 0 .4rem">個人（メンバー）</h2>
          {(line || discord)
            ? <div class="row" style="display:flex;gap:.5rem;flex-wrap:wrap">{line && <a class="btn btn-block" style="background:#06c755;color:#fff" href="/api/auth/line/start">LINEでサインイン</a>} {discord && <a class="btn btn-block" style="background:#5865f2;color:#fff" href="/api/auth/discord/start">Discordでサインイン</a>}</div>
            : <><p class="muted" style="font-size:.85rem">本番はLINEログイン等（§6.2）。dev：ID/パスワード。</p><div class="field"><label for="lid">ログインID</label><input class="input" id="lid" name="lid" autocomplete="username" placeholder="ログインID" /></div><div class="field"><label for="lpw">パスワード</label><input class="input" id="lpw" name="lpw" type="password" autocomplete="current-password" placeholder="パスワード" /></div><button class="btn btn-primary btn-block" id="local">個人ログイン</button></>}
          <p class="muted" style="margin-top:.8rem;font-size:.85rem">招待コードをお持ちの方は <a href="/join">こちらから参加</a></p>
        </div>

        <p class="faint" style="font-size:.76rem;margin-top:1rem;text-align:center">続行すると<a href="/legal">利用規約・プライバシーポリシー</a>に同意したものとみなされます。</p>
      </div>
    </div>
  </div>

  <style>
    .login { min-height: 100vh; display: grid; grid-template-columns: 1.05fr 1fr; }
    .login-brand { position: relative; overflow: hidden; padding: 40px 48px; display: flex; flex-direction: column; justify-content: space-between; background: linear-gradient(160deg, #0E1A2B 0%, #122236 55%, #0A1320 100%); color: #F8F5EE; }
    .lb-top { display: flex; align-items: center; gap: .6rem; z-index: 2; font-size: 1.1rem; }
    .lb-mark { width: 34px; height: 34px; border-radius: 10px; display: grid; place-items: center; background: rgba(255,255,255,.1); color: var(--brand); border: 1px solid rgba(201,168,106,.5); }
    .lb-mark svg { width: 20px; height: 20px; }
    .login-brand-mid { max-width: 480px; z-index: 2; }
    .login-brand-mid .display { color: #F8F5EE; line-height: 1.2; }
    .promises { display: flex; flex-direction: column; gap: 14px; margin-top: 32px; }
    .promise { display: flex; gap: 12px; align-items: flex-start; }
    .promise svg { flex: 0 0 auto; margin-top: 2px; background: rgba(255,255,255,.16); border-radius: 50%; padding: 4px; width: 26px; height: 26px; color: #F8F5EE; }
    .promise strong { display: block; font-size: .98rem; }
    .promise span { color: rgba(255,255,255,.78); font-size: .86rem; }
    .lb-foot { z-index: 2; color: rgba(255,255,255,.55); font-size: .8rem; }
    .login-orbs { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
    .login-orbs span { position: absolute; border-radius: 50%; filter: blur(2px); }
    .login-orbs span:nth-child(1) { width: 320px; height: 320px; right: -90px; top: -70px; background: radial-gradient(circle, var(--brand), transparent 68%); opacity: .5; }
    .login-orbs span:nth-child(2) { width: 240px; height: 240px; right: 60px; bottom: -60px; background: radial-gradient(circle, #fff, transparent 65%); opacity: .12; }
    .login-orbs span:nth-child(3) { width: 160px; height: 160px; left: 40px; top: 45%; background: radial-gradient(circle, var(--brand), transparent 70%); opacity: .25; }
    .login-main { display: grid; place-items: center; padding: 32px 24px; background: var(--bg); }
    .login-card { width: 100%; max-width: 440px; }
    .g-btn { display: flex; align-items: center; justify-content: center; gap: 12px; width: 100%; min-height: 50px; border: 1px solid var(--line-strong); border-radius: var(--r); background: var(--surface); color: var(--ink); font-size: .96rem; font-weight: 600; cursor: pointer; transition: background .15s, transform .08s; text-decoration: none; }
    .g-btn:hover { background: var(--surface-3); }
    .g-mark { width: 24px; height: 24px; border-radius: 50%; display: grid; place-items: center; background: #fff; color: #4285f4; font-weight: 800; border: 1px solid var(--line); font-size: .9rem; }
    @media (max-width: 820px) {
      .login { grid-template-columns: 1fr; }
      .login-brand { padding: 28px 24px; }
      .login-brand-mid { margin: 18px 0; }
      .login-brand-mid .display { font-size: 1.7rem; }
      .promises { display: none; }
    }
  </style>

  <script slot="scripts" is:inline>
    const org=document.getElementById("org");
    if(org)org.addEventListener("click",async(e)=>{const r=await window.bo.api("/api/login",{mode:"org"},{btn:e.currentTarget,successMsg:"ログインしました"});if(r.ok)location.href="/";});
    const lc=document.getElementById("local");
    if(lc)lc.addEventListener("click",async(e)=>{const r=await window.bo.api("/api/login",{mode:"local",loginId:document.getElementById("lid").value,password:document.getElementById("lpw").value},{btn:e.currentTarget,successMsg:"ログインしました"});if(r.ok)location.href="/";});
  </script>
</App>
