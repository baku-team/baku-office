---
export const prerender = false;
---
<!doctype html>
<html lang="ja"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>ログイン — baku-office</title>
<style>body{font-family:system-ui,sans-serif;max-width:480px;margin:3rem auto;padding:0 1rem;color:#1c2530}
.card{border:1px solid #e2e8f0;border-radius:12px;padding:1.25rem;margin:1rem 0}
input{width:100%;padding:.5rem;border:1px solid #cbd5e1;border-radius:8px;margin:.25rem 0}
button{padding:.6rem 1.2rem;background:#2563eb;color:#fff;border:0;border-radius:8px;cursor:pointer;margin-top:.5rem}
.muted{color:#64748b;font-size:.85rem}</style></head>
<body>
<h1>ログイン</h1>
<div class="card">
  <h3>組織（管理者）</h3>
  <p class="muted">本番は組織のGoogleアカウントで認証（§6.2・P6）。dev：下のボタンで管理者ログイン。</p>
  <button id="org">組織管理者としてログイン（dev）</button>
</div>
<div class="card">
  <h3>個人（メンバー）</h3>
  <p class="muted">招待コードで参加後、ID/パスワードでログイン（本番はLINEログイン等）。</p>
  <input id="lid" placeholder="ログインID" />
  <input id="lpw" type="password" placeholder="パスワード" />
  <button id="local">個人ログイン</button>
  <p class="muted">招待コードをお持ちの方は <a href="/join">こちらから参加</a></p>
</div>
<p id="msg" style="color:#b91c1c"></p>
<script type="module">
  const msg=document.getElementById("msg");
  const go=()=>location.href="/";
  document.getElementById("org").onclick=async()=>{const r=await fetch("/api/login",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify({mode:"org"})});(await r.json()).ok?go():msg.textContent="失敗";};
  document.getElementById("local").onclick=async()=>{const r=await fetch("/api/login",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify({mode:"local",loginId:document.getElementById("lid").value,password:document.getElementById("lpw").value})});const j=await r.json();j.ok?go():(msg.textContent=j.error||"失敗");};
</script>
</body></html>
