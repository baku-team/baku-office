---
export const prerender = false;
import App from "../layouts/App.astro";
import { atLeast } from "@baku-office/shared";
const env = Astro.locals.runtime.env;
const { getSession } = await import("../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses) return Astro.redirect("/login", 302);
const { cachedEntitlement } = await import("../lib/client.ts");
const hasPlus = atLeast(await cachedEntitlement(env), "plus");
const isAdmin = ses.role === "admin" && ses.ctx === "org";

const { dailyTotals, monthTotals, todayTotals, monthUsd, monthTokens, getLimits, resetTimes, PROVIDER_LABEL, USAGE_PROVIDERS } = await import("../lib/usage.ts");
let daily: { day: string; count: number }[] = [];
let month: Record<string, number> = {};
let today: Record<string, number> = {};
let usd: Record<string, number> = {};
let tokens: Record<string, number> = {};
let limits: Record<string, { freeQuota?: number; monthlyCap?: number; monthlyUsdCap?: number; onExceed?: string }> = {};
let reset = { daily: "", monthly: "" };
if (hasPlus) {
  daily = await dailyTotals(env, 14);
  month = await monthTotals(env);
  today = await todayTotals(env);
  usd = await monthUsd(env);
  tokens = await monthTokens(env);
  limits = await getLimits(env);
  reset = resetTimes();
}
const maxDay = Math.max(1, ...daily.map((d) => d.count));
const fmtTok = (n: number) => (n >= 1e6 ? (n / 1e6).toFixed(2) + "M" : n >= 1e3 ? (n / 1e3).toFixed(1) + "k" : String(n));
const rows = USAGE_PROVIDERS.map((p) => ({ p, label: PROVIDER_LABEL[p] ?? p, today: today[p] ?? 0, month: month[p] ?? 0, usd: usd[p] ?? 0, tokens: tokens[p] ?? 0, lim: limits[p] ?? {} }));
const totalUsd = rows.reduce((a, r) => a + r.usd, 0);
const overs = rows.filter((r) => (r.lim.monthlyCap && r.month >= (r.lim.monthlyCap ?? 0)) || (r.lim.monthlyUsdCap && r.usd >= (r.lim.monthlyUsdCap ?? 0)));
const warns = rows.filter((r) => r.lim.freeQuota && r.today >= (r.lim.freeQuota ?? 0) * 0.8 && r.today < (r.lim.monthlyCap ?? Infinity));

// 任意API（画像/音声/動画など）。登録・有効化は管理者（旧・高度なオプションから統合）。
const { listCapabilities, CAPABILITY_LABEL } = await import("../lib/capabilities.ts");
const caps = hasPlus ? await listCapabilities(env).catch(() => []) : [];
// ストレージ容量（D1/KV/R2/Drive）。API使用量と同体裁で表示。上限編集は管理者。
const { getStorageUsage, getStorageLimits, fmtBytes } = await import("../lib/storage-usage.ts");
const storage = hasPlus ? await getStorageUsage(env).catch(() => []) : [];
const slimits: Partial<Record<string, number>> = hasPlus && isAdmin ? await getStorageLimits(env).catch(() => ({})) : {};
const spct = (u: number, l: number) => (u < 0 || l <= 0 ? 0 : Math.min(100, Math.round((u / l) * 100)));
---
<App title="使用量・上限" active="/usage">
  <h1>使用量・上限</h1>
  {!hasPlus && (
    <div class="card">
      <div class="banner banner-warn">この機能は <strong>Plus 以上</strong>のプランで利用できます。</div>
      <p class="muted">AI機能・各APIの利用回数を数値とグラフで確認し、無料枠アラート・従量上限・任意APIの登録・ストレージ容量を管理できます。</p>
      <a class="btn btn-primary" href="/billing">プラン・課金へ</a>
    </div>
  )}
  {hasPlus && (
    <Fragment>
      <p class="muted">AI機能・各APIの利用回数（リクエスト単位）。無料枠の目安・従量上限を設定できます（カウントはUTC日次）。</p>

      {overs.map((r) => (<div class="banner banner-danger">⛔ <strong>{r.label}</strong> が当月の上限（{r.lim.monthlyUsdCap && r.usd >= (r.lim.monthlyUsdCap ?? 0) ? `推定 $${(r.lim.monthlyUsdCap ?? 0).toFixed(2)}` : r.lim.monthlyCap}）に達しました。{r.lim.onExceed === "switch_free" ? "無料エンジン（Gemini）へ自動切替されます。" : "該当APIの利用を一時停止します。"} リセット：{reset.monthly}</div>))}
      {warns.map((r) => (<div class="banner banner-warn">⚠️ <strong>{r.label}</strong> が本日の無料枠（{r.lim.freeQuota}）に近づいています（本日 {r.today}）。リセット：{reset.daily}</div>))}

      <h2>直近14日の利用</h2>
      <div class="card">
        <div class="bars">
          {daily.map((d) => (
            <div class="bar" title={`${d.day}: ${d.count}`}>
              <div class="fill" style={`height:${Math.round((d.count / maxDay) * 100)}%`}></div>
              <div class="bl">{d.day.slice(5)}</div>
            </div>
          ))}
        </div>
        <p class="muted" style="margin:.4rem 0 0">14日合計：{daily.reduce((a, d) => a + d.count, 0)} 回</p>
      </div>

      <h2>プロバイダ別</h2>
      <div class="banner banner-info">リセット：無料枠＝<strong>{reset.daily}</strong>（日次）／上限＝<strong>{reset.monthly}</strong>（月次）／当月の推定費用合計＝<strong>${totalUsd.toFixed(2)}</strong>（参考単価による概算・実費は各プロバイダの請求が正）</div>
      <div class="table-wrap"><table>
        <thead><tr><th>API</th><th>本日</th><th>当月回数</th><th>当月token</th><th>当月推定$</th><th>無料枠/日</th><th>当月回数上限</th><th>当月上限$</th><th>超過時</th></tr></thead>
        <tbody>
          {rows.map((r) => (
            <tr data-prov={r.p}>
              <td>{r.label}</td>
              <td class={r.lim.freeQuota && r.today >= (r.lim.freeQuota ?? 0) * 0.8 ? "u-warn" : ""}>{r.today}{r.lim.freeQuota ? ` / ${r.lim.freeQuota}` : ""}</td>
              <td class={r.lim.monthlyCap && r.month >= (r.lim.monthlyCap ?? 0) ? "u-over" : ""}>{r.month}{r.lim.monthlyCap ? ` / ${r.lim.monthlyCap}` : ""}</td>
              <td class="muted">{r.tokens ? fmtTok(r.tokens) : "—"}</td>
              <td class={r.lim.monthlyUsdCap && r.usd >= (r.lim.monthlyUsdCap ?? 0) ? "u-over" : ""}>{r.usd ? `$${r.usd.toFixed(2)}` : "—"}{r.lim.monthlyUsdCap ? ` / $${r.lim.monthlyUsdCap}` : ""}</td>
              <td><input class="lim-fq" type="number" min="0" value={r.lim.freeQuota ?? ""} placeholder="—" disabled={!isAdmin} style="width:80px" /></td>
              <td><input class="lim-mc" type="number" min="0" value={r.lim.monthlyCap ?? ""} placeholder="—" disabled={!isAdmin} style="width:80px" /></td>
              <td><input class="lim-uc" type="number" min="0" step="0.01" value={r.lim.monthlyUsdCap ?? ""} placeholder="—" disabled={!isAdmin} style="width:80px" /></td>
              <td><select class="lim-oe" disabled={!isAdmin}><option value="pause" selected={r.lim.onExceed !== "switch_free"}>一時停止</option><option value="switch_free" selected={r.lim.onExceed === "switch_free"}>無料(Gemini)へ</option></select></td>
            </tr>
          ))}
        </tbody>
      </table></div>
      <p class="muted">「当月上限$」は応答tokenから算出した<strong>推定費用</strong>での hard cap（超過時に停止/切替）。token課金の実費に近づけるための上限です。</p>
      {isAdmin && (<button class="btn btn-primary" id="saveLimits">上限を保存</button>)}
      {!isAdmin && (<p class="muted">上限の変更は管理者のみ可能です。</p>)}

      <h2>任意API（画像生成・音声合成・動画生成など）</h2>
      <p class="muted">外部AIサービスをBYOKで追加。APIキーは暗号化保存。<strong>有効化したものはAI/エージェントが参照・実行</strong>します。利用料は団体負担。管理者がレビューして有効化。利用回数は上の表に計上されます。</p>
      {isAdmin && (
        <details><summary>能力を追加</summary>
          <div class="field"><select id="cap"><option value="image_gen">画像生成</option><option value="tts">音声合成</option><option value="video_gen">動画生成</option><option value="embed">埋め込み(検索)</option><option value="custom">カスタムAPI</option></select></div>
          <div class="field"><input id="cprov" placeholder="プロバイダ（openai / stability / elevenlabs 等）" /></div>
          <div class="row"><input id="cmodel" placeholder="モデル（任意）" /><input id="cendpoint" placeholder="エンドポイントURL（カスタム時）" /></div>
          <div class="field"><input id="ckey" type="password" placeholder="APIキー" /></div>
          <button class="btn btn-primary" id="capadd">登録（無効状態で保存）</button>
        </details>
      )}
      <div class="table-wrap" style="margin-top:.5rem"><table><thead><tr><th>能力</th><th>プロバイダ</th><th>状態</th><th>操作</th></tr></thead><tbody>
        {caps.map((c) => (<tr data-cid={c.id}><td>{CAPABILITY_LABEL[c.capability] ?? c.capability}</td><td>{c.provider ?? ""}{c.model ? `（${c.model}）` : ""}</td><td>{c.enabled ? "有効" : "無効"}</td><td>{isAdmin ? (<Fragment>{c.enabled ? <button class="btn btn-sm btn-warn cdis">無効化</button> : <button class="btn btn-sm btn-ok cen">有効化</button>} <button class="btn btn-sm btn-danger cdel">削除</button></Fragment>) : ""}</td></tr>))}
        {caps.length === 0 && (<tr><td colspan="4" class="muted">任意APIは未登録です。</td></tr>)}
      </tbody></table></div>

      <h2>ストレージ容量</h2>
      <p class="muted">D1／KV／R2／Googleドライブの使用量と上限。上限値はホームのゲージ表示にも使われます（Workers Paid／R2 有効化時は実枠に合わせて調整）。</p>
      <div class="table-wrap"><table>
        <thead><tr><th>区分</th><th>使用量</th><th>上限(GB)</th></tr></thead>
        <tbody>
          {storage.map((s) => (
            <tr data-skey={s.key}>
              <td>{s.label}{!s.enabled && (s.key === "r2" ? "（未使用）" : s.key === "drive" ? "（未連携）" : "")}</td>
              <td class={spct(s.used, s.limit) >= 80 ? "u-warn" : ""}>{s.used < 0 ? "計測不可" : `${fmtBytes(s.used)} / ${fmtBytes(s.limit)}（${spct(s.used, s.limit)}%）`}</td>
              <td><input class="lim-gb" type="number" min="0" step="0.1" value={(slimits as Record<string, number>)[s.key] ?? ""} placeholder="既定" disabled={!isAdmin} style="width:100px" /></td>
            </tr>
          ))}
        </tbody>
      </table></div>
      {isAdmin && (<button class="btn btn-primary" id="saveStorage">容量上限を保存</button>)}

      <script slot="scripts" is:inline>
        (function () {
          document.getElementById("saveLimits")?.addEventListener("click", async (e) => {
            const limits = {};
            document.querySelectorAll("tr[data-prov]").forEach((tr) => {
              const fq = tr.querySelector(".lim-fq").value;
              const mc = tr.querySelector(".lim-mc").value;
              const uc = tr.querySelector(".lim-uc").value;
              limits[tr.dataset.prov] = { freeQuota: fq ? Number(fq) : 0, monthlyCap: mc ? Number(mc) : 0, monthlyUsdCap: uc ? Number(uc) : 0, onExceed: tr.querySelector(".lim-oe").value };
            });
            const r = await window.bo.api("/api/usage", { limits }, { btn: e.currentTarget, successMsg: "上限を保存しました" });
            if (r.ok) setTimeout(() => location.reload(), 600);
          });
          // 任意API（capabilities）。
          const cap = (b, btn) => window.bo.api("/api/capabilities", b, { btn });
          document.getElementById("capadd")?.addEventListener("click", async (e) => {
            const r = await cap({ _action: "create", capability: document.getElementById("cap").value, provider: document.getElementById("cprov").value, model: document.getElementById("cmodel").value, endpoint: document.getElementById("cendpoint").value, api_key: document.getElementById("ckey").value }, e.currentTarget);
            if (r.ok) { window.bo.toast("登録しました（無効状態）"); setTimeout(() => location.reload(), 600); }
          });
          document.querySelectorAll("tr[data-cid]").forEach((tr) => {
            const id = tr.dataset.cid;
            tr.querySelector(".cen")?.addEventListener("click", async (e) => { const r = await cap({ _action: "enable", id, enabled: true }, e.target); if (r.ok) setTimeout(() => location.reload(), 500); });
            tr.querySelector(".cdis")?.addEventListener("click", async (e) => { const r = await cap({ _action: "enable", id, enabled: false }, e.target); if (r.ok) setTimeout(() => location.reload(), 500); });
            tr.querySelector(".cdel")?.addEventListener("click", async (e) => { if (confirm("削除しますか？")) { const r = await cap({ _action: "delete", id }, e.target); if (r.ok) setTimeout(() => location.reload(), 500); } });
          });
          // ストレージ容量上限。
          document.getElementById("saveStorage")?.addEventListener("click", async (e) => {
            const limits = {};
            document.querySelectorAll("tr[data-skey]").forEach((tr) => { const v = tr.querySelector(".lim-gb").value; limits[tr.dataset.skey] = v ? Number(v) : 0; });
            const r = await window.bo.api("/api/settings", { _action: "storage_limits", limits }, { btn: e.currentTarget, successMsg: "容量上限を保存しました" });
            if (r.ok) setTimeout(() => location.reload(), 600);
          });
        })();
      </script>
    </Fragment>
  )}
</App>

<style>
  .bars { display: flex; align-items: flex-end; gap: 4px; height: 140px; }
  .bar { flex: 1; display: flex; flex-direction: column; justify-content: flex-end; align-items: center; height: 100%; }
  .bar .fill { width: 64%; background: #14365c; border-radius: 3px 3px 0 0; min-height: 2px; transition: height .2s; }
  .bar .bl { font-size: .55rem; color: #6b7785; margin-top: 3px; white-space: nowrap; }
  .u-warn { color: #b4541a; font-weight: 700; }
  .u-over { color: #c0392b; font-weight: 700; }
</style>
