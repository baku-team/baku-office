---
export const prerender = false;
const env = Astro.locals.runtime.env;
const { getSession } = await import("../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses) return Astro.redirect("/login", 302);
const { recentDiagnostics, hasRecentLimitError } = await import("../lib/diag.ts");
const diags = await recentDiagnostics(env);
const limit = await hasRecentLimitError(env);
const t = (s: number) => new Date(s * 1000).toISOString().slice(0, 16).replace("T", " ");
---
<!doctype html>
<html lang="ja"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>診断・サポート — baku-office</title>
<style>body{font-family:system-ui,sans-serif;max-width:860px;margin:0 auto;color:#1c2530}header{background:#0f172a;color:#fff;padding:.8rem 1.25rem}header a{color:#cbd5e1;text-decoration:none;margin-right:1rem;font-size:.9rem}main{padding:1.25rem}table{border-collapse:collapse;width:100%;font-size:.88rem}th,td{border:1px solid #e2e8f0;padding:.35rem .5rem}th{background:#f8fafc}.muted{color:#64748b}.alert{background:#fef2f2;border:1px solid #fca5a5;border-radius:8px;padding:.8rem 1rem;margin:.5rem 0}.lim{color:#b91c1c;font-weight:600}</style></head>
<body>
<header><a href="/">ホーム</a><a href="/diagnostics">診断・サポート</a>{ses.role==="admin"&&ses.ctx==="org"&&<a href="/settings/advanced">高度なオプション</a>}</header>
<main>
<h1>診断・サポート</h1>
{limit && (
  <div class="alert">
    ⚠️ 直近にCloudflareの<strong>無料枠の制限</strong>に達したと思われるエラーがあります。<br>
    大きなファイル・重い処理（要約・音声・生成）を安定させるには、
    <a href="/settings/advanced">高度なオプション → Workers Paid</a> の案内に沿って Cloudflare 有料プランへ切り替えてください。
  </div>
)}
<table><thead><tr><th>日時</th><th>区分</th><th>レベル</th><th>内容</th></tr></thead><tbody>
  {diags.map((d)=>(<tr><td>{t(d.created_at)}</td><td class={d.category==="limit"?"lim":""}>{d.category}</td><td>{d.level}</td><td>{d.message}</td></tr>))}
  {diags.length===0 && (<tr><td colspan="4" class="muted">記録はありません（正常）。</td></tr>)}
</tbody></table>
<p class="muted" style="margin-top:1rem">エラーログはこの団体のCloudflare内にのみ保存されます（PIIは含めません・§13.3）。</p>
</main></body></html>
