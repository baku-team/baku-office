---
export const prerender = false;
import App from "../layouts/App.astro";
import { atLeast } from "@baku-office/shared";
const env = Astro.locals.runtime.env;
const ctx = Astro.locals.ctx;
const { getSession } = await import("../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses) return Astro.redirect("/login", 302);
const isAdmin = ses.role === "admin" && ses.ctx === "org";
const { cachedEntitlement } = await import("../lib/client.ts");
const hasPro = atLeast(await cachedEntitlement(env), "pro");
const { googleConfigured, googleStatus } = await import("../lib/google.ts");

let configured = false, connected = false, eventsText = "";
let calGranted = false, lastUsed: number | null = null;
if (hasPro) {
  configured = googleConfigured(env);
  const st = await googleStatus(env);
  connected = st.connected;
  calGranted = st.groups.includes("calendar");
  lastUsed = st.lastUsed;
  if (connected) {
    const { listEvents } = await import("../parts/calendar.ts");
    eventsText = await listEvents(ctx, { max: 20 });
  }
}
const fmtTs = (s: number | null) => (s ? new Date(s * 1000).toISOString().slice(0, 16).replace("T", " ") + " UTC" : "—");
---
<App title="カレンダー" active="/calendar">
  <h1>カレンダー連携</h1>
  {!hasPro && (
    <div class="card">
      <div class="banner banner-warn">この機能は <strong>Pro 以上</strong>のプランで利用できます。</div>
      <p class="muted">Google カレンダーの予定を閲覧・作成（Meet付き会議の発行）・編集・削除できます。AIチャットからも操作できます。</p>
      <a class="btn btn-primary" href="/billing">プラン・課金へ</a>
    </div>
  )}
  {hasPro && (
    <Fragment>
      {!configured && (<div class="banner banner-warn">Google OAuth（GOOGLE_CLIENT_ID/SECRET）が未設定のため連携できません。管理者にご確認ください。</div>)}
      <div class="card">
        <p>カレンダー連携：<span class="pill">{calGranted ? "連携済み" : "未連携"}</span> {connected && <span class="muted" style="font-size:.8rem">最終利用：{fmtTs(lastUsed)}</span>}</p>
        {isAdmin && configured && (
          <div class="row">
            <a class="btn btn-primary" href="/api/google/start?groups=calendar">{calGranted ? "再連携" : "カレンダーを連携"}</a>
            {connected && (<button class="btn" id="gdisc">連携を全解除</button>)}
          </div>
        )}
        {!isAdmin && (<p class="muted">連携・解除の操作は管理者のみ可能です。</p>)}
      </div>
      {connected && (
        <Fragment>
          <h2>今後の予定</h2>
          <div class="card"><pre style="white-space:pre-wrap;font-size:.85rem;margin:0">{eventsText || "予定はありません。"}</pre></div>
          <p class="muted">予定の作成・編集・Meet付き会議の発行は、AIチャットに「来週月曜10時に定例会議をMeet付きで作成して」のように依頼してください。</p>
        </Fragment>
      )}
    </Fragment>
  )}
  <script slot="scripts" is:inline>
    const d = document.getElementById("gdisc");
    if (d) d.addEventListener("click", async (e) => {
      const r = await window.bo.api("/api/google", { _action: "disconnect" }, { btn: e.currentTarget, successMsg: "連携を解除しました" });
      if (r.ok) setTimeout(() => location.reload(), 600);
    });
  </script>
</App>
