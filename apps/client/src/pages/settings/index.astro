---
export const prerender = false;
import App from "../../layouts/App.astro";
import { atLeast } from "@baku-office/shared";
const env = Astro.locals.runtime.env;
const { getSession } = await import("../../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses) return Astro.redirect("/login", 302);
const { cachedEntitlement, getApiKey } = await import("../../lib/client.ts");
const entitlement = await cachedEntitlement(env).catch(() => "free" as const);
const isAdminOrg = ses.role === "admin" && ses.ctx === "org";
const hasPlus = atLeast(entitlement, "plus");

// 初期設定チェックリスト（§9 段階化）：確実に検出できる未設定項目だけを管理者に提示する。
type Step = { label: string; href: string; done: boolean; hint: string };
let steps: Step[] = [];
if (isAdminOrg) {
  const { googleConfigured } = await import("../../lib/google.ts");
  const aiReady = !!(await getApiKey(env, "gemini")) || !!(await getApiKey(env, "claude")) || !!env.LOCAL_AI_BASE_URL;
  const googleReady = await googleConfigured(env).catch(() => false);
  steps = [
    { label: "AIエンジンの接続", href: "/settings/keys", done: aiReady, hint: "Gemini / Claude のキー、またはローカルLLM" },
    { label: "プランの確認", href: "/billing", done: entitlement !== "free", hint: "Plus/Pro でAI・連携機能が解放" },
    { label: "Google 連携（任意）", href: "/settings/google-setup", done: googleReady, hint: "Calendar/Gmail/Meet。Gmailは明示同意のみ" },
  ];
}
const pendingSteps = steps.filter((s) => !s.done);

type Link = { href: string; label: string; desc: string; show: boolean };
type Group = { title: string; items: Link[] };
const groups: Group[] = [
  { title: "アカウント・メンバー", items: [
    { href: "/settings/members", label: "人・ロール", desc: "招待・承認・権限（管理者）", show: isAdminOrg },
    { href: "/billing", label: "プラン・課金", desc: "Free/Plus/Pro のアップグレード", show: isAdminOrg },
  ] },
  { title: "連携・AI", items: [
    { href: "/settings/keys", label: "連携設定（APIキー）", desc: "Gemini / LINE / Claude / Google", show: true },
    { href: "/settings/google-setup", label: "Google 連携セットアップ", desc: "Calendar/Gmail/Meet のOAuth設定を手順で案内", show: isAdminOrg },
    { href: "/usage", label: "使用量・上限", desc: "API消費・上限・任意API・ストレージ容量", show: hasPlus },
    { href: "/drive", label: "Googleドライブ連携", desc: "同期・バックアップ", show: hasPlus },
  ] },
  { title: "カスタマイズ・高度な設定", items: [
    { href: "/settings/advanced", label: "高度なオプション", desc: "AIエンジン・カスタム指示・KV上限・Workers Paid", show: isAdminOrg && hasPlus },
    { href: "/settings/domain", label: "カスタムドメイン", desc: "独自ドメインで公開（Plus以上）", show: isAdminOrg && hasPlus },
    { href: "/settings/a2a", label: "A2A（団体間連携）", desc: "他団体エージェントと相互同意で連携（Pro以上）", show: isAdminOrg && atLeast(entitlement, "pro") },
  ] },
  { title: "運用・サポート", items: [
    { href: "/backup", label: "バックアップ", desc: "全データの取得（ローカル/ドライブ）・復元・定期実行", show: isAdminOrg },
    { href: "/approvals", label: "エージェント操作の承認", desc: "AIの対外/破壊系操作（メール送信・予定変更/削除・A2A）の承認待ち", show: isAdminOrg },
    { href: "/legal", label: "外部送信・AI利用の開示", desc: "外部送信先一覧・保存期間・削除方法（規約転記用テキスト）", show: true },
    { href: "/review", label: "共有承認", desc: "個人→組織の承認", show: ses.role === "admin" || ses.role === "accounting" || ses.role === "clerical" },
    { href: "/diagnostics", label: "診断・サポート", desc: "稼働状況・エラー・Workers Paid 案内", show: true },
    { href: "/settings/update", label: "アプリの更新", desc: "最新版への更新", show: isAdminOrg },
  ] },
];
// カテゴリの可視化（左ナビ用）。空グループは除外。
const slugify = (s: string) => "g-" + s.replace(/[^\p{L}\p{N}]+/gu, "-");
const catIcon: Record<string, string> = {
  "アカウント・メンバー": "M8 11a3.2 3.2 0 100-6.4A3.2 3.2 0 008 11zM2.5 19a5.5 5.5 0 0111 0M16 11a3 3 0 000-6M21.5 19a5.5 5.5 0 00-4-5.3",
  "連携・AI": "M9 3v5M15 3v5M6 8h12v3a6 6 0 01-12 0zM12 17v4",
  "カスタマイズ・高度な設定": "M5 6h14M5 12h14M5 18h14M9 6a1.6 1.6 0 100 .01M15 12a1.6 1.6 0 100 .01M8 18a1.6 1.6 0 100 .01",
  "運用・サポート": "M12 3l7 2.5V11c0 4.5-3 8-7 9.5C8 19 5 15.5 5 11V5.5z",
};
const visGroups = groups.map((g) => ({ ...g, items: g.items.filter((i) => i.show) })).filter((g) => g.items.length > 0);
---
<App title="設定" active="/settings">
  <h1>設定</h1>
  <p class="muted">このシステムの設定・オプションをまとめています。項目を選んでください。</p>

  <div class="card" style="margin-top:1rem">
    <h2 class="h2" style="margin:0 0 .7rem">表示</h2>
    <div class="spread" style="flex-wrap:wrap;gap:14px">
      <div><strong>ダークモード</strong><div class="muted" style="font-size:.82rem">画面全体の配色を切り替えます。</div></div>
      <label class="switch"><input type="checkbox" id="set-dark" aria-label="ダークモード" /><span class="track"></span><span class="knob"></span></label>
    </div>
    <div class="hr"></div>
    <div class="spread" style="flex-wrap:wrap;gap:14px">
      <div><strong>ナビの形</strong><div class="muted" style="font-size:.82rem">メニューの配置（スマホ画面では自動で下部タブになります）。</div></div>
      <div class="seg" id="set-nav" role="group" aria-label="ナビの形">
        <button class="seg-opt" type="button" data-nav="top">上部</button>
        <button class="seg-opt" type="button" data-nav="side">サイド</button>
        <button class="seg-opt" type="button" data-nav="bottom">下部</button>
      </div>
    </div>
  </div>

  {isAdminOrg && pendingSteps.length > 0 && (
    <div class="card" style="border-left:3px solid var(--brand)">
      <strong>初期設定（あと {pendingSteps.length} 項目）</strong>
      <p class="muted" style="font-size:.85rem;margin:.2rem 0 .6rem">まず必須項目から段階的に設定すると、AI・連携機能を安全に有効化できます。</p>
      <ul style="margin:0;padding-left:1.2rem">
        {steps.map((s) => (
          <li style="margin:.2rem 0">
            <span aria-label={s.done ? "設定済み" : "未設定"}>{s.done ? "✅" : "⬜"}</span>{" "}
            {s.done ? <span>{s.label}</span> : <a href={s.href}>{s.label}</a>}
            <span class="muted" style="font-size:.8rem"> — {s.hint}</span>
          </li>
        ))}
      </ul>
    </div>
  )}
  <div class="settings">
    <nav class="set-nav" aria-label="設定カテゴリ">
      {visGroups.map((g, idx) => (
        <a class={"set-nav-btn" + (idx === 0 ? " on" : "")} href={"#" + slugify(g.title)} data-spy={slugify(g.title)}>
          <span class="sn-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={catIcon[g.title] ?? ""} /></svg></span>
          <span><strong>{g.title}</strong></span>
        </a>
      ))}
    </nav>
    <div class="set-pane">
      {visGroups.map((g) => (
        <section id={slugify(g.title)} style="margin-bottom:28px;scroll-margin-top:78px">
          <h2 style="margin-top:0">{g.title}</h2>
          <div class="grid">
            {g.items.map((i) => (
              <a class="card link" href={i.href}>
                <strong>{i.label}</strong>
                <div class="muted" style="font-size:.85rem;margin-top:.2rem">{i.desc}</div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>

  <style>
    .settings { display: grid; grid-template-columns: 260px 1fr; gap: 26px; margin-top: 22px; align-items: start; }
    .set-nav { display: flex; flex-direction: column; gap: 4px; position: sticky; top: 78px; }
    .set-nav-btn { display: flex; align-items: center; gap: 12px; padding: 12px 14px; border-radius: var(--r-sm); text-decoration: none; color: var(--ink-2); transition: background .15s; }
    .set-nav-btn:hover { background: var(--surface-3); }
    .set-nav-btn.on { background: var(--brand-soft); }
    .set-nav-btn.on strong { color: var(--brand-strong); }
    .set-nav-btn .sn-ico { width: 36px; height: 36px; border-radius: 10px; display: grid; place-items: center; background: var(--surface-3); color: var(--ink-2); flex: 0 0 auto; }
    .set-nav-btn .sn-ico svg { width: 19px; height: 19px; }
    .set-nav-btn.on .sn-ico { background: var(--brand); color: var(--on-brand); }
    .set-nav-btn strong { display: block; font-size: .92rem; }
    @media (max-width: 760px) {
      .settings { grid-template-columns: 1fr; }
      .set-nav { flex-direction: row; overflow-x: auto; position: static; padding-bottom: 6px; }
      .set-nav-btn { flex: 0 0 auto; }
    }
  </style>
  <script slot="scripts" is:inline>
    // 表示設定（ダークモード・ナビ形態）。localStorage に保存し即時反映（App.astro の起動スクリプトと同じキー）。
    (function () {
      const root = document.documentElement;
      const dark = document.getElementById("set-dark");
      if (dark) {
        dark.checked = root.getAttribute("data-theme") === "dark";
        dark.addEventListener("change", () => {
          root.classList.add("theme-switching");
          root.setAttribute("data-theme", dark.checked ? "dark" : "light");
          try { localStorage.setItem("bo_theme", dark.checked ? "dark" : "light"); } catch (e) { /* noop */ }
          requestAnimationFrame(() => requestAnimationFrame(() => root.classList.remove("theme-switching")));
        });
      }
      const seg = document.getElementById("set-nav");
      if (seg) {
        const cur = root.getAttribute("data-nav") || "bottom";
        seg.querySelectorAll(".seg-opt").forEach((b) => { b.classList.toggle("on", b.dataset.nav === cur); });
        seg.querySelectorAll(".seg-opt").forEach((b) => b.addEventListener("click", () => {
          root.setAttribute("data-nav", b.dataset.nav);
          try { localStorage.setItem("bo_nav", b.dataset.nav); } catch (e) { /* noop */ }
          seg.querySelectorAll(".seg-opt").forEach((x) => x.classList.toggle("on", x === b));
        }));
      }
    })();
    // スクロールスパイ：表示中セクションに応じて左ナビをハイライト。
    (function () {
      const btns = [...document.querySelectorAll(".set-nav-btn")];
      const map = new Map(btns.map((b) => [b.dataset.spy, b]));
      const secs = btns.map((b) => document.getElementById(b.dataset.spy)).filter(Boolean);
      if (!("IntersectionObserver" in window) || !secs.length) return;
      const io = new IntersectionObserver((ents) => {
        ents.forEach((en) => { if (en.isIntersecting) { btns.forEach((b) => b.classList.remove("on")); map.get(en.target.id)?.classList.add("on"); } });
      }, { rootMargin: "-78px 0px -70% 0px" });
      secs.forEach((s) => io.observe(s));
    })();
  </script>
</App>
