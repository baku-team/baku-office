---
export const prerender = false;
import App from "../../layouts/App.astro";
import { atLeast } from "@baku-office/shared";
const env = Astro.locals.runtime.env;
const { getSession } = await import("../../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses || ses.role !== "admin" || ses.ctx !== "org") return Astro.redirect("/login", 302);
const entitlement = await (await import("../../lib/client.ts")).cachedEntitlement(env);
const hasPlus = atLeast(entitlement, "plus");
const { getTheme } = await import("../../core/theme.ts");
const theme = hasPlus ? await getTheme(Astro.locals.ctx) : {};
---
<App title="ブランド設定" active="/apps">
  <h1>ブランド設定（見た目）</h1>
  {!hasPlus && (
    <div class="card">
      <div class="banner banner-warn">この機能は <strong>Plus 以上</strong>のプランで利用できます。</div>
      <p class="muted">ブランド名・ロゴ・配色を団体ごとに上書きできます。</p>
      <a class="btn btn-primary" href="/billing">プラン・課金へ</a>
    </div>
  )}
  {hasPlus && (
    <Fragment>
      <p class="muted">ブランド名・ロゴ・配色を団体ごとに上書きします（共通の画面構造はそのまま）。空欄は既定値。色は #hex 等で指定。</p>
      <div class="card">
        <div class="field"><label>ブランド名<input id="th-brand" value={theme.brand ?? ""} placeholder="baku-office" /></label></div>
        <div class="field"><label>ロゴURL<input id="th-logo" value={theme.logoUrl ?? ""} placeholder="https://…/logo.png" /></label></div>
        <div class="field">
          <label>相棒（マスコット）画像URL<input id="th-mascot" value={theme.mascotUrl ?? ""} placeholder="空欄=既定（貘キャラ）／ https://…/your.png" /></label>
          <div class="muted" style="font-size:.8rem;margin-top:4px">空欄で合同会社 貘の既定キャラ。背景透過のPNG（正方形〜横長）推奨。自社キャラの画像URLを指定すると相棒が差し替わります。</div>
          <div class="row" style="align-items:center;gap:12px;margin-top:8px">
            <img id="th-mascot-prev" src={theme.mascotUrl || "/mascot/baku.png"} alt="相棒プレビュー" style="width:76px;height:76px;object-fit:contain;background:var(--surface-2);border:1px solid var(--line);border-radius:var(--r-sm)" />
            <button class="btn btn-sm" type="button" id="th-mascot-default" style="flex:0 0 auto">既定に戻す</button>
          </div>
        </div>
        <div class="row">
          <label style="flex:1">ブランド色<input id="th-brand-color" value={theme.colors?.brand ?? ""} placeholder="#C9A86A" /></label>
          <label style="flex:1">背景色<input id="th-bg" value={theme.colors?.bg ?? ""} placeholder="#EFE9DC" /></label>
          <label style="flex:1">文字色<input id="th-ink" value={theme.colors?.ink ?? ""} placeholder="#0E1A2B" /></label>
        </div>
        <button class="btn btn-primary" id="saveTheme">テーマを保存</button>
      </div>

      <script slot="scripts" is:inline>
        (function () {
          const btn = document.getElementById("saveTheme");
          if (!btn) return;
          const mascot = document.getElementById("th-mascot");
          const prev = document.getElementById("th-mascot-prev");
          mascot?.addEventListener("input", () => { if (prev) prev.src = mascot.value.trim() || "/mascot/baku.png"; });
          document.getElementById("th-mascot-default")?.addEventListener("click", () => { if (mascot) mascot.value = ""; if (prev) prev.src = "/mascot/baku.png"; });
          btn.addEventListener("click", async (e) => {
            const theme = { brand: document.getElementById("th-brand").value, logoUrl: document.getElementById("th-logo").value, mascotUrl: mascot ? mascot.value : "", colors: { brand: document.getElementById("th-brand-color").value, bg: document.getElementById("th-bg").value, ink: document.getElementById("th-ink").value } };
            const r = await window.bo.api("/api/settings", { _action: "ui_theme", theme }, { btn: e.currentTarget, successMsg: "テーマを保存しました" });
            if (r.ok) setTimeout(() => location.reload(), 700);
          });
        })();
      </script>
    </Fragment>
  )}
</App>
