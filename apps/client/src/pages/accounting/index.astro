---
import { env } from "cloudflare:workers";
export const prerender = false;
import App from "../../layouts/App.astro";
const acc = await import("../../lib/accounting.ts");
await acc.ensureSeed(env);
const period = await acc.currentPeriod(env);
const wallets = await acc.listWallets(env);
const categories = await acc.listCategories(env);
const selWallet = Astro.url.searchParams.get("wallet") ?? wallets[0]?.id ?? "";
const is = period ? await acc.incomeStatement(env, period.id) : null;
const book = period && selWallet ? await acc.cashbook(env, period.id, selWallet) : null;
const ba = period ? await acc.budgetActual(env, period.id) : [];
const balances = period ? await acc.walletBalances(env, period.id) : [];
const yen = (n: number) => "¥" + n.toLocaleString("ja-JP");
// 入力の初期値・表示は JST 基準。日付は日本語で添える（高齢ユーザーの誤読防止）。
const jstNow = new Date(Date.now() + 9 * 3600 * 1000);
const todayIso = jstNow.toISOString().slice(0, 10);
const jpToday = `${jstNow.getUTCFullYear()}年${jstNow.getUTCMonth() + 1}月${jstNow.getUTCDate()}日（${["日", "月", "火", "水", "木", "金", "土"][jstNow.getUTCDay()]}）`;
const KIND_JA: Record<string, string> = { income: "入金", expense: "出金", transfer: "振替" };
// 記帳方式（単式/複式）と複式用データ。複式は管理者が設定でON。
const { getSession } = await import("../../lib/auth.ts");
const ses = await getSession(env, Astro.request);
const isOrgAdmin = ses?.role === "admin" && ses?.ctx === "org";
const { getBookkeepingMode } = await import("../../lib/settings.ts");
const mode = await getBookkeepingMode(env);
const acctItems = await import("../../lib/account-items.ts");
const jr = await import("../../lib/journal.ts");
const accountItems = await acctItems.listAccountItems(env, { enabledOnly: true });
const trial = (mode === "double" && period) ? await jr.trialBalance(env, period.id) : [];
const entries = (mode === "double" && period) ? await jr.buildEntriesForPeriod(env, period.id) : [];
const trialDebit = trial.reduce((s, r) => s + r.debit, 0);
const trialCredit = trial.reduce((s, r) => s + r.credit, 0);
const SRC_JA: Record<string, string> = { tx: "出納帳", manual: "手動", depreciation: "減価償却", closure: "レジ締め" };
// 固定資産（管理者のみ）。各資産の償却スケジュールと計上済み回数を添える。
const fa = await import("../../lib/fixed-assets.ts");
const assets = isOrgAdmin ? await fa.listFixedAssets(env) : [];
const assetRows = await Promise.all(assets.map(async (a) => ({ a, sched: fa.depreciationSchedule(a), posted: await fa.depreciationCount(env, a.id) })));
// レジ締め（管理者のみ）。
const reg = await import("../../lib/register.ts");
const walletName = new Map(wallets.map((w) => [w.id, w.name]));
const CLOSURE_JA: Record<string, string> = { daily: "日次", monthly: "月次", year_end: "年度末" };
const closuresRaw = (isOrgAdmin && period) ? await reg.listClosures(env, period.id) : [];
const closureRows = closuresRaw.map((c) => {
  const diff = Number(c.difference);
  return {
    id: String(c.id),
    kindJa: CLOSURE_JA[String(c.kind)] ?? String(c.kind),
    label: String(c.period_label),
    wallet: walletName.get(String(c.wallet_id)) ?? "",
    expected: Number(c.expected_amount),
    counted: Number(c.counted_amount),
    diff,
    diffLabel: diff === 0 ? "一致" : (diff > 0 ? `不足 ${yen(diff)}` : `過剰 ${yen(-diff)}`),
    reason: c.ai_reason ? String(c.ai_reason) : (diff === 0 ? "—" : "（AIキー未設定）"),
    canAdjust: diff !== 0 && !c.adjustment_entry_id,
    adjusted: !!c.adjustment_entry_id,
  };
});
---
<App title="お金の記録" active="/accounting">
  <h1>お金の記録 <span class="muted" style="font-size:1rem;font-weight:600">{period?.name ?? "会計期なし"}</span></h1>

  {isOrgAdmin && (
    <div class="book-mode" role="group" aria-label="記帳方式">
      <span class="muted" style="font-size:.85rem">記帳方式：</span>
      <button class={"bm-opt" + (mode === "single" ? " on" : "")} data-mode="single" type="button">単式（かんたん）</button>
      <button class={"bm-opt" + (mode === "double" ? " on" : "")} data-mode="double" type="button">複式（仕訳）</button>
      <span class="muted" style="font-size:.8rem">複式にすると仕訳・試算表が使えます</span>
    </div>
  )}

  {/* 残高カード：開いた瞬間に「今いくらあるか」が見える（会計係の最大の不安に応える）。 */}
  <section class="bal-row" aria-label="口座の残高">
    {balances.map((w) => (
      <div class="bal-card">
        <div class="bal-name">{w.name}</div>
        <div class="bal-amt">{yen(w.balance)}</div>
      </div>
    ))}
    {balances.length === 0 && (<div class="muted">口座がまだありません。</div>)}
  </section>

  <h2>お金を記録する</h2>
  <div class="card">
    <div class="rec-modes" role="group" aria-label="記録の種類">
      <button type="button" class="rec-mode income" data-kind="income"><span class="rm-sign">＋</span>入金を記録<small>お金を受け取った</small></button>
      <button type="button" class="rec-mode expense" data-kind="expense"><span class="rm-sign">−</span>出金を記録<small>お金を支払った</small></button>
    </div>
    <div id="recForm" hidden style="margin-top:1rem">
      <p id="recLabel" class="rec-label"></p>
      <div class="row">
        <div style="flex:1">
          <label for="date">日付</label>
          <input id="date" type="date" value={todayIso} />
          <div class="muted" style="font-size:.85rem;margin-top:4px">今日：{jpToday}</div>
        </div>
        <div style="flex:1"><label for="wallet">口座</label><select id="wallet">{wallets.map((w)=>(<option value={w.id}>{w.name}</option>))}</select></div>
      </div>
      <div class="row" style="margin-top:.5rem">
        <div id="catBox" style="flex:1"><label for="cat">分類（科目）</label><select id="cat">{categories.map((c)=>(<option value={c.id} data-kind={c.kind}>{c.name}</option>))}</select></div>
        <div id="counterBox" style="flex:1;display:none"><label for="counter">振替先の口座</label><select id="counter">{wallets.map((w)=>(<option value={w.id}>{w.name}</option>))}</select></div>
        <div style="flex:1"><label for="amount">金額（円）</label><input id="amount" type="number" min="1" inputmode="numeric" placeholder="0" /></div>
      </div>
      <div class="field"><label for="desc">内容（メモ）</label><input id="desc" placeholder="例：6月分の会費" /></div>
      <div id="acctBox" class="row" style="align-items:flex-end">
        <div style="flex:2"><label for="acct">勘定科目（freee用・任意）</label><select id="acct"><option value="">（指定しない＝分類から自動）</option>{accountItems.map((a)=>(<option value={a.id} data-code={a.code}>{a.code} {a.name}</option>))}</select></div>
        <div style="flex:0 0 auto"><button class="btn" type="button" id="acctAi">AIでおすすめ</button></div>
      </div>
      <input type="hidden" id="kind" value="income" />
      <div class="row">
        <button class="btn btn-primary btn-lg" id="reg" style="flex:1">この内容で記録する</button>
        <button class="btn btn-ghost" id="recCancel" type="button" style="flex:0 0 auto">やめる</button>
      </div>
    </div>
    <details class="rec-transfer" style="margin-top:.7rem">
      <summary>口座間でお金を移したとき（振替）</summary>
      <p class="muted" style="font-size:.9rem;margin:.4rem 0 .6rem">現金を口座に預けた、口座から引き出した、などの「移動」を記録します。</p>
      <button type="button" class="btn" data-kind="transfer">口座間の移動を記録する</button>
    </details>
  </div>

  <h2>収支のまとめ <a class="btn btn-sm btn-ghost" href="/accounting/export.csv">Excel用に保存</a> <a class="btn btn-sm btn-ghost" href="/accounting/yayoi.csv">弥生会計へ書き出し</a></h2>
  {is && (
    <div class="grid">
      <div class="table-wrap"><table><thead><tr><th>収入の科目</th><th class="r">金額</th></tr></thead><tbody>
        {is.income.map((r)=>(<tr><td>{r.name}</td><td class="r">{yen(r.amount)}</td></tr>))}
        <tr><th>収入合計</th><th class="r">{yen(is.totalIncome)}</th></tr></tbody></table></div>
      <div class="table-wrap"><table><thead><tr><th>支出の科目</th><th class="r">金額</th></tr></thead><tbody>
        {is.expense.map((r)=>(<tr><td>{r.name}</td><td class="r">{yen(r.amount)}</td></tr>))}
        <tr><th>支出合計</th><th class="r">{yen(is.totalExpense)}</th></tr></tbody></table></div>
    </div>
  )}
  {is && (<p><strong>今期の収支：{yen(is.totalIncome - is.totalExpense)}</strong></p>)}

  {mode === "double" && (
    <Fragment>
      <h2>試算表 <a class="btn btn-sm btn-ghost" href="/accounting/yayoi.csv">弥生へ書き出し</a></h2>
      <div class="table-wrap"><table>
        <thead><tr><th>科目</th><th class="r">借方</th><th class="r">貸方</th><th class="r">残高</th></tr></thead>
        <tbody>
          {trial.map((r) => (<tr><td>{r.name}</td><td class="r">{r.debit ? yen(r.debit) : ""}</td><td class="r">{r.credit ? yen(r.credit) : ""}</td><td class="r">{yen(r.balance)}</td></tr>))}
          {trial.length === 0 && (<tr><td colspan="4" class="muted" style="text-align:center;padding:1rem">まだ仕訳がありません。</td></tr>)}
          <tr><th>合計</th><th class="r">{yen(trialDebit)}</th><th class="r">{yen(trialCredit)}</th><th class="r">{trialDebit === trialCredit ? "一致" : "不一致"}</th></tr>
        </tbody>
      </table></div>

      {isOrgAdmin && (
        <Fragment>
          <h2>仕訳を入力する</h2>
          <div class="card">
            <div class="row">
              <div style="flex:1"><label for="je-date">日付</label><input id="je-date" type="date" value={todayIso} /></div>
              <div style="flex:2"><label for="je-desc">摘要（メモ）</label><input id="je-desc" placeholder="例：備品購入" /></div>
            </div>
            <div class="row" style="margin-top:.5rem">
              <div style="flex:2"><label for="je-debit">借方科目</label><select id="je-debit">{accountItems.map((a) => (<option value={a.id}>{a.code} {a.name}</option>))}</select></div>
              <div style="flex:1"><label for="je-debit-amt">借方金額</label><input id="je-debit-amt" type="number" min="1" inputmode="numeric" placeholder="0" /></div>
            </div>
            <div class="row" style="margin-top:.5rem">
              <div style="flex:2"><label for="je-credit">貸方科目</label><select id="je-credit">{accountItems.map((a) => (<option value={a.id}>{a.code} {a.name}</option>))}</select></div>
              <div style="flex:1"><label for="je-credit-amt">貸方金額</label><input id="je-credit-amt" type="number" min="1" inputmode="numeric" placeholder="0" /></div>
            </div>
            <p class="muted" style="font-size:.82rem;margin:.5rem 0 0">借方と貸方の金額は一致させてください（複式のルール）。</p>
            <div class="row" style="margin-top:.6rem"><button class="btn btn-primary" id="je-add">この仕訳を登録</button></div>
          </div>
        </Fragment>
      )}

      <h2>仕訳帳</h2>
      <div class="table-wrap"><table>
        <thead><tr><th>日付</th><th>借方</th><th>貸方</th><th class="r">金額</th><th>摘要</th><th>種類</th><th></th></tr></thead>
        <tbody>
          {entries.map((e) => {
            const deb = e.lines.filter((l) => l.side === "debit");
            const cre = e.lines.filter((l) => l.side === "credit");
            const total = deb.reduce((s, l) => s + l.amount, 0);
            return (
              <tr>
                <td>{e.date}</td>
                <td>{deb.map((l) => l.name).join(" / ")}</td>
                <td>{cre.map((l) => l.name).join(" / ")}</td>
                <td class="r">{yen(total)}</td>
                <td>{e.description ?? ""}</td>
                <td><span class="muted" style="font-size:.82rem">{SRC_JA[e.source] ?? e.source}</span></td>
                <td>{isOrgAdmin && e.source !== "tx" && (<button class="btn btn-sm btn-danger je-del" data-del={e.id}>削除</button>)}</td>
              </tr>
            );
          })}
          {entries.length === 0 && (<tr><td colspan="7" class="muted" style="text-align:center;padding:1rem">まだ仕訳がありません。</td></tr>)}
        </tbody>
      </table></div>
    </Fragment>
  )}

  <h2>出納帳（お金の出入り）</h2>
  <div style="display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:.5rem">{wallets.map((w)=>(<a class={`btn btn-sm ${w.id===selWallet?"btn-primary":"btn-ghost"}`} href={`/accounting?wallet=${w.id}`}>{w.name}</a>))}</div>
  {book && (
    <div class="table-wrap"><table>
      <thead><tr><th>日付</th><th>種類</th><th>内容</th><th class="r">入金</th><th class="r">出金</th><th class="r">残高</th><th></th></tr></thead>
      <tbody>
        {book.rows.map((t)=>{const isIn=(t.kind==="income"&&t.wallet_id===selWallet)||(t.kind==="transfer"&&t.counter_wallet_id===selWallet);return (
          <tr><td>{t.date}</td><td>{KIND_JA[t.kind] ?? t.kind}</td><td>{t.description??""}</td><td class="r">{isIn?yen(t.amount):""}</td><td class="r">{!isIn?yen(t.amount):""}</td><td class="r">{yen(t.running)}</td><td><button class="btn btn-sm btn-danger del" data-del={t.id}>削除</button></td></tr>
        );})}
        {book.rows.length===0 && (<tr><td colspan="7" class="muted" style="text-align:center;padding:1.2rem">まだ記録がありません。上の「＋ 入金を記録」から最初の1件を登録してみましょう。</td></tr>)}
      </tbody></table></div>
  )}

  {isOrgAdmin && (
    <Fragment>
      <h2>レジ締め（現金の確認）</h2>
      <div class="card">
        <p class="muted" style="font-size:.9rem">手元の現金を数えて入力すると、帳簿上の想定額と照合します。ズレがあれば原因の見当をAIが補助します。</p>
        <div class="row">
          <div style="flex:1"><label for="cl-wallet">口座</label><select id="cl-wallet">{wallets.map((w) => (<option value={w.id}>{w.name}</option>))}</select></div>
          <div style="flex:1"><label for="cl-kind">締めの種類</label><select id="cl-kind"><option value="daily">日次（今日まで）</option><option value="monthly">月次（今月末まで）</option><option value="year_end">年度末（会計期末まで）</option></select></div>
          <div style="flex:1"><label for="cl-counted">実際に数えた金額（円）</label><input id="cl-counted" type="number" min="0" inputmode="numeric" placeholder="0" /></div>
        </div>
        <div class="row" style="margin-top:.6rem"><button class="btn btn-primary" id="cl-add">この内容で締める</button></div>
      </div>
      <div class="table-wrap"><table>
        <thead><tr><th>締め</th><th>対象</th><th>口座</th><th class="r">想定</th><th class="r">実査</th><th class="r">差異</th><th>原因の見当（AI）</th><th></th></tr></thead>
        <tbody>
          {closureRows.map((c) => (
            <tr>
              <td>{c.kindJa}</td>
              <td>{c.label}</td>
              <td>{c.wallet}</td>
              <td class="r">{yen(c.expected)}</td>
              <td class="r">{yen(c.counted)}</td>
              <td class={c.diff === 0 ? "r" : "r u-warn"}>{c.diffLabel}</td>
              <td style="font-size:.85rem">{c.reason}</td>
              <td>{c.canAdjust && (<button class="btn btn-sm cl-adj" data-id={c.id}>現金過不足で調整</button>)}{c.adjusted && (<span class="muted" style="font-size:.82rem">調整済</span>)}</td>
            </tr>
          ))}
          {closureRows.length === 0 && (<tr><td colspan="8" class="muted" style="text-align:center;padding:1rem">まだレジ締めの記録はありません。</td></tr>)}
        </tbody>
      </table></div>

      <h2>固定資産・減価償却</h2>
      <div class="card">
        <p class="muted" style="font-size:.9rem">パソコン・備品など長く使う資産を登録すると、毎期の減価償却費を仕訳として計上できます。</p>
        <div class="row">
          <div style="flex:2"><label for="fa-name">資産名</label><input id="fa-name" placeholder="例：ノートパソコン" /></div>
          <div style="flex:1"><label for="fa-date">取得日</label><input id="fa-date" type="date" value={todayIso} /></div>
        </div>
        <div class="row" style="margin-top:.5rem">
          <div style="flex:1"><label for="fa-cost">取得価額（円）</label><input id="fa-cost" type="number" min="1" inputmode="numeric" placeholder="0" /></div>
          <div style="flex:1"><label for="fa-life">耐用年数</label><input id="fa-life" type="number" min="1" inputmode="numeric" placeholder="例：4" /></div>
          <div style="flex:1"><label for="fa-method">償却方法</label><select id="fa-method"><option value="straight_line">定額法</option><option value="declining_balance">定率法</option></select></div>
          <div style="flex:1"><label for="fa-residual">残存価額（円）</label><input id="fa-residual" type="number" min="0" inputmode="numeric" value="0" /></div>
        </div>
        <div class="row" style="margin-top:.6rem"><button class="btn btn-primary" id="fa-add">資産を登録</button></div>
      </div>
      <div class="table-wrap"><table>
        <thead><tr><th>資産名</th><th>取得日</th><th class="r">取得価額</th><th>方法</th><th class="r">耐用</th><th class="r">初年度償却</th><th>計上</th><th></th></tr></thead>
        <tbody>
          {assetRows.map(({ a, sched, posted }) => (
            <tr>
              <td>{a.name}</td><td>{a.acquired_date}</td><td class="r">{yen(a.acquisition_cost)}</td>
              <td>{a.method === "declining_balance" ? "定率法" : "定額法"}</td><td class="r">{a.useful_life_years}年</td>
              <td class="r">{sched[0] ? yen(sched[0].amount) : "—"}</td>
              <td>{posted}/{a.useful_life_years}期</td>
              <td>
                <button class="btn btn-sm fa-dep" data-id={a.id} disabled={posted >= a.useful_life_years}>当期分を計上</button>
                <button class="btn btn-sm btn-danger fa-del" data-id={a.id}>削除</button>
              </td>
            </tr>
          ))}
          {assetRows.length === 0 && (<tr><td colspan="8" class="muted" style="text-align:center;padding:1rem">登録された固定資産はありません。</td></tr>)}
        </tbody>
      </table></div>
    </Fragment>
  )}

  <h2>予算と実績</h2>
  <div class="table-wrap"><table><thead><tr><th>科目</th><th class="r">予算</th><th class="r">実績</th><th class="r">差額</th></tr></thead><tbody>
    {ba.map((r)=>(<tr><td>{r.name}</td><td class="r">{yen(r.budget)}</td><td class="r">{yen(r.actual)}</td><td class="r">{yen(r.budget-r.actual)}</td></tr>))}
    {ba.length===0 && (<tr><td colspan="4" class="muted" style="text-align:center;padding:1rem">予算の設定はまだありません。</td></tr>)}
  </tbody></table></div>

  <style>
    .bal-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; margin: 1rem 0 .4rem; }
    .bal-card { background: var(--surface); border: 1px solid var(--line-strong); border-radius: var(--r-md); padding: 16px 18px; box-shadow: var(--shadow-sm); }
    .bal-name { color: var(--muted); font-size: .95rem; font-weight: 600; }
    .bal-amt { font-size: 1.7rem; font-weight: 800; letter-spacing: -.02em; margin-top: 2px; font-feature-settings: "tnum" 1; }
    .rec-modes { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .rec-mode { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; min-height: 76px; border: 2px solid var(--line-strong); border-radius: var(--r-md); background: var(--surface); color: var(--ink); font-size: 1.15rem; font-weight: 800; cursor: pointer; transition: transform .1s, border-color .15s, background .15s; }
    .rec-mode small { font-size: .8rem; font-weight: 500; color: var(--muted); }
    .rec-mode .rm-sign { font-size: 1.4rem; line-height: 1; }
    .rec-mode:hover { transform: translateY(-2px); }
    .rec-mode.income:hover, .rec-mode.income[aria-pressed="true"] { border-color: var(--ok); background: var(--ok-soft); }
    .rec-mode.expense:hover, .rec-mode.expense[aria-pressed="true"] { border-color: var(--danger); background: var(--danger-soft); }
    .rec-label { font-weight: 700; font-size: 1.05rem; margin: 0 0 .6rem; padding: .5rem .8rem; border-radius: var(--r-sm); background: var(--surface-2); }
    .rec-transfer { background: var(--surface-2); border: 1px dashed var(--line-strong); }
    .rec-transfer > summary { color: var(--muted); }
    @media (max-width: 420px) { .rec-mode { min-height: 68px; font-size: 1.05rem; } }
    .book-mode { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin: .2rem 0 1rem; }
    .bm-opt { min-height: 40px; padding: 0 .9rem; border: 1px solid var(--line-strong); background: var(--surface); color: var(--ink); border-radius: var(--r-pill); font-weight: 700; cursor: pointer; }
    .bm-opt.on { background: var(--brand); color: var(--on-brand); border-color: var(--brand-strong); }
    .u-warn { color: var(--warn); font-weight: 700; }
  </style>

  <script slot="scripts" is:inline>
    const recForm=document.getElementById("recForm"),kindEl=document.getElementById("kind"),catBox=document.getElementById("catBox"),counterBox=document.getElementById("counterBox"),recLabel=document.getElementById("recLabel"),acctBox=document.getElementById("acctBox");
    const LABELS={income:"＋ 入金を記録します",expense:"− 出金を記録します",transfer:"口座間の移動（振替）を記録します"};
    function openMode(k){
      kindEl.value=k;recLabel.textContent=LABELS[k]||"";recForm.hidden=false;
      catBox.style.display=k==="transfer"?"none":"";counterBox.style.display=k==="transfer"?"":"none";
      if(acctBox)acctBox.style.display=k==="transfer"?"none":"flex";
      for(const o of document.querySelectorAll("#cat option")){const kk=o.dataset.kind;o.hidden=(k==="income"&&kk!=="income")||(k==="expense"&&kk!=="expense");}
      const v=[...document.querySelectorAll("#cat option")].find(o=>!o.hidden);if(v)v.selected=true;
      document.querySelectorAll(".rec-mode").forEach(b=>b.setAttribute("aria-pressed",String(b.dataset.kind===k)));
      recForm.scrollIntoView({behavior:"smooth",block:"nearest"});
      const amt=document.getElementById("amount");if(amt)setTimeout(()=>amt.focus(),200);
    }
    document.querySelectorAll("[data-kind]").forEach(b=>b.addEventListener("click",()=>openMode(b.dataset.kind)));
    document.getElementById("recCancel").addEventListener("click",()=>{recForm.hidden=true;document.querySelectorAll(".rec-mode").forEach(b=>b.setAttribute("aria-pressed","false"));});
    // AIで勘定科目をおすすめ（経費の科目推定・Plus以上）。
    document.getElementById("acctAi")?.addEventListener("click",async(e)=>{
      const body={vendor:document.getElementById("desc").value,description:document.getElementById("desc").value,amount:Number(document.getElementById("amount").value)||undefined};
      const r=await window.bo.api("/api/accounting/suggest-account",body,{btn:e.currentTarget,successMsg:null});
      if(r.ok&&r.suggestion){document.getElementById("acct").value=r.suggestion.id;window.bo.toast("おすすめ："+r.suggestion.name+(r.suggestion.reason?"（"+r.suggestion.reason+"）":""),"ok");}
      else if(r.ok){window.bo.toast("おすすめ科目が見つかりませんでした。手動で選んでください","info");}
    });
    document.getElementById("reg").addEventListener("click",async(e)=>{
      const body={date:document.getElementById("date").value,kind:kindEl.value,wallet_id:document.getElementById("wallet").value,category_id:document.getElementById("cat").value,counter_wallet_id:document.getElementById("counter").value,amount:document.getElementById("amount").value,description:document.getElementById("desc").value,account_item_id:document.getElementById("acct").value};
      if(!body.date){window.bo.toast("日付を入力してください","err");return;}
      if(!(Number(body.amount)>0)){window.bo.toast("金額は1以上で入力してください","err");return;}
      if(!body.wallet_id){window.bo.toast("口座を選択してください","err");return;}
      if(body.kind==="transfer"&&body.wallet_id===body.counter_wallet_id){window.bo.toast("振替元と振替先が同じ口座です","err");return;}
      const r=await window.bo.api("/api/tx",body,{btn:e.currentTarget,successMsg:"記録しました"});
      if(r.ok)setTimeout(()=>location.reload(),600);
    });
    document.querySelectorAll(".del[data-del]").forEach(b=>b.addEventListener("click",async(e)=>{
      if(!(await window.bo.confirm("この記録を消します。よろしいですか？",{confirmLabel:"削除",danger:true,auditHref:"/diagnostics"})))return;
      const r=await window.bo.api("/api/tx",{_action:"delete",id:e.target.dataset.del},{btn:e.target,successMsg:"削除しました"});
      if(r.ok)setTimeout(()=>location.reload(),500);
    }));
    // 記帳方式の切替（管理者）。
    document.querySelectorAll(".bm-opt").forEach(b=>b.addEventListener("click",async()=>{
      const r=await window.bo.api("/api/settings",{_action:"bookkeeping_mode",mode:b.dataset.mode},{successMsg:"記帳方式を変更しました"});
      if(r.ok)setTimeout(()=>location.reload(),500);
    }));
    // 手動仕訳の登録（複式・管理者）。
    document.getElementById("je-add")?.addEventListener("click",async(e)=>{
      const date=document.getElementById("je-date").value,desc=document.getElementById("je-desc").value;
      const dAcc=document.getElementById("je-debit").value,dAmt=Number(document.getElementById("je-debit-amt").value);
      const cAcc=document.getElementById("je-credit").value,cAmt=Number(document.getElementById("je-credit-amt").value);
      if(!date){window.bo.toast("日付を入力してください","err");return;}
      if(!(dAmt>0)||!(cAmt>0)){window.bo.toast("借方・貸方の金額を入力してください","err");return;}
      if(dAmt!==cAmt){window.bo.toast("借方と貸方の金額を一致させてください","err");return;}
      const body={date,description:desc,lines:[{side:"debit",account_item_id:dAcc,amount:dAmt},{side:"credit",account_item_id:cAcc,amount:cAmt}]};
      const r=await window.bo.api("/api/accounting/journal",body,{btn:e.currentTarget,successMsg:"仕訳を登録しました"});
      if(r.ok)setTimeout(()=>location.reload(),600);
    });
    document.querySelectorAll(".je-del[data-del]").forEach(b=>b.addEventListener("click",async(e)=>{
      if(!(await window.bo.confirm("この仕訳を消します。よろしいですか？",{confirmLabel:"削除",danger:true})))return;
      const r=await window.bo.api("/api/accounting/journal",{_action:"delete",id:e.target.dataset.del},{btn:e.target,successMsg:"削除しました"});
      if(r.ok)setTimeout(()=>location.reload(),500);
    }));
    // レジ締め（管理者）。差異があればAI推定が表示される。
    document.getElementById("cl-add")?.addEventListener("click",async(e)=>{
      const body={wallet_id:document.getElementById("cl-wallet").value,kind:document.getElementById("cl-kind").value,counted_amount:Number(document.getElementById("cl-counted").value)};
      if(!(body.counted_amount>=0)){window.bo.toast("数えた金額を入力してください","err");return;}
      const r=await window.bo.api("/api/accounting/closure",body,{btn:e.currentTarget,successMsg:null});
      if(r.ok){const msg=r.difference===0?"ぴったり一致しました":((r.difference>0?"不足":"過剰")+" "+Math.abs(r.difference).toLocaleString()+"円");window.bo.toast("締めました："+msg,r.difference===0?"ok":"info");setTimeout(()=>location.reload(),900);}
    });
    document.querySelectorAll(".cl-adj[data-id]").forEach(b=>b.addEventListener("click",async(e)=>{
      if(!(await window.bo.confirm("差異を現金過不足で調整する仕訳を作成します。よろしいですか？",{confirmLabel:"調整する"})))return;
      const r=await window.bo.api("/api/accounting/closure",{_action:"adjust",id:e.target.dataset.id},{btn:e.target,successMsg:"調整しました"});
      if(r.ok)setTimeout(()=>location.reload(),600);
    }));
    // 固定資産の登録・減価償却の計上・削除（管理者）。
    document.getElementById("fa-add")?.addEventListener("click",async(e)=>{
      const body={name:document.getElementById("fa-name").value,acquired_date:document.getElementById("fa-date").value,acquisition_cost:Number(document.getElementById("fa-cost").value),useful_life_years:Number(document.getElementById("fa-life").value),method:document.getElementById("fa-method").value,residual_value:Number(document.getElementById("fa-residual").value)||0};
      if(!body.name){window.bo.toast("資産名を入力してください","err");return;}
      if(!(body.acquisition_cost>0)||!(body.useful_life_years>0)){window.bo.toast("取得価額と耐用年数を入力してください","err");return;}
      const r=await window.bo.api("/api/accounting/asset",body,{btn:e.currentTarget,successMsg:"固定資産を登録しました"});
      if(r.ok)setTimeout(()=>location.reload(),600);
    });
    document.querySelectorAll(".fa-dep[data-id]").forEach(b=>b.addEventListener("click",async(e)=>{
      const r=await window.bo.api("/api/accounting/asset",{_action:"depreciate",id:e.target.dataset.id},{btn:e.target,successMsg:"当期分の減価償却を計上しました"});
      if(r.ok)setTimeout(()=>location.reload(),600);
    }));
    document.querySelectorAll(".fa-del[data-id]").forEach(b=>b.addEventListener("click",async(e)=>{
      if(!(await window.bo.confirm("この固定資産を削除しますか？",{confirmLabel:"削除",danger:true})))return;
      const r=await window.bo.api("/api/accounting/asset",{_action:"delete",id:e.target.dataset.id},{btn:e.target,successMsg:"削除しました"});
      if(r.ok)setTimeout(()=>location.reload(),500);
    }));
  </script>
</App>
