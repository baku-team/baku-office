---
export const prerender = false;
import App from "../layouts/App.astro";
const env = Astro.locals.runtime.env;
const { getSession } = await import("../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses) return Astro.redirect("/login", 302);
const { results } = await env.DB.prepare("SELECT id,title,body,created_at FROM knowledge WHERE tags='議事録' AND deleted_at IS NULL ORDER BY created_at DESC").all<{ id: string; title: string; body: string | null; created_at: number }>();
const d = (s: number) => new Date(s * 1000).toISOString().slice(0, 10);
---
<App title="議事録" active="/minutes">
  <h1>議事録</h1>
  <div class="card">
    <div class="field"><input id="title" placeholder="タイトル（例：6月定例会）" /></div>
    <div class="field"><textarea id="body" rows="4" placeholder="本文・決定事項"></textarea></div>
    <button class="btn btn-primary" id="add">保存</button>
  </div>
  <div style="margin-top:1rem">
    {results.map((r)=>(<div class="card" data-id={r.id} style="margin-bottom:.6rem"><div style="display:flex;justify-content:space-between"><strong>{r.title}</strong><button class="btn btn-sm btn-danger del">削除</button></div><div class="muted">{d(r.created_at)}</div><p style="white-space:pre-wrap">{r.body}</p></div>))}
    {results.length===0 && (<p class="muted">議事録がありません。</p>)}
  </div>
  <script slot="scripts" is:inline>
    const P=(b,btn)=>window.bo.api("/api/docs",{kind:"minutes",...b},{btn});
    document.getElementById("add").addEventListener("click",async(e)=>{const t=document.getElementById("title").value;if(!t){window.bo.toast("タイトルを入力","err");return;}const r=await P({title:t,body:document.getElementById("body").value},e.currentTarget);if(r.ok)setTimeout(()=>location.reload(),500);});
    document.querySelectorAll("[data-id] .del").forEach(b=>b.addEventListener("click",async(e)=>{if(!(await window.bo.confirm("この議事録を削除しますか？",{confirmLabel:"削除",danger:true,irreversible:true})))return;const r=await P({_action:"delete",id:e.target.closest("[data-id]").dataset.id},e.target);if(r.ok)setTimeout(()=>location.reload(),400);}));
  </script>
</App>
