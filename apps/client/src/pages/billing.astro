---
export const prerender = false;
const env = Astro.locals.runtime.env;
const { getSession } = await import("../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses || ses.role !== "admin" || ses.ctx !== "org") return Astro.redirect("/login", 302);

const { pollHost, cachedEntitlement, getLicenseId } = await import("../lib/client.ts");
const check = await pollHost(env, Astro.url.origin);
const entitlement = check?.entitlement ?? (await cachedEntitlement(env));
const licenseId = await getLicenseId(env);
const hostBase = env.HOST_BASE_URL.replace(/\/$/, "");
const label = (e: string) => (e === "Z" ? "Z（エージェント）" : e === "Y" ? "Y（AI）" : "X（無料）");
---
<!doctype html>
<html lang="ja"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>プラン・課金 — baku-office</title>
<style>body{font-family:system-ui,sans-serif;max-width:680px;margin:0 auto;color:#1c2530}header{background:#0f172a;color:#fff;padding:.8rem 1.25rem}header a{color:#cbd5e1;text-decoration:none;margin-right:1rem;font-size:.9rem}main{padding:1.25rem}.card{border:1px solid #e2e8f0;border-radius:12px;padding:1rem 1.25rem;margin:1rem 0}button{padding:.6rem 1.2rem;background:#2563eb;color:#fff;border:0;border-radius:8px;cursor:pointer}.muted{color:#64748b;font-size:.9rem}.cur{background:#ecfeff;color:#0e7490;padding:.15rem .6rem;border-radius:999px}</style></head>
<body>
<header><a href="/">ホーム</a><a href="/billing">プラン・課金</a></header>
<main>
<h1>プラン・課金</h1>
<div class="card">現在のプラン：<span class="cur">{label(entitlement)}</span>
  <p class="muted">入金が確認・継続している間のみ有料機能が有効（プロビジョナル §2.3）。無料(X)は常に利用可。データはロックも削除もしません。</p>
</div>
<div class="card">
  <h3>アップグレード</h3>
  <p class="muted">カードは即時、銀行振込・コンビニは入金確認後に反映（§2.4）。</p>
  <button class="up" data-plan="Y" disabled={entitlement==="Y"||entitlement==="Z"}>Y（AI・Gemini）にする</button>
  <button class="up" data-plan="Z" disabled={entitlement==="Z"}>Z（エージェント）にする</button>
  <p id="msg" class="muted"></p>
</div>
<script type="module" define:vars={{ licenseId, hostBase }}>
  const msg=document.getElementById("msg");
  document.querySelectorAll(".up").forEach(b=>b.onclick=async()=>{
    const plan=b.dataset.plan; msg.textContent="決済へ移動中…";
    const r=await fetch("/api/billing/start",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify({plan})});
    const j=await r.json();
    if(!j.ok){msg.textContent="エラー："+(j.error||"");return;}
    if(j.mode==="stripe"){location.href=j.url;return;}
    // dev：host の入金シミュレートへ（ブラウザ遷移）。
    location.href=`${hostBase}/api/billing/dev-confirm?license_id=${encodeURIComponent(licenseId)}&plan=${plan}&return=${encodeURIComponent(location.origin+"/billing")}`;
  });
</script>
</main></body></html>
