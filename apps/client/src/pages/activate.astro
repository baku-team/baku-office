---
export const prerender = false;
import App from "../layouts/App.astro";
const env = Astro.locals.runtime.env;
const url = Astro.url;
const origin = url.origin;
const host = env.HOST_BASE_URL.replace(/\/$/, "");
const licenseId = url.searchParams.get("license_id");
const code = url.searchParams.get("code");
let message = "";
if (licenseId && !code) {
  return Astro.redirect(`${host}/api/activate?license_id=${encodeURIComponent(licenseId)}&callback=${encodeURIComponent(origin + "/activate")}`, 302);
}
if (code) {
  const { hostFetch, saveToken } = await import("../lib/client.ts");
  const r = await hostFetch(env, "/api/token", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ code, deployUrl: origin }) });
  const j = (await r.json().catch(() => ({}))) as { ok?: boolean; token?: string; error?: string };
  if (j.ok && j.token) { await saveToken(env, j.token); return Astro.redirect("/", 302); }
  message = "アクティベーションに失敗しました：" + (j.error ?? "不明なエラー");
}
---
<App title="アクティベーション" auth={false}>
  <h1 style="margin-top:1rem">baku-office をアクティベート</h1>
  {message
    ? <div class="banner banner-danger">{message}</div>
    : <p>この団体のアプリはまだライセンスを取得していません。当社から案内された<strong>アクティベーションURL（?license_id=…付き）</strong>を開いてください。</p>}
  <p class="muted">（Phase1：Googleログインは省略。本番は申込時のGoogleアカウントで認証＝§4）</p>
</App>
