---
export const prerender = false;
const env = Astro.locals.runtime.env;
const { getSession } = await import("../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses) return Astro.redirect("/login", 302);
const { results } = await env.DB.prepare("SELECT id,title,start_at,end_at,body FROM schedules WHERE deleted_at IS NULL ORDER BY start_at").all<{ id: string; title: string; start_at: string; end_at: string | null; body: string | null }>();
---
<!doctype html>
<html lang="ja"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>予定 — baku-office</title>
<style>body{font-family:system-ui,sans-serif;max-width:760px;margin:0 auto;color:#1c2530}header{background:#0f172a;color:#fff;padding:.8rem 1.25rem}header a{color:#cbd5e1;text-decoration:none;margin-right:1rem;font-size:.9rem}main{padding:1.25rem}input,textarea{padding:.4rem;border:1px solid #cbd5e1;border-radius:6px;margin:.2rem 0}button{padding:.35rem .7rem;border:0;border-radius:6px;cursor:pointer}table{border-collapse:collapse;width:100%;font-size:.9rem;margin-top:1rem}th,td{border:1px solid #e2e8f0;padding:.4rem .6rem}th{background:#f8fafc}.muted{color:#64748b}</style></head>
<body>
<header><a href="/">ホーム</a><a href="/files">ファイル</a><a href="/schedule">予定</a><a href="/minutes">議事録</a></header>
<main>
<h1>予定</h1>
<div><input id="title" placeholder="件名" /> <input id="start" type="datetime-local" /> <input id="end" type="datetime-local" /> <button id="add" style="background:#2563eb;color:#fff">追加</button></div>
<table><thead><tr><th>開始</th><th>件名</th><th></th></tr></thead><tbody>
  {results.map((s)=>(<tr data-id={s.id}><td>{s.start_at.replace("T"," ")}</td><td>{s.title}</td><td><button class="del" style="background:#ef4444;color:#fff">削除</button></td></tr>))}
  {results.length===0 && (<tr><td colspan="3" class="muted">予定がありません。</td></tr>)}
</tbody></table>
<script type="module">
  const post=(b)=>fetch("/api/docs",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify({kind:"schedule",...b})}).then(r=>r.json());
  document.getElementById("add").onclick=async()=>{await post({title:document.getElementById("title").value,start_at:document.getElementById("start").value,end_at:document.getElementById("end").value});location.reload();};
  document.querySelectorAll("tr[data-id] .del").forEach(b=>b.onclick=async()=>{await post({_action:"delete",id:b.closest("tr").dataset.id});location.reload();});
</script>
</main></body></html>
