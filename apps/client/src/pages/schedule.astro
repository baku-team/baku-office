---
export const prerender = false;
import App from "../layouts/App.astro";
const env = Astro.locals.runtime.env;
const { getSession } = await import("../lib/auth.ts");
const ses = await getSession(env, Astro.request);
if (!ses) return Astro.redirect("/login", 302);
const { results } = await env.DB.prepare("SELECT id,title,start_at FROM schedules WHERE deleted_at IS NULL ORDER BY start_at").all<{ id: string; title: string; start_at: string }>();
---
<App title="予定" active="/schedule">
  <h1>予定</h1>
  <div class="card">
    <div class="row">
      <input id="title" placeholder="件名" />
      <input id="start" type="datetime-local" />
      <button class="btn btn-primary" id="add" style="flex:0 0 auto">追加</button>
    </div>
  </div>
  <div class="table-wrap" style="margin-top:1rem"><table><thead><tr><th>開始</th><th>件名</th><th></th></tr></thead><tbody>
    {results.map((s)=>(<tr data-id={s.id}><td>{s.start_at.replace("T"," ")}</td><td>{s.title}</td><td><button class="btn btn-sm btn-danger del">削除</button></td></tr>))}
    {results.length===0 && (<tr><td colspan="3" class="muted">予定がありません。</td></tr>)}
  </tbody></table></div>
  <script slot="scripts" is:inline>
    const P=(b,btn)=>window.bo.api("/api/docs",{kind:"schedule",...b},{btn});
    document.getElementById("add").addEventListener("click",async(e)=>{const t=document.getElementById("title").value,s=document.getElementById("start").value;if(!t||!s){window.bo.toast("件名と開始日時を入力","err");return;}const r=await P({title:t,start_at:s},e.currentTarget);if(r.ok)setTimeout(()=>location.reload(),500);});
    document.querySelectorAll("tr[data-id] .del").forEach(b=>b.addEventListener("click",async(e)=>{if(!(await window.bo.confirm("この予定を削除しますか？",{confirmLabel:"削除",danger:true,irreversible:true})))return;const r=await P({_action:"delete",id:e.target.closest("tr").dataset.id},e.target);if(r.ok)setTimeout(()=>location.reload(),400);}));
  </script>
</App>
