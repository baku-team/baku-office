---
export const prerender = false;
import Host from "../layouts/Host.astro";
const env = Astro.locals.runtime.env;
const { getHostSession } = await import("../lib/hostauth.ts");
const ses = await getHostSession(env, Astro.request);
if (!ses?.isAdmin) return Astro.redirect("/login", 302);
type Row = { license_id: string; org_name: string; plan: string; entitlement: string; status: string; version: string | null; last_seen: number | null };
const { results } = await env.DB.prepare(
  `SELECT l.license_id, c.org_name, l.plan, l.entitlement, l.status, l.version, l.last_seen
   FROM licenses l JOIN customers c ON c.id = l.customer_id ORDER BY l.created_at DESC LIMIT 200`,
).all<Row>();
const fmt = (s: number | null) => (s ? new Date(s * 1000).toISOString().slice(0, 16).replace("T", " ") : "—");
---
<Host title="クライアント管理" active="/clients">
  <h1>クライアント管理</h1>
  <div class="table-wrap"><table>
    <thead><tr><th>団体</th><th>プラン</th><th>エンタイトルメント</th><th>状態</th><th>稼働ver</th><th>最終受信</th><th>ライセンスID</th></tr></thead>
    <tbody>
      {results.map((r) => (<tr><td>{r.org_name}</td><td>{r.plan}</td><td><span class="pill">{r.entitlement}</span></td><td>{r.status}</td><td>{r.version ?? "—"}</td><td>{fmt(r.last_seen)}</td><td><code style="font-size:.8rem">{r.license_id}</code></td></tr>))}
      {results.length === 0 && (<tr><td colspan="7" class="muted">まだ申込がありません。</td></tr>)}
    </tbody>
  </table></div>
</Host>
