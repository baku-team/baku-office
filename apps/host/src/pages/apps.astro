---
export const prerender = false;
import Host from "../layouts/Host.astro";
const env = Astro.locals.runtime.env;
const { getHostSession } = await import("../lib/hostauth.ts");
const ses = await getHostSession(env, Astro.request);
if (!ses?.isAdmin) return Astro.redirect("/login", 302);

const { listApps, usageByApp, appStoreMeta, builtinPolicy, BUILTIN_APP_IDS } = await import("../lib/registry.ts");
const apps = await listApps(env);
const usage = await usageByApp(env);
const storeMeta = await appStoreMeta(env);
const policy = await builtinPolicy(env);
// 撤去墓標（未登録アプリの停止/削除状態の表示・復帰用）。
const revRows = (await env.DB.prepare("SELECT app_id,kind FROM app_revocations").all<{ app_id: string; kind: string }>()).results;
const revMap = new Map(revRows.map((r) => [r.app_id, r.kind]));
const usageMap = new Map(usage.map((u) => [u.app_id, u]));
const builtin = new Set(BUILTIN_APP_IDS);
// 本当に未知＝レジストリ未登録かつ標準同梱でもないアプリ（要確認）。
const unregistered = usage.filter((u) => !builtin.has(u.app_id) && !apps.some((a) => a.id === u.app_id));
---
<Host title="アプリ管理" active="/apps">
  <h1>アプリ管理（中枢レジストリ）</h1>
  <p class="muted">各リポで作成されたアプリの<strong>存在（レジストリ）</strong>と、<strong>利用状況</strong>（どのクライアントがどの版を使っているか・PIIなし）を中枢で管理します。</p>

  <h2>レジストリ（公開アプリ）</h2>
  <div class="table-wrap"><table><thead><tr><th>ID</th><th>名称</th><th>版</th><th>状態</th><th>ストア</th><th>最低プラン</th><th>DL数</th><th>★平均(件)</th><th>導入(有効)</th><th>操作</th></tr></thead><tbody>
    {apps.map((a) => { const u = usageMap.get(a.id); const m = storeMeta[a.id]; return (
      <tr data-id={a.id}>
        <td><code>{a.id}</code></td><td>{a.name}</td><td>{a.version}</td>
        <td><span class="pill" style={a.status === "approved" ? "background:#dcfce7;color:#166534" : a.status === "blocked" ? "background:#fee2e2;color:#b91c1c" : ""}>{a.status}</span></td>
        <td>{m?.listed ? "掲載中" : "非掲載"}</td>
        <td>{m?.min_entitlement ?? "free"}</td>
        <td>{m?.downloads ?? 0}</td>
        <td>{m?.reviews ? `${m.avg}(${m.reviews})` : "—"}</td>
        <td>{u ? `${u.installs}(${u.active})` : 0}</td>
        <td style="white-space:nowrap">
          <button class="btn btn-ghost st" data-st="approved">承認</button>
          <button class="btn btn-ghost st" data-st="blocked">公開停止</button>
          <button class="btn btn-ghost lst" data-lst={m?.listed ? "0" : "1"}>{m?.listed ? "掲載OFF" : "掲載ON"}</button>
          <button class="btn btn-danger del">削除</button>
        </td>
      </tr>); })}
    {apps.length === 0 && (<tr><td colspan="10" class="muted">レジストリは空です。下のフォームから登録してください。</td></tr>)}
  </tbody></table></div>

  <h2>標準同梱アプリ（登録／除外）</h2>
  <p class="muted">全クライアントに同梱される標準アプリ。<strong>除外</strong>すると次回の統合チェックで全クライアントの導入集合から外れます。<strong>登録</strong>で再び有効化。必須アプリ（AIチャット）は除外できません。</p>
  <div class="table-wrap"><table><thead><tr><th>ID</th><th>名称</th><th>状態</th><th>導入数(有効)</th><th>操作</th></tr></thead><tbody>
    {policy.map((p) => { const u = usageMap.get(p.id); return (
      <tr data-bid={p.id}>
        <td><code>{p.id}</code></td><td>{p.label}{p.mandatory && <span class="muted">（必須）</span>}</td>
        <td><span class="pill" style={p.enabled ? "background:#dcfce7;color:#166534" : "background:#fee2e2;color:#b91c1c"}>{p.enabled ? "登録（有効）" : "除外"}</span></td>
        <td>{u ? `${u.installs}(${u.active})` : 0}</td>
        <td>{p.mandatory ? <span class="muted">—</span> : (
          p.enabled
            ? <button class="btn btn-ghost b-set" data-en="0">除外する</button>
            : <button class="btn btn-primary b-set" data-en="1">登録する</button>
        )}</td>
      </tr>); })}
  </tbody></table></div>

  {unregistered.length > 0 && (
    <>
      <h2>未登録で稼働中のアプリ（要確認）</h2>
      <div class="banner banner-warn">レジストリ未登録だが利用申告のあるアプリ。各リポを確認し、登録／公開停止／削除を判断してください。停止・削除は全クライアントに反映されます。</div>
      <div class="table-wrap"><table><thead><tr><th>ID</th><th>導入数(有効)</th><th>版</th><th>状態</th><th>操作</th></tr></thead><tbody>
        {unregistered.map((u) => { const rk = revMap.get(u.app_id); return (
          <tr data-uid={u.app_id} data-ver={u.versions?.split(",")[0] ?? ""}>
            <td><code>{u.app_id}</code></td><td>{u.installs}({u.active})</td><td class="muted">{u.versions}</td>
            <td>{rk ? <span class="pill" style="background:#fee2e2;color:#b91c1c">{rk === "deleted" ? "削除済" : "停止中"}</span> : <span class="muted">稼働中</span>}</td>
            <td style="white-space:nowrap">
              <button class="btn btn-ghost u-reg">登録</button>
              {rk ? <button class="btn btn-ghost u-unrev">復帰</button> : <button class="btn btn-ghost u-rev" data-kind="blocked">公開停止</button>}
              <button class="btn btn-danger u-del">削除</button>
            </td>
          </tr>); })}
      </tbody></table></div>
    </>
  )}

  <h2>アプリを登録（各リポの公開時）</h2>
  <div class="card">
    <div class="row"><label style="flex:1">ID<input id="r-id" placeholder="inventory" /></label><label style="flex:1">名称<input id="r-name" placeholder="在庫" /></label><label style="flex:0 0 120px">版<input id="r-version" placeholder="1.0.0" /></label></div>
    <div class="row"><label style="flex:1">リポURL<input id="r-repo" placeholder="https://github.com/…" /></label><label style="flex:1">公開者<input id="r-pub" /></label><label style="flex:0 0 140px">分類<input id="r-cat" /></label></div>
    <div class="field"><label>権限（カンマ区切り）<input id="r-perms" placeholder="db:read, db:write" /></label></div>
    <div class="field"><label>説明<input id="r-desc" /></label></div>
    <button class="btn btn-primary" id="reg">レジストリに登録</button>
  </div>

  <script slot="scripts" is:inline>
    // 共通基盤（window.bo.api）に統一：エラー/成功トースト・処理中表示を他のホスト画面と揃える。
    const api = (body, btn, successMsg) => window.bo.api("/api/registry", body, { btn, successMsg });
    document.querySelectorAll("tr[data-id]").forEach((tr) => {
      const id = tr.getAttribute("data-id");
      tr.querySelectorAll(".st").forEach((b) => b.addEventListener("click", async (e) => { const st = e.currentTarget.dataset.st; if (st === "blocked" && !confirm("このアプリを公開停止し、導入済みクライアントからも無効化（キルスイッチ）しますか？")) return; const r = await api({ _action: "status", id, status: st }, e.currentTarget, st === "approved" ? "承認しました" : "公開停止しました"); if (r.ok) location.reload(); }));
      tr.querySelector(".lst")?.addEventListener("click", async (e) => { const r = await api({ _action: "set_listed", id, listed: e.currentTarget.dataset.lst === "1" }, e.currentTarget, "更新しました"); if (r.ok) location.reload(); });
      tr.querySelector(".del")?.addEventListener("click", async (e) => { if (!confirm("このアプリを削除し、全クライアントから撤去します。利用が0なら登録自体も完全削除されます。よろしいですか？")) return; const r = await api({ _action: "delete", id }, e.currentTarget, "削除しました"); if (r.ok) location.reload(); });
    });
    // 標準同梱アプリ（登録／除外）。
    document.querySelectorAll("tr[data-bid]").forEach((tr) => {
      const id = tr.getAttribute("data-bid");
      tr.querySelector(".b-set")?.addEventListener("click", async (e) => { const en = e.currentTarget.dataset.en === "1"; if (!en && !confirm("この標準同梱アプリを全クライアントの導入集合から除外します。よろしいですか？")) return; const r = await api({ _action: "builtin_set", id, enabled: en }, e.currentTarget, en ? "登録しました" : "除外しました"); if (r.ok) location.reload(); });
    });
    // 未登録で稼働中のアプリ（登録／公開停止／復帰／削除）。
    document.querySelectorAll("tr[data-uid]").forEach((tr) => {
      const id = tr.getAttribute("data-uid");
      const ver = tr.getAttribute("data-ver") || "0.0.0";
      tr.querySelector(".u-reg")?.addEventListener("click", async (e) => { const name = prompt("レジストリに登録します。アプリ名称を入力してください。", id) || id; const r = await api({ _action: "register", id, name, version: ver }, e.currentTarget, "登録しました（pending）"); if (r.ok) location.reload(); });
      tr.querySelector(".u-rev")?.addEventListener("click", async (e) => { if (!confirm("このアプリを公開停止し、全クライアントから無効化します。よろしいですか？")) return; const r = await api({ _action: "revoke", id, kind: "blocked" }, e.currentTarget, "公開停止しました"); if (r.ok) location.reload(); });
      tr.querySelector(".u-unrev")?.addEventListener("click", async (e) => { const r = await api({ _action: "unrevoke", id }, e.currentTarget, "復帰しました"); if (r.ok) location.reload(); });
      tr.querySelector(".u-del")?.addEventListener("click", async (e) => { if (!confirm("このアプリを削除し、全クライアントから撤去します。よろしいですか？")) return; const r = await api({ _action: "revoke", id, kind: "deleted" }, e.currentTarget, "削除しました"); if (r.ok) location.reload(); });
    });
    document.getElementById("reg").addEventListener("click", async (e) => {
      const perms = (document.getElementById("r-perms").value || "").split(",").map((s) => s.trim()).filter(Boolean);
      const body = { _action: "register", id: document.getElementById("r-id").value, name: document.getElementById("r-name").value, version: document.getElementById("r-version").value, repoUrl: document.getElementById("r-repo").value, publisher: document.getElementById("r-pub").value, category: document.getElementById("r-cat").value, permissions: perms, description: document.getElementById("r-desc").value };
      if (!body.id || !body.name || !body.version) { window.bo.toast("ID・名称・版は必須です", "err"); return; }
      const r = await api(body, e.currentTarget, "登録しました"); if (r.ok) location.reload();
    });
  </script>
</Host>
