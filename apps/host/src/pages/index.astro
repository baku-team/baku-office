---
export const prerender = false;
import Host from "../layouts/Host.astro";
const env = Astro.locals.runtime.env;
let count = 0;
try { count = (await env.DB.prepare("SELECT COUNT(*) AS n FROM licenses").first<{ n: number }>())?.n ?? 0; } catch { /* 未マイグレ */ }
const applyUrl = env.APPLY_URL ?? "";
---
<Host title="ポータル" active="/">
  <h1>ホストポータル</h1>
  <p class="muted">当社（ホスト）の管理ポータル。業務データ・会員PIIは保持しません（§7.3）。申込は<strong>申込専用Worker</strong>に分離されています。</p>
  <div class="grid">
    <div class="card"><div class="label">登録ライセンス数</div><div class="num">{count}</div></div>
    {applyUrl
      ? (<a class="card" href={applyUrl} target="_blank" rel="noreferrer" style="text-decoration:none;color:inherit"><strong>団体を申し込む（申込Worker）</strong><div class="muted">団体情報→プラン→同意（別Workerで稼働）</div></a>)
      : (<div class="card"><strong>団体を申し込む</strong><div class="muted">申込専用Workerを稼働後、APPLY_URL を設定すると表示されます。</div></div>)}
    <a class="card" href="/clients" style="text-decoration:none;color:inherit"><strong>クライアント管理</strong><div class="muted">一覧・エンタイトルメント・稼働状況</div></a>
    <a class="card" href="/notices" style="text-decoration:none;color:inherit"><strong>お知らせ配信</strong><div class="muted">更新・メンテ・重要通知</div></a>
  </div>
  <p class="muted" style="margin-top:1rem">クライアント管理・お知らせは <a href="/login">スタッフログイン</a>（管理者）が必要です。</p>
</Host>
