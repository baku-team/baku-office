---
export const prerender = false;
// Phase1：Googleログインは dev 省略（本番は /api/auth/google でログイン後に申込）。
const clientBase = "https://baku-office-app.fragrant-sun-78f3.workers.dev";
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>申込 — baku-office</title>
    <style>
      body { font-family: system-ui, sans-serif; max-width: 640px; margin: 2rem auto; padding: 0 1rem; color: #1c2530; }
      label { display: block; margin: .75rem 0 .25rem; font-weight: 600; }
      input, select { width: 100%; padding: .5rem; border: 1px solid #cbd5e1; border-radius: 8px; }
      button { margin-top: 1rem; padding: .6rem 1.2rem; background: #2563eb; color: #fff; border: 0; border-radius: 8px; cursor: pointer; }
      .out { margin-top: 1.5rem; padding: 1rem; background: #f1f5f9; border-radius: 8px; white-space: pre-wrap; }
      .muted { color: #64748b; font-size: .9rem; }
    </style>
  </head>
  <body>
    <h1>団体の申込</h1>
    <p class="muted">団体情報とプランを入力（Phase1：Google認証は省略）。Xは即時にライセンス発行（無料）。</p>
    <form id="f">
      <label>団体名</label><input name="orgName" required />
      <label>代表者名</label><input name="contactName" />
      <label>連絡先メール</label><input name="contactEmail" type="email" />
      <label>プラン</label>
      <select name="plan">
        <option value="X">X（完全無料）</option>
        <option value="Y">Y（AI・Gemini）</option>
        <option value="Z">Z（エージェント・LINE/Claude）</option>
      </select>
      <button type="submit">申し込む</button>
    </form>
    <div class="out" id="out" hidden></div>

    <script type="module" define:vars={{ clientBase }}>
      const f = document.getElementById("f");
      const out = document.getElementById("out");
      f.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(f));
        const r = await fetch("/api/apply", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(data) });
        const j = await r.json();
        out.hidden = false;
        if (!j.ok) { out.textContent = "エラー：" + JSON.stringify(j); return; }
        const activate = clientBase + "/activate?license_id=" + encodeURIComponent(j.licenseId);
        out.innerHTML =
          "✅ 発行しました\nライセンスID: " + j.licenseId + "\nプラン: " + j.plan + " / エンタイトルメント: " + j.entitlement +
          "\n\nクライアントの初期アクティベーションURL（団体へ案内）:\n" + activate +
          '\n\n<a href="' + activate + '">→ このURLでクライアントをアクティベート</a>';
      });
    </script>
  </body>
</html>
