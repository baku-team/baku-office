---
export const prerender = false;
import Host from "../layouts/Host.astro";
const env = Astro.locals.runtime.env;
const { getHostSession } = await import("../lib/hostauth.ts");
const ses = await getHostSession(env, Astro.request);
if (!ses?.isAdmin) return Astro.redirect("/login", 302);
const { results } = await env.DB.prepare("SELECT id,severity,body,active,created_at FROM notices ORDER BY created_at DESC LIMIT 100").all<{ id: string; severity: string; body: string; active: number; created_at: number }>();
const d = (s: number) => new Date(s * 1000).toISOString().slice(0, 16).replace("T", " ");
---
<Host title="お知らせ配信" active="/notices">
  <h1>お知らせ・通知配信（§13.1）</h1>
  <p class="muted">クライアントは統合チェック(/api/check)でこれを受け取り表示。critical は確認モーダルで提示。</p>
  <div class="card">
    <div class="row">
      <select id="sev" style="flex:0 0 220px"><option value="info">info（一般）</option><option value="important">important（メンテ/障害）</option><option value="critical">critical（要確認）</option></select>
      <button class="btn btn-primary" id="pub" style="flex:0 0 auto">配信</button>
    </div>
    <div class="field"><textarea id="body" rows="2" placeholder="お知らせ本文（PIIなし）"></textarea></div>
  </div>
  <div class="table-wrap" style="margin-top:1rem"><table><thead><tr><th>日時</th><th>重要度</th><th>本文</th><th>状態</th><th></th></tr></thead><tbody>
    {results.map((n) => (<tr data-id={n.id}><td>{d(n.created_at)}</td><td>{n.severity}</td><td>{n.body}</td><td>{n.active ? "配信中" : "停止"}</td><td>{n.active ? <button class="btn btn-sm btn-danger off">停止</button> : ""}</td></tr>))}
    {results.length === 0 && (<tr><td colspan="5" class="muted">お知らせはありません。</td></tr>)}
  </tbody></table></div>
  <script slot="scripts" is:inline>
    document.getElementById("pub").addEventListener("click", async (e) => {
      const body = document.getElementById("body").value;
      if (!body) { window.bo.toast("本文を入力してください", "err"); return; }
      const r = await window.bo.api("/api/notices", { severity: document.getElementById("sev").value, body }, { btn: e.currentTarget, successMsg: "配信しました" });
      if (r.ok) setTimeout(() => location.reload(), 600);
    });
    document.querySelectorAll("tr[data-id] .off").forEach((b) => b.addEventListener("click", async (e) => { const r = await window.bo.api("/api/notices", { _action: "deactivate", id: e.target.closest("tr").dataset.id }, { btn: e.target, successMsg: "停止しました" }); if (r.ok) setTimeout(() => location.reload(), 500); }));
  </script>
</Host>
