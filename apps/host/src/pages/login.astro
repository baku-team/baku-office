---
import { env } from "cloudflare:workers";
export const prerender = false;
import Host from "../layouts/Host.astro";
const { googleEnabled } = await import("../lib/hostauth.ts");
const google = googleEnabled(env);
const e = Astro.url.searchParams.get("e");
---
<Host title="スタッフログイン" auth={false}>
  <h1 style="margin-top:1rem">baku-office ホスト管理</h1>
  {e && <div class="banner banner-danger">{e === "state" ? "セッション切れ。再度お試しください。" : "認証に失敗しました。"}</div>}
  <div class="card">
    {google
      ? <><p class="muted">スタッフのGoogleアカウントでログイン（HOST_ADMIN_EMAILS の管理者のみ操作可）。</p><a class="btn btn-primary" href="/api/auth/google/start">Googleでログイン</a></>
      : <><p class="muted">Google未設定。dev管理者ログイン：</p><button class="btn btn-primary" id="dev">管理者としてログイン（dev）</button></>}
  </div>
  <script slot="scripts" is:inline>
    const d=document.getElementById("dev");
    if(d)d.addEventListener("click",async(e)=>{const r=await window.bo.api("/api/auth/dev",undefined,{btn:e.currentTarget,successMsg:"ログインしました"});if(r.ok)location.href="/clients";});
  </script>
</Host>
