---
export const prerender = false;
const deployUrl = "https://deploy.workers.cloudflare.com/?url=https://github.com/baku-team/baku-office-app";
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>団体の申込 — baku-office</title>
    <style>
      * { box-sizing: border-box; }
      body { font-family: system-ui, "Hiragino Sans", "Noto Sans JP", Meiryo, sans-serif; margin: 0; background: #f4f6f9; color: #1f2933; line-height: 1.7; }
      .wrap { max-width: 680px; margin: 0 auto; padding: 28px 16px 72px; }
      h1 { color: #14365c; margin: .2rem 0 .4rem; }
      h2 { color: #14365c; font-size: 1.1rem; margin: 1.4rem 0 .4rem; }
      .brand { color: #14365c; font-weight: 800; letter-spacing: .02em; }
      .card { background: #fff; border: 1px solid #dde3ea; border-radius: 10px; padding: 16px; margin: 12px 0; }
      .field { margin: 10px 0; display: flex; flex-direction: column; gap: 4px; }
      .field label { font-size: .85rem; color: #5b6770; }
      .field input, .field select { padding: 9px; border: 1px solid #dde3ea; border-radius: 6px; font: inherit; background: #fff; }
      .btn { background: #14365c; color: #fff; border: 0; border-radius: 8px; padding: 11px 20px; font-weight: 700; cursor: pointer; }
      .btn[disabled] { opacity: .6; }
      .muted { color: #6b7785; }
      .steps { counter-reset: s; list-style: none; padding: 0; margin: .4rem 0; }
      .steps li { position: relative; padding: 8px 0 8px 38px; border-bottom: 1px dashed #e3e8ee; }
      .steps li:last-child { border-bottom: 0; }
      .steps li::before { counter-increment: s; content: counter(s); position: absolute; left: 0; top: 8px; width: 26px; height: 26px; background: #14365c; color: #fff; border-radius: 50%; text-align: center; line-height: 26px; font-weight: 800; font-size: .85rem; }
      .steps a { color: #14365c; }
      .ok { color: #1f7a4d; font-weight: 700; }
      code { background: #eef1f5; padding: 1px 6px; border-radius: 4px; font-size: .88em; word-break: break-all; }
      #out { white-space: normal; }
      #toasts { position: fixed; left: 0; right: 0; bottom: 16px; display: flex; flex-direction: column; align-items: center; gap: 8px; pointer-events: none; }
      .toast { background: #1f2933; color: #fff; padding: 9px 16px; border-radius: 8px; font-size: .9rem; opacity: 0; transform: translateY(8px); transition: .2s; }
      .toast.show { opacity: 1; transform: none; }
      .toast.err { background: #c0392b; } .toast.ok { background: #1f7a4d; }
      .spin { display: inline-block; width: 12px; height: 12px; border: 2px solid #fff; border-top-color: transparent; border-radius: 50%; animation: s .6s linear infinite; vertical-align: -1px; margin-right: 6px; }
      @keyframes s { to { transform: rotate(360deg); } }
    </style>
  </head>
  <body>
    <main class="wrap">
      <div class="brand">baku-office</div>
      <h1>団体の申込</h1>
      <p class="muted">会計・庶務のクラウドアシスタントを、団体ご自身の Cloudflare に設置（自己ホスト）します。申込後、画面の案内に沿ってワンクリックで導入できます。</p>

      <div class="card">
        <h2>① 事前に必要なアカウント</h2>
        <p class="muted">まず <strong>Google アカウント</strong>を用意し、それを使って Cloudflare・GitHub を作成すると一元管理できて簡単です（いずれも無料）。</p>
        <ol class="steps">
          <li><strong>Google アカウント（必須・最初に）</strong><br><span class="muted">未取得なら </span><a href="https://accounts.google.com/signup" target="_blank" rel="noreferrer">作成</a><span class="muted">。以降のログインに使います。</span></li>
          <li><strong>Cloudflare</strong>（アプリの設置先）<br><span class="muted"><a href="https://dash.cloudflare.com/sign-up" target="_blank" rel="noreferrer">登録ページ</a> で「<strong>Sign up with Google</strong>（Googleで登録）」を選び、上の Google アカウントで作成。</span></li>
          <li><strong>GitHub</strong>（導入時にアプリを複製）<br><span class="muted"><a href="https://github.com/signup" target="_blank" rel="noreferrer">登録ページ</a> で「<strong>Continue with Google</strong>（Googleで続行）」を選び、上の Google アカウントで作成。</span></li>
        </ol>
        <p class="muted">※（任意）AI機能を使う場合は、後で Gemini／（Pro）LINE・Claude の API キーを管理画面で登録します。</p>
      </div>

      <div class="card">
        <h2>② 団体情報とプランを入力</h2>
        <div class="field"><label>団体名</label><input id="orgName" required /></div>
        <div class="field"><label>代表者名</label><input id="contactName" /></div>
        <div class="field"><label>連絡先メール</label><input id="contactEmail" type="email" /></div>
        <div class="field"><label>プラン</label>
          <select id="plan">
            <option value="free">Free（完全無料）</option>
            <option value="plus">Plus（AI・Gemini）</option>
            <option value="pro">Pro（エージェント・LINE/Claude）</option>
          </select>
        </div>
        <button class="btn" id="submit">申し込む</button>
      </div>

      <div class="card" id="out" hidden></div>
    </main>
    <div id="toasts" aria-live="polite"></div>

    <script is:inline define:vars={{ deployUrl }}>
      const wrap = document.getElementById("toasts");
      function toast(msg, kind = "ok") {
        const el = document.createElement("div");
        el.className = "toast " + (kind === "err" ? "err" : "ok");
        el.textContent = msg; wrap.appendChild(el);
        requestAnimationFrame(() => el.classList.add("show"));
        setTimeout(() => { el.classList.remove("show"); setTimeout(() => el.remove(), 250); }, kind === "err" ? 5000 : 2800);
      }
      function busy(btn, on) { if (!btn) return; if (on) { btn.disabled = true; btn.dataset.label = btn.innerHTML; btn.innerHTML = '<span class="spin"></span>処理中…'; } else { btn.disabled = false; if (btn.dataset.label) btn.innerHTML = btn.dataset.label; } }

      document.getElementById("submit").addEventListener("click", async (e) => {
        const body = { orgName: orgName.value, contactName: contactName.value, contactEmail: contactEmail.value, plan: plan.value };
        if (!body.orgName) { toast("団体名を入力してください", "err"); return; }
        const btn = e.currentTarget; busy(btn, true);
        let j = {};
        try {
          const r = await fetch("/api/apply", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
          j = await r.json().catch(() => ({}));
          if (!r.ok || j.error) { toast("エラー：" + (j.error || r.status), "err"); return; }
        } catch { toast("通信に失敗しました", "err"); return; } finally { busy(btn, false); }

        toast("申込が完了しました");
        const out = document.getElementById("out");
        out.hidden = false;
        const planLabel = { free: "Free", plus: "Plus", pro: "Pro" }[j.plan] || j.plan;
        out.innerHTML =
          '<h2><span class="ok">✅ 申込が完了しました</span></h2>' +
          '<p class="muted">プラン：<strong>' + planLabel + '</strong>／ライセンスID：<code>' + j.licenseId + '</code></p>' +
          '<h2>③ アプリを導入（このまま進めてください）</h2>' +
          '<ol class="steps">' +
          '<li><strong>下のボタンでデプロイ</strong><br><span class="muted">Cloudflare と GitHub にログインすると、あなたの Cloudflare にアプリが作られます（鍵などの設定は不要）。</span><br><br>' +
          '<a href="' + deployUrl + '" target="_blank" rel="noreferrer"><img src="https://deploy.workers.cloudflare.com/button" alt="Deploy to Cloudflare" height="36"></a></li>' +
          '<li><strong>アクティベート</strong><br><span class="muted">デプロイ完了後に表示される「あなたのアプリのURL」を開き、その末尾に次を付けてアクセスします：</span><br><code>/activate?license_id=' + j.licenseId + '</code></li>' +
          '<li><strong>Google でログイン</strong><br><span class="muted">団体の Google アカウントでログインすれば利用開始です。</span></li>' +
          '</ol>' +
          '<p class="muted">このライセンスIDは控えておいてください（アクティベートに使います）。</p>';
        out.scrollIntoView({ behavior: "smooth" });
      });
    </script>
  </body>
</html>
